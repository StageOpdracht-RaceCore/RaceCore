@model StageProject_RaceCore.Models.Stage
@using StageProject_RaceCore.Models

@{
    // Prepare view-specific data passed from the controller via ViewBag
    var top25 = ViewBag.Top25 as List<StageResult> ?? new List<StageResult>();
    var jerseys = ViewBag.Jerseys as List<StageResult> ?? new List<StageResult>();
    // Use the shared clean layout for stage pages
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
}

@* Stylesheet for stage views (asp-append-version for cache busting) *@
<link rel="stylesheet" href="~/css/Stage.css" asp-append-version="true" />

@* Back link to the stages index *@
<div style="margin-bottom: 10px;">
    <a asp-action="Index" class="app-btn">
        ← Back to stages
    </a>
</div>

<div class="stage-page">

    @* HEADER: Stage title and date *@
    <section class="stage-header-card">
        <div class="stage-details-header">
            <h1>@Model.Name</h1>
            <p>@Model.Date?.ToString("dd MMM yyyy")</p>
        </div>
    </section>

    @* TOP 25 *@
    <section class="stage-table-card stage-details-section">
        <h2>Top 25</h2>

        @if (top25.Any())
        {
            <table class="stage-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Cyclist</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in top25)
                    {
                        var rowClass = r.Position == 1 ? "top-1"
                                     : r.Position == 2 ? "top-2"
                                     : r.Position == 3 ? "top-3"
                                     : "";

                        <tr class="@rowClass">
                            <td>@r.Position</td>
                            <td>@r.Cyclist.FirstName @r.Cyclist.LastName</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="stage-details-empty">
                No results available.
            </div>
        }
    </section>

    @* JERSEYS *@
    <section class="stage-table-card stage-details-section">
        <h2>Jersey holders</h2>

        @if (jerseys.Any())
        {
            <table class="stage-table stage-jersey-table">
                <thead>
                    <tr>
                        <th>Cyclist</th>
                        <th>Type</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in jerseys)
                    {
                        <tr>
                            <td>@r.Cyclist.FirstName @r.Cyclist.LastName</td>
                            <td>
                                <span class="jersey-badge">
                                    Jersey
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="stage-details-empty">
                No jersey holders available.
            </div>
        }
    </section>

</div>