@model StageProject_RaceCore.Models.DashboardViewModel

@{
    ViewData["Title"] = "Game Dashboard";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";

    int gameId = ViewBag.GameId ?? 0;
    int raceId = ViewBag.RaceId ?? 0;
    string gameStatus = ViewBag.GameStatus ?? "Unknown";
    string raceName = ViewBag.RaceName ?? "No active game";
    int currentStage = ViewBag.CurrentStage ?? 0;

    int maxPlayerPoints = Model.PlayerRanking.Any()
        ? Math.Max(1, Model.PlayerRanking.Max(x => x.Points))
        : 1;
}

<link rel="stylesheet" href="~/css/Dashboard.css" asp-append-version="true" />

@if (ViewBag.DatabaseOnline == false)
{
    <div class="alert-box alert-warning">⚠️ Database not reachable. Start OpenVPN to view live data.</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert-box alert-error">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
    <div class="alert-box alert-success">@TempData["Success"]</div>
}

@functions {
    public string GetPlayerColor(string playerName)
    {
        var colors = new List<string> { "#2563eb", "#16a34a", "#f59e0b", "#dc2626", "#7c3aed", "#0891b2" };

        if (string.IsNullOrWhiteSpace(playerName))
        {
            return colors[0];
        }

        int total = 0;

        foreach (char letter in playerName.ToLower())
        {
            total += letter;
        }

        return colors[Math.Abs(total) % colors.Count];
    }

    public string GetInitial(string name)
    {
        return string.IsNullOrWhiteSpace(name) ? "?" : name.Substring(0, 1).ToUpper();
    }

    public string GetJerseyClass(string type)
    {
        string value = (type ?? "").ToLower();

        if (value.Contains("yellow") || value.Contains("gele")) return "jersey yellow";
        if (value.Contains("green") || value.Contains("groene")) return "jersey green";
        if (value.Contains("mountain") || value.Contains("bolletjes") || value.Contains("polka")) return "jersey polka";
        if (value.Contains("white") || value.Contains("witte")) return "jersey white";

        return "jersey default";
    }
}

<div class="dashboard-container">

    <section class="dashboard-hero">
        <div>
            <div class="small-title">RaceCore Game Hub</div>
            <h1>@raceName</h1>
            <p>
                Status: <strong>@gameStatus</strong> |
                Stage: <strong>@currentStage</strong> |
                Game ID: <strong>@gameId</strong>
            </p>
        </div>
    </section>

    <section class="stats-row">
        <div class="stat-box blue">
            <div class="stat-icon">👤</div>
            <div>
                <span>Players</span>
                <strong>@Model.PlayersCount</strong>
            </div>
        </div>

        <div class="stat-box orange">
            <div class="stat-icon">🎯</div>
            <div>
                <span>Draft Picks</span>
                <strong>@Model.TotalDraftPicks</strong>
            </div>
        </div>

        <div class="stat-box purple">
            <div class="stat-icon">🏁</div>
            <div>
                <span>Status</span>
                <strong>@gameStatus</strong>
            </div>
        </div>
    </section>

    <section class="main-dashboard-grid">

        <div class="card">
            <div class="card-title">
                <span>Competition</span>
                <h2>Player Ranking</h2>
            </div>

            @if (Model.PlayerRanking.Any())
            {
                <div class="ranking-list">
                    @foreach (var player in Model.PlayerRanking)
                    {
                        int width = player.Points > 0
                            ? Math.Max(8, (int)Math.Round((double)player.Points / maxPlayerPoints * 100))
                            : 8;

                        string color = GetPlayerColor(player.PlayerName);

                        <div class="ranking-row">
                            <div class="ranking-left">
                                <div class="ranking-number">#@player.Position</div>

                                <div class="player-avatar" style="background:@color;">
                                    @GetInitial(player.PlayerName)
                                </div>

                                <div class="ranking-info">
                                    <div class="player-name">
                                        <span style="background:@color;"></span>
                                        <strong>@player.PlayerName</strong>
                                    </div>

                                    <div class="progress-bar">
                                        <div class="progress-fill" style="width:@width%; background:@color;"></div>
                                    </div>
                                </div>
                            </div>

                            <strong class="points">@player.Points pts</strong>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">No ranking available yet.</div>
            }
        </div>

        <div class="card">
            <div class="card-title">
                <span>Game</span>
                <h2>Game Progress</h2>
            </div>

            <div class="info-grid">
                <div class="info-box">
                    <span>Race</span>
                    <strong>@raceName</strong>
                </div>

                <div class="info-box">
                    <span>Status</span>
                    <strong>@gameStatus</strong>
                </div>

                <div class="info-box">
                    <span>Stage</span>
                    <strong>@currentStage</strong>
                </div>

                <div class="info-box">
                    <span>Total Picks</span>
                    <strong>@Model.TotalDraftPicks</strong>
                </div>
            </div>

            <div class="draft-progress-box">
                <div class="draft-progress-top">
                    <span>Draft Progress</span>
                    <strong>@Model.TotalDraftPicks picks</strong>
                </div>

                <div class="progress-bar">
                    <div class="progress-fill green-fill" style="width:@(Model.TotalDraftPicks == 0 ? 5 : 100)%"></div>
                </div>
            </div>

            <div class="game-next-box">
                @if (gameStatus == "Draft")
                {
                    <h3>Next Step</h3>
                    <p>The game is still in draft mode. Pick all riders first.</p>

                    <a asp-controller="Draft"
                           asp-action="Index"
                           asp-route-gameId="@gameId"
                           class="btn-green">
                        Continue Draft
                    </a>
                }
                else if (gameStatus == "Active")
                {
                    <h3>Next Step</h3>
                    <p>The draft is complete. Go to scoring to manage stages and results.</p>

                    <a asp-controller="Scoring"
                           asp-action="Index"
                           asp-route-raceId="@raceId"
                           class="btn-green">
                        Go to Scoring
                    </a>
                }
                else
                {
                    <h3>Game Finished</h3>
                    <p>All stages have been processed. View the final leaderboard.</p>

                    <a asp-controller="Result"
                           asp-action="Index"
                           asp-route-gameId="@gameId"
                           class="btn-green">
                        View Leaderboard
                    </a>
                }
            </div>

            <div class="dashboard-actions">
                <a asp-controller="Scoring" asp-action="Index" asp-route-raceId="@raceId" class="dashboard-action-btn">Scoring</a>
                <a asp-controller="Stage" asp-action="Index" asp-route-raceId="@raceId" class="dashboard-action-btn">Stages</a>
                <a asp-controller="Result" asp-action="Index" asp-route-gameId="@gameId" class="dashboard-action-btn">Leaderboard</a>
                <a asp-controller="Game" asp-action="New" class="dashboard-action-btn">New Game</a>
            </div>
        </div>

    </section>

    <section class="bottom-dashboard-grid">

        <div class="card">
            <div class="card-title">
                <span>Performance</span>
                <h2>Top Cyclists</h2>
            </div>

            @if (Model.TopCyclists.Any())
            {
                <div class="simple-list">
                    @foreach (var cyclist in Model.TopCyclists)
                    {
                        <div class="simple-row">
                            <strong>@cyclist.Name</strong>
                            <span>@cyclist.Points pts</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">No cyclist points available yet.</div>
            }
        </div>

        <div class="card">
            <div class="card-title">
                <span>Classifications</span>
                <h2>Jerseys</h2>
            </div>

            @if (Model.Jerseys.Any())
            {
                <div class="simple-list">
                    @foreach (var jersey in Model.Jerseys)
                    {
                        <div class="simple-row">
                            <span class="@GetJerseyClass(jersey.Type)">@jersey.Type</span>
                            <strong>@jersey.CyclistName</strong>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-box">No jersey holders available yet.</div>
            }
        </div>

    </section>
</div>