@model StageProject_RaceCore.Models.TeamIndexViewModel
@using System.Linq
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var searchQuery = (Context.Request.Query["search"].ToString() ?? "").Trim();
    var openTeamIdValue = Context.Request.Query["openTeamId"].ToString();
    int.TryParse(openTeamIdValue, out var openTeamId);

    bool MatchesSearch(string? value) =>
        !string.IsNullOrWhiteSpace(value) &&
        value.Contains(searchQuery, StringComparison.OrdinalIgnoreCase);

    var allTeams = (Model?.Teams ?? Enumerable.Empty<TeamViewModel>())
        .OrderByDescending(team => team.ActiveCyclistsCount + team.BenchCyclistsCount)
        .ToList();

    var teams = allTeams
        .Where(team =>
            string.IsNullOrWhiteSpace(searchQuery) ||
            MatchesSearch(team.Name) ||
            MatchesSearch(team.Tag) ||
            (team.ActiveCyclists?.Any(c => MatchesSearch($"{c.FirstName} {c.LastName}")) ?? false) ||
            (team.BenchCyclists?.Any(c => MatchesSearch($"{c.FirstName} {c.LastName}")) ?? false))
        .ToList();

    var availableCyclists = (Model?.AvailableCyclists ?? Enumerable.Empty<Cyclist>())
        .ToList();

    var totalCyclistMatches = string.IsNullOrWhiteSpace(searchQuery)
        ? 0
        : teams.Sum(team =>
            (team.ActiveCyclists?.Count(c => MatchesSearch($"{c.FirstName} {c.LastName}")) ?? 0) +
            (team.BenchCyclists?.Count(c => MatchesSearch($"{c.FirstName} {c.LastName}")) ?? 0));

    string GetTeamStyle(TeamViewModel team)
    {
        var tag = (team.Tag ?? "").Trim().ToUpperInvariant();

        return tag switch
        {
            "WT" => "--team-color: #dc2626; --team-color-soft: rgba(220, 38, 38, 0.10); --team-color-border: rgba(220, 38, 38, 0.28); --team-color-contrast: #ffffff;",
            "PRT" => "--team-color: #16a34a; --team-color-soft: rgba(22, 163, 74, 0.10); --team-color-border: rgba(22, 163, 74, 0.28); --team-color-contrast: #ffffff;",
            "CT" => "--team-color: #f59e0b; --team-color-soft: rgba(245, 158, 11, 0.12); --team-color-border: rgba(245, 158, 11, 0.32); --team-color-contrast: #ffffff;",
            _ => "--team-color: #7c3aed; --team-color-soft: rgba(124, 58, 237, 0.10); --team-color-border: rgba(124, 58, 237, 0.28); --team-color-contrast: #ffffff;"
        };
    }

    string ToggleUrl(int teamId)
    {
        var url = Url.Action("Index", "Team", new
        {
            search = searchQuery,
            openTeamId = openTeamId == teamId ? (int?)null : teamId
        }) ?? "#";

        return $"{url}#team-{teamId}";
    }
}

<link rel="stylesheet" href="~/css/Team.css" />

<div class="team-page">
    <div class="team-header-card">
        <div>
            <p class="team-page-kicker">RaceCore</p>
            <h1 class="team-page-title">Teams</h1>
            <p class="team-page-subtitle">Overview of all pro cycling teams, their rosters, and current points.</p>
        </div>
    </div>

    @if (!allTeams.Any())
    {
        <div class="team-table-card team-empty-state">
            <h3>No teams found</h3>
            <p>There are currently no teams in the system.</p>
        </div>
    }
    else
    {
        <div class="team-toolbar-card">
            <form asp-controller="Team" asp-action="Index" method="get" class="team-search-form">
                <div class="team-search-group">
                    <label for="teamSearch">Search teams or cyclists</label>
                    <input type="text"
                           id="teamSearch"
                           name="search"
                           value="@searchQuery"
                           class="team-search-input"
                           placeholder="Search by team or cyclist name&hellip;" />
                </div>

                <div class="team-toolbar-actions">
                    <button type="submit" class="team-btn team-btn-primary">Search</button>

                    @if (!string.IsNullOrWhiteSpace(searchQuery))
                    {
                        <a asp-controller="Team" asp-action="Index" class="team-btn team-btn-light">Clear</a>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(searchQuery))
                {
                    <div class="team-search-count">
                        @teams.Count team@(teams.Count == 1 ? "" : "s") found

                        @if (totalCyclistMatches > 0)
                        {
                            <span>&middot; @totalCyclistMatches cyclist@(totalCyclistMatches == 1 ? "" : "s") matched</span>
                        }
                    </div>
                }
            </form>
        </div>

        @if (!teams.Any())
        {
            <div class="team-table-card team-empty-state">
                <h3>No search results</h3>
                <p>No teams or cyclists match “@searchQuery”.</p>
                <a asp-controller="Team" asp-action="Index" class="team-btn team-btn-primary">Show all teams</a>
            </div>
        }
        else
        {
            <div class="teams-grid teams-grid-wide-gap">
                @foreach (var team in teams)
                {
                    var totalCyclists = team.ActiveCyclistsCount + team.BenchCyclistsCount;
                    var isExpanded = false;
                    var cardClass = isExpanded ? "team-card" : "team-card collapsed";

                    <div id="team-@team.Id" class="@cardClass" style="@GetTeamStyle(team)">
                        <div class="team-header">
                            <div class="team-meta">
                                <div class="team-avatar">@team.Tag</div>

                                <div>
                                    <div class="team-name">@team.Name</div>
                                    <div class="team-cyclist-count">@totalCyclists cyclists</div>
                                </div>
                            </div>

                            <div class="team-stats">
                                <div class="team-stats-top">
                                    <div class="team-points">@team.TeamPoints pts</div>

                                    <button type="button"
                                            class="collapse-toggle"
                                            aria-expanded="@isExpanded.ToString().ToLower()">
                                        <span class="collapse-text">@(isExpanded ? "Close" : "Open")</span>
                                        <span class="arrow">&#9662;</span>
                                    </button>
                                </div>

                                <div class="team-counts">
                                    Active: <strong>@team.ActiveCyclistsCount</strong>
                                    &middot;
                                    Bench: <strong>@team.BenchCyclistsCount</strong>
                                </div>
                            </div>
                        </div>

                        <div class="team-body">
                            <div class="team-management">
                                <div class="team-management-title">Add cyclist to team</div>

                                @if (availableCyclists.Any())
                                {
                                    <form asp-controller="Team"
                                          asp-action="AddCyclistToTeam"
                                          method="post"
                                          class="add-cyclist-form">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="teamId" value="@team.Id" />

                                        <select name="cyclistId" class="add-cyclist-select" aria-label="Select cyclist to add" required>
                                            <option value="">Select cyclist</option>

                                            @foreach (var cyclist in availableCyclists)
                                            {
                                                <option value="@cyclist.Id">@cyclist.FirstName @cyclist.LastName</option>
                                            }
                                        </select>

                                        <select name="isActive" class="add-cyclist-status" aria-label="Choose cyclist status">
                                            <option value="true">Active</option>
                                            <option value="false">Bench</option>
                                        </select>

                                        <button type="submit" class="team-btn team-btn-primary add-cyclist-btn">
                                            Add to team
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <div class="empty team-management-empty">No unassigned cyclists available</div>
                                }
                            </div>

                            <div class="composition">
                                <div class="column">
                                    <h4>Active</h4>

                                    @if (team.ActiveCyclists?.Any() ?? false)
                                    {
                                        <ul class="cyclist-list">
                                            @foreach (var cyclist in team.ActiveCyclists)
                                            {
                                                var cyclistFullName = $"{cyclist.FirstName} {cyclist.LastName}";
                                                var isCyclistMatch =
                                                    string.IsNullOrWhiteSpace(searchQuery) ||
                                                    MatchesSearch(cyclistFullName) ||
                                                    MatchesSearch(team.Name) ||
                                                    MatchesSearch(team.Tag);

                                                if (isCyclistMatch)
                                                {
                                                    <li>
                                                        <span class="cyclist-name-text">@cyclistFullName</span>

                                                        <div class="cyclist-actions">
                                                            <form asp-controller="Team" asp-action="ToggleCyclistStatus" method="post" class="cyclist-form">
                                                                @Html.AntiForgeryToken()

                                                                <input type="hidden" name="cyclistId" value="@cyclist.Id" />
                                                                <input type="hidden" name="isActive" value="false" />

                                                                <button type="submit" class="bench-btn">Bench</button>
                                                            </form>

                                                            <form asp-controller="Team" asp-action="RemoveCyclistFromTeam" method="post" class="cyclist-form">
                                                                @Html.AntiForgeryToken()

                                                                <input type="hidden" name="cyclistId" value="@cyclist.Id" />

                                                                <button type="submit" class="remove-btn">Remove</button>
                                                            </form>
                                                        </div>
                                                    </li>
                                                }
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <div class="empty">No active cyclists</div>
                                    }
                                </div>

                                <div class="column">
                                    <h4>Bench</h4>

                                    @if (team.BenchCyclists?.Any() ?? false)
                                    {
                                        <ul class="cyclist-list">
                                            @foreach (var cyclist in team.BenchCyclists)
                                            {
                                                var cyclistFullName = $"{cyclist.FirstName} {cyclist.LastName}";
                                                var isCyclistMatch =
                                                    string.IsNullOrWhiteSpace(searchQuery) ||
                                                    MatchesSearch(cyclistFullName) ||
                                                    MatchesSearch(team.Name) ||
                                                    MatchesSearch(team.Tag);

                                                if (isCyclistMatch)
                                                {
                                                    <li>
                                                        <span class="cyclist-name-text">@cyclistFullName</span>

                                                        <div class="cyclist-actions">
                                                            <form asp-controller="Team" asp-action="ToggleCyclistStatus" method="post" class="cyclist-form">
                                                                @Html.AntiForgeryToken()

                                                                <input type="hidden" name="cyclistId" value="@cyclist.Id" />
                                                                <input type="hidden" name="isActive" value="true" />

                                                                <button type="submit" class="activate-btn">Activate</button>
                                                            </form>

                                                            <form asp-controller="Team" asp-action="RemoveCyclistFromTeam" method="post" class="cyclist-form">
                                                                @Html.AntiForgeryToken()

                                                                <input type="hidden" name="cyclistId" value="@cyclist.Id" />

                                                                <button type="submit" class="remove-btn">Remove</button>
                                                            </form>
                                                        </div>
                                                    </li>
                                                }
                                            }
                                        </ul>
                                    }
                                    else
                                    {
                                        <div class="empty">No cyclists on the bench</div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {

        const buttons = document.querySelectorAll(".collapse-toggle");

        buttons.forEach(button => {
            button.addEventListener("click", function () {

                const card = button.closest(".team-card");
                if (!card) return;

                // Toggle open/dicht
                card.classList.toggle("collapsed");

                const isExpanded = !card.classList.contains("collapsed");

                // Update tekst
                const text = button.querySelector(".collapse-text");
                if (text) {
                    text.textContent = isExpanded ? "Close" : "Open";
                }

                // Update aria
                button.setAttribute("aria-expanded", isExpanded);

                // (optioneel) smooth scroll bij openen
                if (isExpanded) {
                    card.scrollIntoView({
                        behavior: "smooth",
                        block: "start"
                    });
                }
            });
        });

    });
</script>