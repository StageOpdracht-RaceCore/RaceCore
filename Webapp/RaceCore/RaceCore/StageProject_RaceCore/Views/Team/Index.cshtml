@* ─────────────────────────────────────────────────────────────────────────────
   Team/Index.cshtml
   Renders the full Teams overview page: game banner, stats, player cards,
   roster tables with active/bench/DQ sections, and the swap/disqualify UI.
   ───────────────────────────────────────────────────────────────────────────── *@
@model StageProject_RaceCore.Models.PlayerTeamsPageViewModel

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
}

@* Razor helper functions that safely render rider name and pro-team, returning "Free slot" / "-" for nulls. *@
@functions {
    public string RiderName(StageProject_RaceCore.Models.PlayerTeamRiderViewModel? rider)
    {
        return rider == null ? "Free slot" : rider.FullName;
    }

    public string RiderTeam(StageProject_RaceCore.Models.PlayerTeamRiderViewModel? rider)
    {
        return rider == null || string.IsNullOrWhiteSpace(rider.ProTeamName)
            ? "-"
            : rider.ProTeamName;
    }
}

<link rel="stylesheet" href="~/css/Team.css" asp-append-version="true" />

@* ─── Page wrapper ─────────────────────────────────────────────────────────── *@
<div class="team-page dashboard-container" data-game-id="@Model.GameId">

    @* Hidden container storing the anti-forgery token so inline JS can read it for fetch POST requests. *@
    <div class="team-antiforgery">
        @Html.AntiForgeryToken()
    </div>

    @* ── Banner section ─────────────────────────────────────────────────────── *@
    <section class="team-page-banner page-banner">
        <div>
            <div class="small-title">RaceCore Game Hub</div>
            <h1>Teams</h1>
            <p>
                @if (Model.HasGame)
                {
                    <text>Race: <strong>@Model.RaceName</strong> | Status: <strong>@Model.GameStatus</strong></text>
                }
                else
                {
                    <text>Start a game first to view the player teams.</text>
                }
            </p>
        </div>

        <div class="team-banner-actions">
            <a asp-controller="Dashboard" asp-action="Index" class="team-dashboard-white-btn">
                Dashboard
            </a>
        </div>
    </section>

    @* ── Empty state (no players) ────────────────────────────────────────────── *@
    @if (!Model.PlayerTeams.Any())
    {
        <section class="card team-empty-state">
            <h2>No teams found</h2>
            <p>There is no active game with players or draft turns yet.</p>
            <a asp-controller="Game" asp-action="New" class="team-btn team-btn-primary">Start new game</a>
        </section>
    }
    else
    {
        @* ── Game overview card (stats row + info grid) ───────────────────────── *@
        <section class="card team-overview-card" aria-label="Game overview">
            <section class="stats-row team-stats-row" aria-label="Team overview">
                <div class="stat-box blue">
                    <div class="stat-icon">👥</div>
                    <div>
                        <span>Players</span>
                        <strong>@Model.PlayerCount</strong>
                    </div>
                </div>

                <div class="stat-box orange">
                    <div class="stat-icon">🚴</div>
                    <div>
                        <span>Active</span>
                        <strong>@Model.ActiveRiderSlots</strong>
                    </div>
                </div>

                <div class="stat-box purple">
                    <div class="stat-icon">🪑</div>
                    <div>
                        <span>Bench</span>
                        <strong>@Model.BenchRiderSlots</strong>
                    </div>
                </div>
            </section>

            <div class="info-grid">
                <div class="info-box">
                    <span>Game</span>
                    <strong>#@Model.GameId</strong>
                </div>

                <div class="info-box">
                    <span>Race</span>
                    <strong>@Model.RaceName</strong>
                </div>

                <div class="info-box">
                    <span>Filled</span>
                    <strong>@Model.FilledSlots / @Model.TotalSlots</strong>
                </div>

                <div class="info-box">
                    <span>Slots</span>
                    <strong>@Model.TotalSlots</strong>
                </div>
            </div>
        </section>

        @* ── Swap hint bar ───────────────────────────────────────────────────── *@
        <div class="team-swap-hint team-swap-hint-global" aria-live="polite">
            Click a rider to swap. Then select another rider from the bench riders list.
        </div>

        @* ── Player team cards grid ──────────────────────────────────────────── *@
        <section class="player-team-grid" aria-label="Player teams">
            @foreach (var playerTeam in Model.PlayerTeams)
            {
                var activePercent = Model.ActiveRiderSlots == 0
                    ? 0
                    : Math.Min(100, playerTeam.ActiveRiders.Count * 100 / Model.ActiveRiderSlots);

                @* Each card receives CSS custom properties (--player-color, --player-color-soft, etc.)
                   injected as inline styles so the CSS can theme each card independently. *@
                <article class="player-team-card"
                         data-player-id="@playerTeam.PlayerId"
                         style="--player-color:@playerTeam.Color; --player-color-soft:@playerTeam.ColorSoft; --player-color-dark:@playerTeam.ColorDark; --player-text-color:@playerTeam.TextColor;">
                    <header class="player-team-header">
                        <div class="player-team-identity">
                            <div class="player-team-avatar">@playerTeam.Initials</div>

                            <div>
                                <h2>@playerTeam.PlayerName</h2>
                                <p>@playerTeam.ActiveRiders.Count active riders, @playerTeam.BenchRiders.Count bench riders</p>
                            </div>
                        </div>

                        @* Completion bar showing active rider count vs. maximum slots. *@
                        <div class="team-completion">
                            <span>@playerTeam.ActiveRiders.Count / @Model.ActiveRiderSlots active</span>
                            <div class="team-completion-bar" aria-hidden="true">
                                <div style="width:@activePercent%;"></div>
                            </div>
                        </div>
                    </header>

                    @* ── Roster table ─────────────────────────────────────────── *@
                    <div class="player-roster-table-wrap">
                        <table class="player-roster-table">
                            <thead>
                                <tr>
                                    <th>No.</th>
                                    <th>Cyclist</th>
                                    <th>Team</th>
                                    <th>Role</th>
                                    <th></th>
                                </tr>
                            </thead>

                            <tbody>
                                @* ── Active riders section ────────────────────────── *@
                                <tr class="roster-section-row active-section">
                                    <th colspan="5">Active riders</th>
                                </tr>

                                @for (var index = 0; index < Model.ActiveRiderSlots; index++)
                                {
                                    var rider = playerTeam.ActiveRiders.ElementAtOrDefault(index);

                                    <tr class="roster-row active-rider @(rider == null ? "empty-slot" : "") @(index == Model.ActiveRiderSlots - 1 ? "roster-before-bench" : "")"
                                        data-section="active"
                                        onclick="selectRider(this)"
                                        role="button"
                                        tabindex="0"
                                        title="@(rider != null ? "Select to swap" : "Free slot")"
                                        data-cyclist-id="@(rider?.CyclistId ?? 0)">
                                        <td class="slot-number">@(index + 1)</td>
                                        <td>
                                            <span class="rider-name">@RiderName(rider)</span>
                                        </td>
                                        <td>
                                            <span class="rider-team">@RiderTeam(rider)</span>
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <span class="status-pill active">Cyclist</span>
                                            }
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <button type="button" class="dq-btn" onclick="disqualifyRider(event, this)" title="Disqualify">DQ</button>
                                            }
                                        </td>
                                    </tr>
                                }

                                @* ── Bench riders section ─────────────────────────── *@
                                <tr class="roster-section-row bench-section">
                                    <th colspan="5">Bench riders</th>
                                </tr>

                                @for (var index = 0; index < Model.BenchRiderSlots; index++)
                                {
                                    var rider = playerTeam.BenchRiders.ElementAtOrDefault(index);

                                    <tr class="roster-row bench-rider @(rider == null ? "empty-slot" : "")"
                                        data-section="bench"
                                        onclick="selectRider(this)"
                                        role="button"
                                        tabindex="0"
                                        title="@(rider != null ? "Select to swap" : "Free slot")"
                                        data-cyclist-id="@(rider?.CyclistId ?? 0)">
                                        <td class="slot-number">@(Model.ActiveRiderSlots + index + 1)</td>
                                        <td>
                                            <span class="rider-name">@RiderName(rider)</span>
                                        </td>
                                        <td>
                                            <span class="rider-team">@RiderTeam(rider)</span>
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <span class="status-pill bench">Bench</span>
                                            }
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <button type="button" class="dq-btn" onclick="disqualifyRider(event, this)" title="Disqualify">DQ</button>
                                            }
                                        </td>
                                    </tr>
                                }

                                @* ── Disqualified riders section (rendered only if there are any) ── *@
                                @if (playerTeam.DisqualifiedRiders.Any())
                                {
                                    <tr class="roster-section-row disqualified-section">
                                        <th colspan="5">Disqualified</th>
                                    </tr>

                                    @foreach (var rider in playerTeam.DisqualifiedRiders)
                                    {
                                        <tr class="roster-row disqualified-rider"
                                            data-section="disqualified"
                                            data-cyclist-id="@rider.CyclistId">
                                            <td class="slot-number"></td>
                                            <td>
                                                <span class="rider-name">@rider.FullName</span>
                                            </td>
                                            <td>
                                                <span class="rider-team">@rider.ProTeamName</span>
                                            </td>
                                            <td>
                                                <span class="status-pill disqualified">DQ</span>
                                            </td>
                                            <td>
                                                <button type="button" class="undq-btn" onclick="undisqualifyRider(event, this)" title="Undisqualify">UNDQ</button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </article>
            }
        </section>
    }
</div>

@* ─── Client-side JavaScript ─────────────────────────────────────────────────
   Handles the rider swap flow (select, highlight, swap rows optimistically, persist via fetch),
   as well as disqualify / undisqualify with optimistic DOM updates.
   ───────────────────────────────────────────────────────────────────────────── *@
<script>
    (function () {
        var selectedRow = null;

        /**
         * Called when a roster row is clicked (or activated via keyboard).
         * Orchestrates the two-click swap flow:
         *   1. First click on a rider → selects it, enters swap mode.
         *   2. Second click on a row in the opposite section → performs the swap.
         * If the same section is clicked again, the selection moves to the new row.
         */
        window.selectRider = function (row) {
            // If clicking an empty slot and nothing is selected, do nothing.
            if (!hasCyclist(row)) {
                if (!selectedRow) {
                    clearSelection();
                    return;
                }
            } else {
                // Clicking the already selected row → deselect.
                if (selectedRow === row) {
                    clearSelection();
                    return;
                }
            }

            var card = row.closest('.player-team-card');

            // First selection → enter swap mode.
            if (!selectedRow) {
                selectedRow = row;
                row.classList.add('roster-row--selected');
                enableSwapMode(card, row);
                return;
            }

            var firstCard = selectedRow.closest('.player-team-card');

            // Cross-card swap is not supported; re-select on the new card instead.
            if (firstCard !== card) {
                clearSelection();
                if (hasCyclist(row)) {
                    selectedRow = row;
                    row.classList.add('roster-row--selected');
                    enableSwapMode(card, row);
                }
                return;
            }

            var firstSection = selectedRow.dataset.section;
            var secondSection = row.dataset.section;

            // Same section → move the selection to the new row.
            if (firstSection === secondSection) {
                clearSelection();
                if (hasCyclist(row)) {
                    selectedRow = row;
                    row.classList.add('roster-row--selected');
                    enableSwapMode(card, row);
                }
                return;
            }

            // Opposite section → perform the swap.
            try {
                swapRows(selectedRow, row);
            } finally {
                clearSelection();
            }
        };

        /**
         * Highlights all rows in the opposite section as valid swap targets,
         * and dims rows in the same section (except the selected one).
         * Updates the hint text accordingly.
         */
        function enableSwapMode(card, selected) {
            if (!card) {
                return;
            }

            card.classList.add('swap-mode');

            var selectedSection = selected.dataset.section;
            var targetSection = selectedSection === 'active' ? 'bench' : 'active';

            // Highlight valid targets in the opposite section, including empty slots.
            card.querySelectorAll('.roster-row[data-section]').forEach(function (row) {
                row.classList.toggle('swap-target', row.dataset.section === targetSection);
                row.classList.toggle('swap-dimmed', row.dataset.section === selectedSection && row !== selected);
            });

            var hint = document.querySelector('.team-swap-hint-global');
            if (hint) {
                hint.textContent = targetSection === 'bench'
                    ? 'Selected. Now click a bench rider to swap.'
                    : 'Selected. Now click an active rider to swap.';
            }
        }

        /**
         * Optimistically swaps the content (name, team, cyclistId) between two rows,
         * then persists the change to the server via fetch.
         * On failure, the page is reloaded to revert to the server state.
         */
        function swapRows(rowA, rowB) {
            var cellsA = rowA.querySelectorAll('td');
            var cellsB = rowB.querySelectorAll('td');

            var activeRow = rowA.classList.contains('active-rider') ? rowA : rowB;
            var benchRow = activeRow === rowA ? rowB : rowA;
            var originalActiveCyclistId = activeRow.dataset.cyclistId;
            var originalBenchCyclistId = benchRow.dataset.cyclistId;

            // Swap the name cell HTML.
            var tmpName = cellsA[1].innerHTML;
            cellsA[1].innerHTML = cellsB[1].innerHTML;
            cellsB[1].innerHTML = tmpName;

            // Swap the team cell HTML.
            var tmpTeam = cellsA[2].innerHTML;
            cellsA[2].innerHTML = cellsB[2].innerHTML;
            cellsB[2].innerHTML = tmpTeam;

            // Swap the data-cyclist-id attributes.
            var tmpId = rowA.dataset.cyclistId;
            rowA.dataset.cyclistId = rowB.dataset.cyclistId;
            rowB.dataset.cyclistId = tmpId;

            // Refresh the status pill and DQ button in each row.
            updateRowState(rowA);
            updateRowState(rowB);

            // POST to the server.
            persistSwap(activeRow, originalActiveCyclistId, originalBenchCyclistId);
        }

        /**
         * Refreshes the status pill and action button in a row based on whether it
         * currently holds a cyclist (data-cyclist-id !== "0") or is empty.
         */
        function updateRowState(row) {
            if (!row) {
                return;
            }

            var id = row.dataset.cyclistId;
            var hasRider = id !== undefined && id !== '' && String(id) !== '0';

            row.classList.toggle('empty-slot', !hasRider);

            var cells = row.querySelectorAll('td');
            if (cells.length < 4) {
                return;
            }

            if (!hasRider) {
                // Empty slot: clear the status pill and action cell.
                cells[3].innerHTML = '';
                cells[4].innerHTML = '';
            } else {
                // Occupied: render the correct pill (active/bench) and a DQ button.
                var isActiveRow = row.classList.contains('active-rider');
                var pillClass = isActiveRow ? 'active' : 'bench';
                var pillLabel = isActiveRow ? 'Cyclist' : 'Bench';
                cells[3].innerHTML =
                    '<span class="status-pill ' + pillClass + '">' + pillLabel + '</span>';
                cells[4].innerHTML =
                    '<button type="button" class="dq-btn" onclick="disqualifyRider(event, this)" title="Disqualify">DQ</button>';
            }
        }

        /**
         * Returns true if the row has a non-zero data-cyclist-id (i.e. is occupied by a rider).
         */
        function hasCyclist(row) {
            if (!row) {
                return false;
            }

            var id = row.dataset.cyclistId;
            return id !== undefined && id !== '' && String(id) !== '0';
        }

        /**
         * Sends the swap to the server via a POST request.
         * Uses URL-encoded form data with the anti-forgery token.
         * If the server returns an error, reloads the page to revert the optimistic DOM update.
         */
        function persistSwap(activeRow, activeCyclistId, benchCyclistId) {
            var card = activeRow.closest('.player-team-card');

            if (!card) {
                return;
            }

            var gameId = document.querySelector('.team-page')?.dataset?.gameId;
            var playerId = card.dataset.playerId;

            if (!gameId || !playerId) {
                return;
            }

            var token = document.querySelector('.team-antiforgery input[name="__RequestVerificationToken"]')?.value;

            if (!token) {
                return;
            }

            var body =
                '__RequestVerificationToken=' + encodeURIComponent(token) +
                '&gameId=' + encodeURIComponent(gameId) +
                '&playerId=' + encodeURIComponent(playerId) +
                '&activeCyclistId=' + encodeURIComponent(activeCyclistId) +
                '&benchCyclistId=' + encodeURIComponent(benchCyclistId);

            fetch('@Url.Action("SwapActiveBench", "Team")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: body
            }).then(function (r) {
                if (!r.ok) {
                    location.reload();
                }
            }).catch(function () {
                location.reload();
            });
        }

        /**
         * Disqualifies a rider: clears the source row in the DOM, creates/updates the
         * disqualified section with a new row, and posts to the server.
         */
        window.disqualifyRider = function (event, button) {
            event.stopPropagation();

            var row = button.closest('tr');
            if (!row || !hasCyclist(row)) return;

            var card = row.closest('.player-team-card');
            if (!card) return;

            var tbody = row.closest('tbody');
            if (!tbody) return;

            var cells = row.querySelectorAll('td');
            var cyclistId = row.dataset.cyclistId;
            var riderName = cells[1] ? cells[1].textContent.trim() : '';
            var riderTeam = cells[2] ? cells[2].textContent.trim() : '';

            // Clear the source row (make it an empty but clickable swap target).
            row.dataset.cyclistId = '0';
            row.classList.add('empty-slot');
            cells[1].innerHTML = '<span class="rider-name">Free slot</span>';
            cells[2].innerHTML = '<span class="rider-team">-</span>';
            cells[3].innerHTML = '';
            cells[4].innerHTML = '';
            row.setAttribute('title', 'Free slot');

            // Find or create the "Disqualified" section header row.
            var dqHeader = tbody.querySelector('.disqualified-section');
            if (!dqHeader) {
                dqHeader = document.createElement('tr');
                dqHeader.className = 'roster-section-row disqualified-section';
                var th = document.createElement('th');
                th.colSpan = 5;
                th.textContent = 'Disqualified';
                dqHeader.appendChild(th);
                tbody.appendChild(dqHeader);
            }

            // Build the disqualified rider row.
            var dqRow = document.createElement('tr');
            dqRow.className = 'roster-row disqualified-rider';
            dqRow.dataset.section = 'disqualified';
            dqRow.dataset.cyclistId = cyclistId;

            var td0 = document.createElement('td');
            td0.className = 'slot-number';
            dqRow.appendChild(td0);

            var td1 = document.createElement('td');
            td1.innerHTML = '<span class="rider-name">' + escapeHtml(riderName) + '</span>';
            dqRow.appendChild(td1);

            var td2 = document.createElement('td');
            td2.innerHTML = '<span class="rider-team">' + escapeHtml(riderTeam) + '</span>';
            dqRow.appendChild(td2);

            var td3 = document.createElement('td');
            td3.innerHTML = '<span class="status-pill disqualified">DQ</span>';
            dqRow.appendChild(td3);

            var td4 = document.createElement('td');
            td4.innerHTML = '<button type="button" class="undq-btn" onclick="undisqualifyRider(event, this)" title="Undisqualify">UNDQ</button>';
            dqRow.appendChild(td4);

            // Insert the new DQ row after the last existing DQ row, or after the DQ header.
            var lastDq = tbody.querySelector('.disqualified-rider:last-of-type');
            if (lastDq) {
                lastDq.parentNode.insertBefore(dqRow, lastDq.nextSibling);
            } else {
                dqHeader.parentNode.insertBefore(dqRow, dqHeader.nextSibling);
            }

            // Persist to server.
            var gameId = document.querySelector('.team-page')?.dataset?.gameId;
            var playerId = card.dataset.playerId;
            var token = document.querySelector('.team-antiforgery input[name="__RequestVerificationToken"]')?.value;

            if (gameId && playerId && token) {
                var body =
                    '__RequestVerificationToken=' + encodeURIComponent(token) +
                    '&gameId=' + encodeURIComponent(gameId) +
                    '&playerId=' + encodeURIComponent(playerId) +
                    '&cyclistId=' + encodeURIComponent(cyclistId);

                fetch('@Url.Action("DisqualifyCyclist", "Team")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: body
                }).catch(function () {});
            }
        };

        /**
         * Undisqualifies (restores) a previously disqualified rider: removes the DQ row,
         * finds the first empty slot (active first, then bench), fills it with the rider's data,
         * and posts to the server.
         */
        window.undisqualifyRider = function (event, button) {
            event.stopPropagation();

            var row = button.closest('tr');
            if (!row) return;

            var card = row.closest('.player-team-card');
            if (!card) return;

            var tbody = row.closest('tbody');
            if (!tbody) return;

            var cells = row.querySelectorAll('td');
            var cyclistId = row.dataset.cyclistId;
            var riderName = cells[1] ? cells[1].textContent.trim() : '';
            var riderTeam = cells[2] ? cells[2].textContent.trim() : '';

            // Capture game/player/token BEFORE removing the row from the DOM.
            var gameId = document.querySelector('.team-page')?.dataset?.gameId;
            var playerId = card.dataset.playerId;
            var token = document.querySelector('.team-antiforgery input[name="__RequestVerificationToken"]')?.value;

            // Remove the disqualified row from the DOM.
            row.parentNode.removeChild(row);

            // If no more disqualified rows remain, remove the section header too.
            var remaining = tbody.querySelectorAll('.disqualified-rider');
            if (remaining.length === 0) {
                var dqHeader = tbody.querySelector('.disqualified-section');
                if (dqHeader) dqHeader.parentNode.removeChild(dqHeader);
            }

            // Find the first empty slot (check active rows first, then bench rows).
            var emptyRow = null;
            var sections = ['.active-rider', '.bench-rider'];
            for (var s = 0; s < sections.length && !emptyRow; s++) {
                var rows = tbody.querySelectorAll(sections[s]);
                for (var i = 0; i < rows.length; i++) {
                    var r = rows[i];
                    var id = r.dataset.cyclistId;
                    if (id === undefined || id === '' || String(id) === '0') {
                        emptyRow = r;
                        break;
                    }
                }
            }

            if (emptyRow) {
                // Fill the empty slot with the restored rider's data.
                emptyRow.dataset.cyclistId = cyclistId;
                emptyRow.classList.remove('empty-slot');
                emptyRow.querySelectorAll('td')[1].innerHTML = '<span class="rider-name">' + escapeHtml(riderName) + '</span>';
                emptyRow.querySelectorAll('td')[2].innerHTML = '<span class="rider-team">' + escapeHtml(riderTeam) + '</span>';
                updateRowState(emptyRow);
            }

            // Persist to server.
            if (gameId && playerId && token) {
                var body =
                    '__RequestVerificationToken=' + encodeURIComponent(token) +
                    '&gameId=' + encodeURIComponent(gameId) +
                    '&playerId=' + encodeURIComponent(playerId) +
                    '&cyclistId=' + encodeURIComponent(cyclistId);

                fetch('@Url.Action("UndisqualifyCyclist", "Team")', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: body
                }).catch(function () {});
            }
        };

        /**
         * Escapes HTML entities in a string to prevent XSS when inserting user-controlled text
         * via innerHTML. Uses the browser's built-in text node serialisation.
         */
        function escapeHtml(str) {
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }

        /**
         * Toggles the empty-slot class on a target row and manages its interactivity
         * attributes based on whether the source row had a cyclist.
         * (This function is preserved but is no longer called in the current swap flow;
         *  swapRows + updateRowState handle row state directly.)
         */
        function toggleEmptyState(targetRow, sourceRow) {
            var isEmpty = !sourceRow.dataset.cyclistId || sourceRow.classList.contains('empty-slot');
            targetRow.classList.toggle('empty-slot', isEmpty);

            if (isEmpty) {
                delete targetRow.dataset.cyclistId;
                targetRow.removeAttribute('onclick');
                targetRow.removeAttribute('role');
                targetRow.removeAttribute('tabindex');
                targetRow.removeAttribute('title');
                targetRow.querySelectorAll('td')[3].innerHTML = '';
            } else {
                targetRow.setAttribute('onclick', 'selectRider(this)');
                targetRow.setAttribute('role', 'button');
                targetRow.setAttribute('tabindex', '0');
                targetRow.setAttribute('title', 'Select to swap');
                var isActive = targetRow.classList.contains('active-rider');
                var pillClass = isActive ? 'active' : 'bench';
                var pillLabel = isActive ? 'Cyclist' : 'Bench';
                targetRow.querySelectorAll('td')[3].innerHTML =
                    '<span class="status-pill ' + pillClass + '">' + pillLabel + '</span>';
            }
        }

        /**
         * Clears the current selection, removes visual highlights, and resets the swap hint.
         */
        function clearSelection() {
            if (selectedRow) {
                var card = selectedRow.closest('.player-team-card');
                selectedRow.classList.remove('roster-row--selected');
                selectedRow = null;
                disableSwapMode(card);
            }
        }

        /**
         * Removes all swap-mode visual cues (target highlights, dimmed rows, hint text).
         */
        function disableSwapMode(card) {
            if (!card) {
                return;
            }

            card.classList.remove('swap-mode');

            card.querySelectorAll('.roster-row.swap-target').forEach(function (row) {
                row.classList.remove('swap-target');
            });

            card.querySelectorAll('.roster-row.swap-dimmed').forEach(function (row) {
                row.classList.remove('swap-dimmed');
            });

            var hint = document.querySelector('.team-swap-hint-global');
            if (hint) {
                hint.textContent = 'Click a rider to swap. Then select another rider from the bench riders list.';
            }
        }

        /**
         * Keyboard support: pressing Enter or Space on a focusable table row triggers selectRider.
         */
        document.addEventListener('keydown', function (e) {
            if ((e.key === 'Enter' || e.key === ' ') && document.activeElement) {
                var row = document.activeElement.closest
                    ? document.activeElement.closest('tr[data-cyclist-id]')
                    : null;

                if (row) {
                    e.preventDefault();
                    selectRider(row);
                }
            }
        });
    })();
</script>
