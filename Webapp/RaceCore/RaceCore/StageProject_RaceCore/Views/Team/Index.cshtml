@model StageProject_RaceCore.Models.PlayerTeamsPageViewModel

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
}

@* Helper methods keep null rider slots readable in the roster table. *@
@functions {
    public string RiderName(StageProject_RaceCore.Models.PlayerTeamRiderViewModel? rider)
    {
        return rider == null ? "Vrije plaats" : rider.FullName;
    }

    public string RiderTeam(StageProject_RaceCore.Models.PlayerTeamRiderViewModel? rider)
    {
        return rider == null || string.IsNullOrWhiteSpace(rider.ProTeamName)
            ? "-"
            : rider.ProTeamName;
    }
}

@* Team-specific styles for this page. *@
<link rel="stylesheet" href="~/css/Team.css" asp-append-version="true" />

<div class="team-page dashboard-container" data-game-id="@Model.GameId">
    @* Hidden form token used by the swap request in the script below. *@
    <div class="team-antiforgery">
        @Html.AntiForgeryToken()
    </div>

    @* Header shows the current game context and dashboard navigation. *@
    <section class="player-teams-hero dashboard-hero">
        <div>
            <div class="small-title">RaceCore Game Hub</div>
            <h1>Teams</h1>
            <p>
                @if (Model.HasGame)
                {
                    <text>Race: <strong>@Model.RaceName</strong> | Status: <strong>@Model.GameStatus</strong></text>
                }
                else
                {
                    <text>Start eerst een game om de teams van de spelers te zien.</text>
                }
            </p>
        </div>

        <div class="team-hero-actions">
            <a asp-controller="Dashboard" asp-action="Index" class="team-dashboard-white-btn">
                Dashboard
            </a>
        </div>
    </section>

    @* Summary cards mirror the team counts and slot counts from the view model. *@
    <section class="stats-row team-stats-row" aria-label="Team overzicht">
        <div class="stat-box blue">
            <div class="stat-icon">👥</div>
            <div>
                <span>Spelers</span>
                <strong>@Model.PlayerCount</strong>
            </div>
        </div>

        <div class="stat-box orange">
            <div class="stat-icon">🚴</div>
            <div>
                <span>Actief</span>
                <strong>@Model.ActiveRiderSlots</strong>
            </div>
        </div>

        <div class="stat-box purple">
            <div class="stat-icon">🪑</div>
            <div>
                <span>Bank</span>
                <strong>@Model.BenchRiderSlots</strong>
            </div>
        </div>
    </section>

    @* Empty state shown until a game has teams or draft data. *@
    @if (!Model.PlayerTeams.Any())
    {
        <section class="card team-empty-state">
            <h2>Geen teams gevonden</h2>
            <p>Er is nog geen actieve game met spelers of draftbeurten.</p>
            <a asp-controller="Game" asp-action="New" class="team-btn team-btn-primary">Nieuwe game starten</a>
        </section>
    }
    else
    {
        @* Compact game summary shown above the player roster cards. *@
        <section class="card team-overview-card" aria-label="Game overzicht">
            <div class="info-grid">
                <div class="info-box">
                    <span>Game</span>
                    <strong>#@Model.GameId</strong>
                </div>

                <div class="info-box">
                    <span>Race</span>
                    <strong>@Model.RaceName</strong>
                </div>

                <div class="info-box">
                    <span>Gevuld</span>
                    <strong>@Model.FilledSlots / @Model.TotalSlots</strong>
                </div>

                <div class="info-box">
                    <span>Slots</span>
                    <strong>@Model.TotalSlots</strong>
                </div>
            </div>
        </section>

        @* Global swap instructions are updated while a rider is selected. *@
        <div class="team-swap-hint team-swap-hint-global" aria-live="polite">
            Klik op een renner om te wisselen. Daarna kies je een andere renner uit de bankrenners lijst.
        </div>

        @* Render one roster card per player, split into active and bench rider slots. *@
        <section class="player-team-grid" aria-label="Teams van spelers">
            @foreach (var playerTeam in Model.PlayerTeams)
            {
                // Tracks how full the active roster is for the progress bar.
                var activePercent = Model.ActiveRiderSlots == 0
                    ? 0
                    : Math.Min(100, playerTeam.ActiveRiders.Count * 100 / Model.ActiveRiderSlots);

                <article class="player-team-card"
                         data-player-id="@playerTeam.PlayerId"
                         style="--player-color:@playerTeam.Color; --player-color-soft:@playerTeam.ColorSoft; --player-color-dark:@playerTeam.ColorDark; --player-text-color:@playerTeam.TextColor;">
                    <header class="player-team-header">
                        <div class="player-team-identity">
                            <div class="player-team-avatar">@playerTeam.Initials</div>

                            <div>
                                <h2>@playerTeam.PlayerName</h2>
                                <p>@playerTeam.ActiveRiders.Count actieve renners, @playerTeam.BenchRiders.Count bankrenners</p>
                            </div>
                        </div>

                        <div class="team-completion">
                            <span>@playerTeam.ActiveRiders.Count / @Model.ActiveRiderSlots actief</span>
                            <div class="team-completion-bar" aria-hidden="true">
                                <div style="width:@activePercent%;"></div>
                            </div>
                        </div>
                    </header>

                    <div class="player-roster-table-wrap">
                        <table class="player-roster-table">
                            <thead>
                                <tr>
                                    <th>nr.</th>
                                    <th>Renner</th>
                                    <th>Ploeg</th>
                                    <th>Rol</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr class="roster-section-row active-section">
                                    <th colspan="4">Actieve renners</th>
                                </tr>

                                @* Active rows are fixed to the configured slot count so empty slots stay visible. *@
                                @for (var index = 0; index < Model.ActiveRiderSlots; index++)
                                {
                                    var rider = playerTeam.ActiveRiders.ElementAtOrDefault(index);

                                    <tr class="roster-row active-rider @(rider == null ? "empty-slot" : "") @(index == Model.ActiveRiderSlots - 1 ? "roster-before-bench" : "")"
                                        data-section="active"
                                        onclick="selectRider(this)" role="button" tabindex="0" title="Selecteer om te wisselen"
                                        @(rider != null ? $"data-cyclist-id=\"{rider.CyclistId}\"" : "")>
                                        <td class="slot-number">@(index + 1)</td>
                                        <td>
                                            <span class="rider-name">@RiderName(rider)</span>
                                        </td>
                                        <td>
                                            <span class="rider-team">@RiderTeam(rider)</span>
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <span class="status-pill active">Renner</span>
                                            }
                                        </td>
                                    </tr>
                                }

                                <tr class="roster-section-row bench-section">
                                    <th colspan="4">Bankrenners</th>
                                </tr>

                                @* Bench rows are fixed to the configured slot count so empty slots stay visible. *@
                                @for (var index = 0; index < Model.BenchRiderSlots; index++)
                                {
                                    var rider = playerTeam.BenchRiders.ElementAtOrDefault(index);

                                    <tr class="roster-row bench-rider @(rider == null ? "empty-slot" : "")"
                                        data-section="bench"
                                        onclick="selectRider(this)" role="button" tabindex="0" title="Selecteer om te wisselen"
                                        @(rider != null ? $"data-cyclist-id=\"{rider.CyclistId}\"" : "")>
                                        <td class="slot-number">@(Model.ActiveRiderSlots + index + 1)</td>
                                        <td>
                                            <span class="rider-name">@RiderName(rider)</span>
                                        </td>
                                        <td>
                                            <span class="rider-team">@RiderTeam(rider)</span>
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <span class="status-pill bench">Bank</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </article>
            }
        </section>
    }
</div>

<script>
    (function () {
        // Keeps selected row state local while exposing selectRider for row click handlers.
        var selectedRow = null;

        // First click selects a rider; second click in the opposite section performs the swap.
        window.selectRider = function (row) {
            var card = row.closest('.player-team-card');

            if (selectedRow === row) {
                clearSelection();
                return;
            }

            if (!selectedRow) {
                selectedRow = row;
                row.classList.add('roster-row--selected');
                enableSwapMode(card, row);
                return;
            }

            var firstCard = selectedRow.closest('.player-team-card');

            if (firstCard !== card) {
                clearSelection();
                selectedRow = row;
                row.classList.add('roster-row--selected');
                enableSwapMode(card, row);
                return;
            }

            var firstSection = selectedRow.dataset.section;
            var secondSection = row.dataset.section;

            if (firstSection === secondSection) {
                clearSelection();
                selectedRow = row;
                row.classList.add('roster-row--selected');
                enableSwapMode(card, row);
                return;
            }

            try {
                swapRows(selectedRow, row);
            } finally {
                clearSelection();
            }
        };

        // Enables visual feedback for valid swap targets in the selected player's card.
        function enableSwapMode(card, selected) {
            if (!card) {
                return;
            }

            card.classList.add('swap-mode');

            var selectedSection = selected.dataset.section;
            var targetSection = selectedSection === 'active' ? 'bench' : 'active';

            // Highlight valid targets in the opposite section
            card.querySelectorAll('.roster-row[data-section]').forEach(function (row) {
                row.classList.toggle('swap-target', row.dataset.section === targetSection);
                row.classList.toggle('swap-dimmed', row.dataset.section === selectedSection && row !== selected);
            });

            var hint = document.querySelector('.team-swap-hint-global');
            if (hint) {
                hint.textContent = targetSection === 'bench'
                    ? 'Geselecteerd. Klik nu een bankrenner (of vrije plaats) om te wisselen.'
                    : 'Geselecteerd. Klik nu een actieve renner (of vrije plaats) om te wisselen.';
            }
        }

        // Swaps the visible rider cells first so the page responds immediately.
        function swapRows(rowA, rowB) {
            var cellsA = rowA.querySelectorAll('td');
            var cellsB = rowB.querySelectorAll('td');

            var activeRow = rowA.classList.contains('active-rider') ? rowA : rowB;
            var benchRow = activeRow === rowA ? rowB : rowA;

            var tmpName = cellsA[1].innerHTML;
            cellsA[1].innerHTML = cellsB[1].innerHTML;
            cellsB[1].innerHTML = tmpName;

            var tmpTeam = cellsA[2].innerHTML;
            cellsA[2].innerHTML = cellsB[2].innerHTML;
            cellsB[2].innerHTML = tmpTeam;

            var tmpId = rowA.dataset.cyclistId;
            rowA.dataset.cyclistId = rowB.dataset.cyclistId;
            rowB.dataset.cyclistId = tmpId;

            updateRowState(rowA);
            updateRowState(rowB);

            persistSwap(activeRow, benchRow);
        }

        // Updates row styling and role labels after a rider has moved.
        function updateRowState(row) {
            if (!row) {
                return;
            }

            var id = row.dataset.cyclistId;
            var hasRider = id !== undefined && id !== '' && String(id) !== '0';

            row.classList.toggle('empty-slot', !hasRider);

            var cells = row.querySelectorAll('td');
            if (cells.length < 4) {
                return;
            }

            if (!hasRider) {
                cells[3].innerHTML = '';
            } else {
                var isActiveRow = row.classList.contains('active-rider');
                var pillClass = isActiveRow ? 'active' : 'bench';
                var pillLabel = isActiveRow ? 'Renner' : 'Bank';
                cells[3].innerHTML =
                    '<span class="status-pill ' + pillClass + '">' + pillLabel + '</span>';
            }
        }

        // Persists the active and bench rider ids after the visual swap succeeds.
        function persistSwap(activeRow, benchRow) {
            var card = activeRow.closest('.player-team-card');

            if (!card) {
                return;
            }

            var gameId = document.querySelector('.team-page')?.dataset?.gameId;
            var playerId = card.dataset.playerId;
            var activeCyclistId = activeRow.dataset.cyclistId || '0';
            var benchCyclistId = benchRow.dataset.cyclistId || '0';

            if (!gameId || !playerId) {
                return;
            }

            var token = document.querySelector('.team-antiforgery input[name="__RequestVerificationToken"]')?.value;

            if (!token) {
                return;
            }

            var body =
                '__RequestVerificationToken=' + encodeURIComponent(token) +
                '&gameId=' + encodeURIComponent(gameId) +
                '&playerId=' + encodeURIComponent(playerId) +
                '&activeCyclistId=' + encodeURIComponent(activeCyclistId) +
                '&benchCyclistId=' + encodeURIComponent(benchCyclistId);

            fetch('@Url.Action("SwapActiveBench", "Team")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: body
            }).catch(function () {
            });
        }

        // Keeps empty-slot attributes and labels in sync when moving riders between rows.
        function toggleEmptyState(targetRow, sourceRow) {
            // If the source had no cyclist id, the target is now an empty slot
            var isEmpty = !sourceRow.dataset.cyclistId || sourceRow.classList.contains('empty-slot');
            targetRow.classList.toggle('empty-slot', isEmpty);

            if (isEmpty) {
                delete targetRow.dataset.cyclistId;
                targetRow.removeAttribute('onclick');
                targetRow.removeAttribute('role');
                targetRow.removeAttribute('tabindex');
                targetRow.removeAttribute('title');
                // Clear the status pill cell
                targetRow.querySelectorAll('td')[3].innerHTML = '';
            } else {
                // Restore interactivity if it was previously empty
                targetRow.setAttribute('onclick', 'selectRider(this)');
                targetRow.setAttribute('role', 'button');
                targetRow.setAttribute('tabindex', '0');
                targetRow.setAttribute('title', 'Selecteer om te wisselen');
                // Restore correct pill
                var isActive = targetRow.classList.contains('active-rider');
                var pillClass = isActive ? 'active' : 'bench';
                var pillLabel = isActive ? 'Renner' : 'Bank';
                targetRow.querySelectorAll('td')[3].innerHTML =
                    '<span class="status-pill ' + pillClass + '">' + pillLabel + '</span>';
            }
        }

        // Clears selection classes and restores the neutral hint text.
        function clearSelection() {
            if (selectedRow) {
                var card = selectedRow.closest('.player-team-card');
                selectedRow.classList.remove('roster-row--selected');
                selectedRow = null;
                disableSwapMode(card);
            }
        }

        // Removes all visual swap hints from the current player card.
        function disableSwapMode(card) {
            if (!card) {
                return;
            }

            card.classList.remove('swap-mode');

            card.querySelectorAll('.roster-row.swap-target').forEach(function (row) {
                row.classList.remove('swap-target');
            });

            card.querySelectorAll('.roster-row.swap-dimmed').forEach(function (row) {
                row.classList.remove('swap-dimmed');
            });

            var hint = document.querySelector('.team-swap-hint-global');
            if (hint) {
                hint.textContent = 'Klik op een renner om te wisselen. Daarna kies je een andere renner uit de bankrenners lijst.';
            }
        }

        // Keyboard users can trigger a selected roster row with Enter or Space.
        document.addEventListener('keydown', function (e) {
            if ((e.key === 'Enter' || e.key === ' ') && document.activeElement) {
                var row = document.activeElement.closest
                    ? document.activeElement.closest('tr[data-cyclist-id]')
                    : null;

                if (row) {
                    e.preventDefault();
                    selectRider(row);
                }
            }
        });
    })();
</script>
