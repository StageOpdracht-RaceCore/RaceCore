@model StageProject_RaceCore.Models.TeamIndexViewModel
@using System.Linq
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var teams = (Model?.Teams ?? Enumerable.Empty<TeamViewModel>())
        .OrderByDescending(team => team.ActiveCyclistsCount + team.BenchCyclistsCount)
        .ToList();

    var availableCyclists = (Model?.AvailableCyclists ?? Enumerable.Empty<Cyclist>())
        .ToList();

    string GetTeamStyle(TeamViewModel team) =>
        $"--team-color: {team.Color}; " +
        $"--team-color-soft: {team.ColorSoft}; " +
        $"--team-color-soft-border: {team.ColorSoftBorder}; " +
        $"--team-color-contrast: {team.ColorContrast};";
}

<link rel="stylesheet" href="~/css/Team.css" />

<div class="page-card page-summary">
    <h2>Teams</h2>
    <p>Overview of all pro cycling teams, their rosters, and current points.</p>
</div>

@if (!teams.Any())
{
    <div class="page-card">
        <h3>No teams found</h3>
        <p>There are currently no teams in the system.</p>
    </div>
}
else
{
    <div class="global-search-bar">
        <input
            type="text"
            id="globalSearchInput"
            placeholder="Search by team or cyclist name&hellip;"
            aria-label="Search teams and cyclists" />
        <button
            type="button"
            id="globalSearchClear"
            title="Clear search"
            hidden>
            &#10005; Clear
        </button>
        <span id="globalSearchCount" aria-live="polite"></span>
    </div>

    <div class="teams-grid teams-grid-wide-gap" id="teamsGrid">
        @foreach (var team in teams)
        {
            var totalCyclists = team.ActiveCyclistsCount + team.BenchCyclistsCount;

            <div
                class="team-card collapsed"
                data-team-id="@team.Id"
                data-team-name="@team.Name.ToLower()"
                style="@GetTeamStyle(team)">
                <div class="team-header">
                    <div class="team-meta">
                        <span class="swatch"></span>

                        <div>
                            <div class="team-name">
                                @team.Name
                                <span class="tag">@team.Tag</span>
                            </div>

                            <div class="team-cyclist-count">
                                @totalCyclists cyclists
                            </div>
                        </div>
                    </div>

                    <div class="team-stats">
                        <div class="team-stats-top">
                            <div class="badge">@team.TeamPoints pts</div>
                            <button
                                type="button"
                                class="collapse-toggle"
                                aria-expanded="false"
                                title="Toggle team">
                                <span class="arrow">&#9662;</span>
                            </button>
                        </div>

                        <div class="team-counts">
                            Active: <strong>@team.ActiveCyclistsCount</strong>
                            &middot;
                            Bench: <strong>@team.BenchCyclistsCount</strong>
                        </div>
                    </div>
                </div>

                <div class="team-body">
                    <div class="team-management">
                        <div class="team-management-title">Add cyclist to team</div>

                        @if (availableCyclists.Any())
                        {
                            <form
                                asp-controller="Team"
                                asp-action="AddCyclistToTeam"
                                method="post"
                                class="add-cyclist-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="teamId" value="@team.Id" />

                                <select
                                    name="cyclistId"
                                    class="add-cyclist-select"
                                    aria-label="Select cyclist to add"
                                    required>
                                    <option value="">Select cyclist</option>
                                    @foreach (var cyclist in availableCyclists)
                                    {
                                        <option value="@cyclist.Id">
                                            @cyclist.FirstName @cyclist.LastName
                                        </option>
                                    }
                                </select>

                                <select
                                    name="isActive"
                                    class="add-cyclist-status"
                                    aria-label="Choose cyclist status">
                                    <option value="true">Active</option>
                                    <option value="false">Bench</option>
                                </select>

                                <button type="submit" class="add-cyclist-btn">Add to team</button>
                            </form>
                        }
                        else
                        {
                            <div class="empty team-management-empty">
                                No unassigned cyclists available
                            </div>
                        }
                    </div>

                    <div class="composition">
                        <div class="column">
                            <h4>Active</h4>

                            @if (team.ActiveCyclists?.Any() ?? false)
                            {
                                <ul class="cyclist-list">
                                    @foreach (var cyclist in team.ActiveCyclists)
                                    {
                                        var cyclistFullName = $"{cyclist.FirstName} {cyclist.LastName}";

                                        <li data-cyclist-name="@cyclistFullName.ToLower()">
                                            <span class="cyclist-name-text">@cyclistFullName</span>

                                            <div class="cyclist-actions">
                                                <form
                                                    asp-controller="Team"
                                                    asp-action="ToggleCyclistStatus"
                                                    method="post"
                                                    class="cyclist-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="cyclistId" value="@cyclist.Id" />
                                                    <input type="hidden" name="isActive" value="false" />
                                                    <button type="submit" class="bench-btn">Bench</button>
                                                </form>

                                                <form
                                                    asp-controller="Team"
                                                    asp-action="RemoveCyclistFromTeam"
                                                    method="post"
                                                    class="cyclist-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="cyclistId" value="@cyclist.Id" />
                                                    <button type="submit" class="remove-btn">Remove</button>
                                                </form>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No active cyclists</div>
                            }
                        </div>

                        <div class="column">
                            <h4>Bench</h4>

                            @if (team.BenchCyclists?.Any() ?? false)
                            {
                                <ul class="cyclist-list">
                                    @foreach (var cyclist in team.BenchCyclists)
                                    {
                                        var cyclistFullName = $"{cyclist.FirstName} {cyclist.LastName}";

                                        <li data-cyclist-name="@cyclistFullName.ToLower()">
                                            <span class="cyclist-name-text">@cyclistFullName</span>

                                            <div class="cyclist-actions">
                                                <form
                                                    asp-controller="Team"
                                                    asp-action="ToggleCyclistStatus"
                                                    method="post"
                                                    class="cyclist-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="cyclistId" value="@cyclist.Id" />
                                                    <input type="hidden" name="isActive" value="true" />
                                                    <button type="submit" class="activate-btn">Activate</button>
                                                </form>

                                                <form
                                                    asp-controller="Team"
                                                    asp-action="RemoveCyclistFromTeam"
                                                    method="post"
                                                    class="cyclist-form">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="cyclistId" value="@cyclist.Id" />
                                                    <button type="submit" class="remove-btn">Remove</button>
                                                </form>
                                            </div>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No cyclists on the bench</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script>
        (function () {
            var STORAGE_KEY = "teamsCollapseState";
            var TEAM_CARD_SELECTOR = ".team-card[data-team-id]";
            var SEARCH_HIDDEN_CLASS = "team-card-search-hidden";

            function getTeamCards() {
                return document.querySelectorAll(TEAM_CARD_SELECTOR);
            }

            function readState() {
                try {
                    return JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
                } catch (e) {
                    return {};
                }
            }

            function writeState(state) {
                try {
                    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
                } catch (e) {
                }
            }

            function saveCardState(card) {
                var id = card.dataset.teamId;
                if (!id) {
                    return;
                }

                var state = readState();
                state[id] = card.classList.contains("collapsed");
                writeState(state);
            }

            function persistAllCardStates() {
                var state = {};

                getTeamCards().forEach(function (card) {
                    var id = card.dataset.teamId;
                    if (id) {
                        state[id] = card.classList.contains("collapsed");
                    }
                });

                writeState(state);
            }

            function setCardExpanded(card, isExpanded) {
                card.classList.toggle("collapsed", !isExpanded);

                var button = card.querySelector(".collapse-toggle");
                if (button) {
                    button.setAttribute("aria-expanded", String(isExpanded));
                }
            }

            function toggleCardExpanded(card) {
                setCardExpanded(card, card.classList.contains("collapsed"));
                saveCardState(card);
            }

            function restoreAll() {
                var state = readState();

                getTeamCards().forEach(function (card) {
                    var id = card.dataset.teamId;
                    if (!id) {
                        return;
                    }

                    var isCollapsed = Object.prototype.hasOwnProperty.call(state, id)
                        ? state[id]
                        : true;

                    setCardExpanded(card, !isCollapsed);
                });
            }

            function removeDynamicEmpties() {
                document.querySelectorAll(".search-empty").forEach(function (element) {
                    element.remove();
                });
            }

            function setCardVisibility(card, isVisible) {
                card.classList.toggle(SEARCH_HIDDEN_CLASS, !isVisible);
                card.hidden = !isVisible;
                card.setAttribute("aria-hidden", String(!isVisible));
            }

            function expandCard(card) {
                if (!card.classList.contains("collapsed")) {
                    return;
                }

                setCardExpanded(card, true);
                saveCardState(card);
            }

            function applyFilter(query) {
                query = query.trim().toLowerCase();
                removeDynamicEmpties();

                var totalVisible = 0;

                getTeamCards().forEach(function (card) {
                    var teamName = card.dataset.teamName || "";
                    var items = Array.from(
                        card.querySelectorAll(".cyclist-list li[data-cyclist-name]")
                    );

                    if (query === "") {
                        items.forEach(function (item) {
                            item.hidden = false;
                        });

                        setCardVisibility(card, true);
                        totalVisible += items.length;
                        return;
                    }

                    var teamMatches = teamName.includes(query);
                    var cyclistMatches = 0;

                    items.forEach(function (item) {
                        var isMatch = (item.dataset.cyclistName || "").includes(query);
                        item.hidden = !isMatch;

                        if (isMatch) {
                            cyclistMatches++;
                        }
                    });

                    if (teamMatches) {
                        setCardVisibility(card, true);

                        items.forEach(function (item) {
                            item.hidden = false;
                        });

                        totalVisible += items.length;
                        expandCard(card);
                        return;
                    }

                    if (cyclistMatches > 0) {
                        setCardVisibility(card, true);
                        totalVisible += cyclistMatches;
                        expandCard(card);

                        card.querySelectorAll(".column").forEach(function (column) {
                            var list = column.querySelector(".cyclist-list");
                            if (!list) {
                                return;
                            }

                            var allHidden = Array.from(list.querySelectorAll("li")).every(
                                function (item) {
                                    return item.hidden;
                                }
                            );

                            if (!allHidden) {
                                return;
                            }

                            var message = document.createElement("div");
                            message.className = "empty search-empty";
                            message.textContent = "No matches";
                            column.appendChild(message);
                        });

                        return;
                    }

                    setCardVisibility(card, false);
                });

                if (query === "") {
                    clearBtn.hidden = true;
                    countEl.textContent = "";
                    return;
                }

                clearBtn.hidden = false;
                countEl.textContent =
                    totalVisible > 0
                        ? totalVisible + " cyclist" + (totalVisible !== 1 ? "s" : "") + " found"
                        : "No results";
            }

            restoreAll();

            document.addEventListener("click", function (event) {
                var toggleButton = event.target.closest(".collapse-toggle");
                if (toggleButton) {
                    var toggleCard = toggleButton.closest(".team-card");
                    if (toggleCard) {
                        toggleCardExpanded(toggleCard);
                    }

                    return;
                }

                var header = event.target.closest(".team-header");
                if (header && !event.target.closest("button, a, form")) {
                    var headerCard = header.closest(".team-card");
                    if (headerCard) {
                        toggleCardExpanded(headerCard);
                    }
                }
            });

            document.addEventListener(
                "click",
                function (event) {
                    if (!event.target.closest(".bench-btn, .activate-btn, .remove-btn, .add-cyclist-btn")) {
                        return;
                    }

                    persistAllCardStates();
                },
                true
            );

            var searchInput = document.getElementById("globalSearchInput");
            var clearBtn = document.getElementById("globalSearchClear");
            var countEl = document.getElementById("globalSearchCount");

            if (!searchInput) {
                return;
            }

            searchInput.addEventListener("input", function () {
                applyFilter(searchInput.value);
            });

            clearBtn.addEventListener("click", function () {
                searchInput.value = "";
                applyFilter("");
                searchInput.focus();
            });
        })();
    </script>
}
