@model StageProject_RaceCore.Models.PlayerTeamsPageViewModel

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@functions {
    public string RiderName(StageProject_RaceCore.Models.PlayerTeamRiderViewModel? rider)
    {
        return rider == null ? "Vrije plaats" : rider.FullName;
    }

    public string RiderTeam(StageProject_RaceCore.Models.PlayerTeamRiderViewModel? rider)
    {
        return rider == null || string.IsNullOrWhiteSpace(rider.ProTeamName)
            ? "-"
            : rider.ProTeamName;
    }
}

<link rel="stylesheet" href="~/css/team.css" asp-append-version="true" />

<div class="team-page" data-game-id="@Model.GameId">
    <div class="team-antiforgery">
        @Html.AntiForgeryToken()
    </div>
    <section class="team-header-card player-teams-hero">
        <div class="team-hero-copy">
            <p class="team-page-kicker">RaceCore Game</p>
            <div class="team-hero-title-row">
                <h1 class="team-page-title">Teams</h1>
                <a asp-controller="Dashboard" asp-action="Index" class="team-btn team-btn-secondary team-dashboard-btn">← Dashboard</a>
            </div>
            <p class="team-page-subtitle">
                @if (Model.HasGame)
                {
                    <text>@Model.RaceName - @Model.GameStatus</text>
                }
                else
                {
                    <text>Start eerst een game om de teams van de spelers te zien.</text>
                }
            </p>
        </div>

        <div class="team-hero-stats" aria-label="Team overzicht">
            <div>
                <span>Spelers</span>
                <strong>@Model.PlayerCount</strong>
            </div>

            <div>
                <span>Renners</span>
                <strong>@Model.ActiveRiderSlots</strong>
            </div>

            <div>
                <span>Bank</span>
                <strong>@Model.BenchRiderSlots</strong>
            </div>
        </div>
    </section>

    @if (!Model.PlayerTeams.Any())
    {
        <section class="team-table-card team-empty-state">
            <h2>Geen teams gevonden</h2>
            <p>Er is nog geen actieve game met spelers of draftbeurten.</p>
            <a asp-controller="Game" asp-action="New" class="team-btn team-btn-primary">Nieuwe game starten</a>
        </section>
    }
    else
    {
        <section class="team-overview-strip">
            <div>
                <span>Game</span>
                <strong>#@Model.GameId</strong>
            </div>

            <div>
                <span>Race</span>
                <strong>@Model.RaceName</strong>
            </div>

            <div>
                <span>Gevuld</span>
                <strong>@Model.FilledSlots / @Model.TotalSlots</strong>
            </div>
        </section>

        <section class="player-team-grid" aria-label="Teams van spelers">
            @foreach (var playerTeam in Model.PlayerTeams)
            {
                var activePercent = Model.ActiveRiderSlots == 0
                    ? 0
                    : Math.Min(100, playerTeam.ActiveRiders.Count * 100 / Model.ActiveRiderSlots);

                <article class="player-team-card"
                         data-player-id="@playerTeam.PlayerId"
                         style="--player-color:@playerTeam.Color; --player-color-soft:@playerTeam.ColorSoft; --player-color-dark:@playerTeam.ColorDark; --player-text-color:@playerTeam.TextColor;">
                    <header class="player-team-header">
                        <div class="player-team-identity">
                            <div class="player-team-avatar">@playerTeam.Initials</div>

                            <div>
                                <h2>@playerTeam.PlayerName</h2>
                                <p>@playerTeam.ActiveRiders.Count actieve renners, @playerTeam.BenchRiders.Count bankrenners</p>
                            </div>
                        </div>

                        <div class="team-completion">
                            <span>@playerTeam.ActiveRiders.Count / @Model.ActiveRiderSlots actief</span>
                            <div class="team-completion-bar" aria-hidden="true">
                                <div style="width:@activePercent%;"></div>
                            </div>
                        </div>
                    </header>

                    <div class="player-roster-table-wrap">
                        <table class="player-roster-table">
                            <thead>
                                <tr>
                                    <th>nr.</th>
                                    <th>Renner</th>
                                    <th>Ploeg</th>
                                    <th>Rol</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr class="roster-section-row active-section">
                                    <th colspan="4">Actieve renners</th>
                                </tr>

                                @for (var index = 0; index < Model.ActiveRiderSlots; index++)
                                {
                                    var rider = playerTeam.ActiveRiders.ElementAtOrDefault(index);

                                    <tr class="roster-row active-rider @(rider == null ? "empty-slot" : "") @(index == Model.ActiveRiderSlots - 1 ? "roster-before-bench" : "")"
                                        @(rider != null ? $"data-cyclist-id=\"{rider.CyclistId}\" data-section=\"active\" onclick=\"selectRider(this)\" role=\"button\" tabindex=\"0\" title=\"Selecteer om te wisselen\"" : "")>
                                        <td class="slot-number">@(index + 1)</td>
                                        <td>
                                            <span class="rider-name">@RiderName(rider)</span>
                                        </td>
                                        <td>
                                            <span class="rider-team">@RiderTeam(rider)</span>
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <span class="status-pill active">Renner</span>
                                            }
                                        </td>
                                    </tr>
                                }

                                <tr class="roster-section-row bench-section">
                                    <th colspan="4">Bankrenners</th>
                                </tr>

                                @for (var index = 0; index < Model.BenchRiderSlots; index++)
                                {
                                    var rider = playerTeam.BenchRiders.ElementAtOrDefault(index);

                                    <tr class="roster-row bench-rider @(rider == null ? "empty-slot" : "")"
                                        @(rider != null ? $"data-cyclist-id=\"{rider.CyclistId}\" data-section=\"bench\" onclick=\"selectRider(this)\" role=\"button\" tabindex=\"0\" title=\"Selecteer om te wisselen\"" : "")>
                                        <td class="slot-number">@(Model.ActiveRiderSlots + index + 1)</td>
                                        <td>
                                            <span class="rider-name">@RiderName(rider)</span>
                                        </td>
                                        <td>
                                            <span class="rider-team">@RiderTeam(rider)</span>
                                        </td>
                                        <td>
                                            @if (rider != null)
                                            {
                                                <span class="status-pill bench">Bank</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </article>
            }
        </section>
    }
</div>

<script>
    (function () {
        // selectedRow: the currently highlighted row waiting for a swap partner
        var selectedRow = null;

        window.selectRider = function (row) {
            var card = row.closest('.player-team-card');

            // Clicking the already-selected row deselects it
            if (selectedRow === row) {
                clearSelection();
                return;
            }

            // First pick � just highlight it
            if (!selectedRow) {
                selectedRow = row;
                row.classList.add('roster-row--selected');
                return;
            }

            // Second pick � must be in the SAME card but OPPOSITE section
            var firstCard = selectedRow.closest('.player-team-card');
            if (firstCard !== card) {
                // Different card: restart selection in new card
                clearSelection();
                selectedRow = row;
                row.classList.add('roster-row--selected');
                return;
            }

            var firstSection = selectedRow.dataset.section;   // 'active' or 'bench'
            var secondSection = row.dataset.section;

            if (firstSection === secondSection) {
                // Same section: move selection to the new row
                clearSelection();
                selectedRow = row;
                row.classList.add('roster-row--selected');
                return;
            }

            // Different sections within the same card � perform the swap
            swapRows(selectedRow, row);
            clearSelection();
        };

        function swapRows(rowA, rowB) {
            // Swap the rider content cells (cols 1, 2, 3) and the data-section attribute.
            // Col 0 (slot number) and the pill styling stay tied to the row's section.
            var cellsA = rowA.querySelectorAll('td');
            var cellsB = rowB.querySelectorAll('td');

            var activeRow = rowA.classList.contains('active-rider') ? rowA : rowB;
            var benchRow = activeRow === rowA ? rowB : rowA;

            // Swap rider name
            var tmpName = cellsA[1].innerHTML;
            cellsA[1].innerHTML = cellsB[1].innerHTML;
            cellsB[1].innerHTML = tmpName;

            // Swap pro team
            var tmpTeam = cellsA[2].innerHTML;
            cellsA[2].innerHTML = cellsB[2].innerHTML;
            cellsB[2].innerHTML = tmpTeam;

            // Swap cyclist id (so a third swap would still work correctly)
            var tmpId = rowA.dataset.cyclistId;
            rowA.dataset.cyclistId = rowB.dataset.cyclistId;
            rowB.dataset.cyclistId = tmpId;

            // Handle empty-slot state: a row becomes empty if the partner had no cyclist id
            toggleEmptyState(rowA, rowB);
            toggleEmptyState(rowB, rowA);

            persistSwap(activeRow, benchRow);
        }

        function persistSwap(activeRow, benchRow) {
            var card = activeRow.closest('.player-team-card');
            if (!card) {
                return;
            }

            var gameId = document.querySelector('.team-page')?.dataset?.gameId;
            var playerId = card.dataset.playerId;
            var activeCyclistId = activeRow.dataset.cyclistId;
            var benchCyclistId = benchRow.dataset.cyclistId;

            if (!gameId || !playerId || !activeCyclistId || !benchCyclistId) {
                return;
            }

            var token = document.querySelector('.team-antiforgery input[name="__RequestVerificationToken"]')?.value;
            if (!token) {
                return;
            }

            var body =
                '__RequestVerificationToken=' + encodeURIComponent(token) +
                '&gameId=' + encodeURIComponent(gameId) +
                '&playerId=' + encodeURIComponent(playerId) +
                '&activeCyclistId=' + encodeURIComponent(activeCyclistId) +
                '&benchCyclistId=' + encodeURIComponent(benchCyclistId);

            fetch('@Url.Action("SwapActiveBench", "Team")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                body: body
            }).catch(function () {
                // UI swap already happened; if persistence fails, a refresh will restore server state.
            });
        }

        function toggleEmptyState(targetRow, sourceRow) {
            // If the source had no cyclist id, the target is now an empty slot
            var isEmpty = !sourceRow.dataset.cyclistId || sourceRow.classList.contains('empty-slot');
            targetRow.classList.toggle('empty-slot', isEmpty);

            if (isEmpty) {
                delete targetRow.dataset.cyclistId;
                targetRow.removeAttribute('onclick');
                targetRow.removeAttribute('role');
                targetRow.removeAttribute('tabindex');
                targetRow.removeAttribute('title');
                // Clear the status pill cell
                targetRow.querySelectorAll('td')[3].innerHTML = '';
            } else {
                // Restore interactivity if it was previously empty
                targetRow.setAttribute('onclick', 'selectRider(this)');
                targetRow.setAttribute('role', 'button');
                targetRow.setAttribute('tabindex', '0');
                targetRow.setAttribute('title', 'Selecteer om te wisselen');
                // Restore correct pill
                var isActive = targetRow.classList.contains('active-rider');
                var pillClass = isActive ? 'active' : 'bench';
                var pillLabel = isActive ? 'Renner' : 'Bank';
                targetRow.querySelectorAll('td')[3].innerHTML =
                    '<span class="status-pill ' + pillClass + '">' + pillLabel + '</span>';
            }
        }

        function clearSelection() {
            if (selectedRow) {
                selectedRow.classList.remove('roster-row--selected');
                selectedRow = null;
            }
        }

        // Keyboard support: Enter/Space triggers click on focused rows
        document.addEventListener('keydown', function (e) {
            if ((e.key === 'Enter' || e.key === ' ') && document.activeElement) {
                var row = document.activeElement.closest
                    ? document.activeElement.closest('tr[data-cyclist-id]')
                    : null;
                if (row) {
                    e.preventDefault();
                    selectRider(row);
                }
            }
        });
    })();
</script>
    