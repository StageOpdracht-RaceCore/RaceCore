@model StageProject_RaceCore.ViewModels.ScoringViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using StageProject_RaceCore.Models
@using System.Text.Json

@{
    ViewData["Title"] = "Etappe Resultaten";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";

    var races = ViewBag.Races as List<Race> ?? new List<Race>();
    var selectedRaceId = ViewBag.SelectedRaceId ?? 0;
    var selectedGameId = ViewBag.SelectedGameId ?? Model.GameSessionId;
    var stages = ViewBag.AvailableStages as List<SelectListItem> ?? new List<SelectListItem>();

    string redOutsideName = ViewData["RedOutsideTop25CyclistName"]?.ToString() ?? "";
    string greenOutsideName = ViewData["GreenOutsideTop25CyclistName"]?.ToString() ?? "";
    string blueOutsideName = ViewData["BlueOutsideTop25CyclistName"]?.ToString() ?? "";
    string whiteOutsideName = ViewData["WhiteOutsideTop25CyclistName"]?.ToString() ?? "";
}

<link rel="stylesheet" href="~/css/Scoring.css" asp-append-version="true" />

<div class="scoring-page">

    @if (TempData["Error"] != null)
    {
        <div class="scoring-alert scoring-alert-error">
            <strong>FOUT:</strong>
            <span>@TempData["Error"]</span>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="scoring-alert scoring-alert-success">
            <strong>OK:</strong>
            <span>@TempData["Success"]</span>
        </div>
    }

    <section class="scoring-hero">
        <div>
            <h1>Scoring Beheer</h1>
            <p>Selecteer de gewenste wedstrijd en etappe.</p>
        </div>

        <a asp-controller="Dashboard"
               asp-action="Index"
               class="scoring-dashboard-btn">
            Dashboard
        </a>
    </section>

    <section class="scoring-card">
        <form asp-controller="Scoring"
              asp-action="Index"
              method="get"
              class="scoring-filter-form">

            <div class="scoring-field">
                <label>Wedstrijd kiezen</label>
                <select name="raceId">
                    @foreach (var race in races)
                    {
                        if (race.Id == selectedRaceId)
                        {
                            <option value="@race.Id" selected>
                                @race.Name
                            </option>
                        }
                        else
                        {
                            <option value="@race.Id">
                                @race.Name
                            </option>
                        }
                    }
                </select>
            </div>

            <div class="scoring-field">
                <label>Rit kiezen</label>
                <select name="stageId">
                    @foreach (var stage in stages)
                    {
                        if (stage.Selected)
                        {
                            <option value="@stage.Value" selected>
                                @stage.Text
                            </option>
                        }
                        else
                        {
                            <option value="@stage.Value">
                                @stage.Text
                            </option>
                        }
                    }
                </select>
            </div>

            <input type="hidden" name="gameId" value="@selectedGameId" />

            <button type="submit" class="scoring-load-btn">
                Rit laden
            </button>
        </form>
    </section>

    <form asp-controller="Scoring"
          asp-action="SaveScores"
          method="post"
          id="scoringForm">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="GameSessionId" />
        <input type="hidden" asp-for="StageId" />
        <input type="hidden" name="raceId" value="@selectedRaceId" />

        <section class="scoring-section-header">
            <h2>Rit @Model.StageId Resultaten</h2>

            <button type="submit" class="scoring-publish-btn">
                Scores Publiceren
            </button>
        </section>

        <datalist id="cyclistList"></datalist>

        <section class="scoring-results-list">

            @for (int i = 0; i < Model.Results.Count; i++)
            {
                <div class="scoring-result-row">

                    <div class="scoring-position">
                        @Model.Results[i].Position
                    </div>

                    <input type="hidden"
                           asp-for="Results[i].Position" />

                    <input type="hidden"
                           asp-for="Results[i].CyclistId"
                           class="js-cyclist-id" />

                    <input type="text"
                           class="scoring-rider-input js-cyclist-name"
                           list="cyclistList"
                           value="@Model.Results[i].CyclistName"
                           placeholder="Zoek renner..."
                           autocomplete="off"
                           onfocus="updateCyclistList(this)"
                           oninput="syncCyclistId(this); updateCyclistList(this)" />

                    <div class="scoring-jersey-options">

                        <label class="jersey-dot jersey-red" title="Rode trui">
                            <input asp-for="Results[i].HasYellowJersey"
                                   type="checkbox"
                                   onchange="clearOutsideJersey('Red')" />
                            <span></span>
                        </label>

                        <label class="jersey-dot jersey-green" title="Groene trui">
                            <input asp-for="Results[i].HasGreenJersey"
                                   type="checkbox"
                                   onchange="clearOutsideJersey('Green')" />
                            <span></span>
                        </label>

                        <label class="jersey-dot jersey-blue" title="Blauwe trui">
                            <input asp-for="Results[i].HasPolkaJersey"
                                   type="checkbox"
                                   onchange="clearOutsideJersey('Blue')" />
                            <span></span>
                        </label>

                        <label class="jersey-dot jersey-white" title="Witte trui">
                            <input asp-for="Results[i].HasWhiteJersey"
                                   type="checkbox"
                                   onchange="clearOutsideJersey('White')" />
                            <span></span>
                        </label>

                    </div>
                </div>
            }

        </section>

        <section class="scoring-section-header scoring-jersey-header">
            <h2>Truien buiten Top 25</h2>
        </section>

        <section class="scoring-card scoring-outside-jerseys">

            <div class="outside-jersey-row">
                <label>Rode trui buiten Top 25</label>

                <input type="hidden"
                       asp-for="YellowOutsideTop25CyclistId"
                       class="js-outside-jersey-id"
                       data-jersey="Red" />

                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@redOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="Red"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('Red')" />
            </div>

            <div class="outside-jersey-row">
                <label>Groene trui buiten Top 25</label>

                <input type="hidden"
                       asp-for="GreenOutsideTop25CyclistId"
                       class="js-outside-jersey-id"
                       data-jersey="Green" />

                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@greenOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="Green"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('Green')" />
            </div>

            <div class="outside-jersey-row">
                <label>Blauwe trui buiten Top 25</label>

                <input type="hidden"
                       asp-for="PolkaOutsideTop25CyclistId"
                       class="js-outside-jersey-id"
                       data-jersey="Blue" />

                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@blueOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="Blue"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('Blue')" />
            </div>

            <div class="outside-jersey-row">
                <label>Witte trui buiten Top 25</label>

                <input type="hidden"
                       asp-for="WhiteOutsideTop25CyclistId"
                       class="js-outside-jersey-id"
                       data-jersey="White" />

                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@whiteOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="White"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('White')" />
            </div>

        </section>
    </form>
</div>

<script>
    const allCyclists = [
        @foreach (var rider in Model.AvailableCyclists)
        {
                <text>{ id: "@rider.Value", name: @Html.Raw(JsonSerializer.Serialize(rider.Text)) },</text>
        }
    ];

    function getHiddenInput(textInput) {
        const row = textInput.closest(".scoring-result-row, .outside-jersey-row");

        if (!row) {
            return null;
        }

        return row.querySelector("input[type='hidden']");
    }

    function getSelectedCyclistIds(exceptInput) {
        const selectedIds = new Set();

        document.querySelectorAll(".js-cyclist-name, .js-outside-jersey-name").forEach(input => {
            if (input === exceptInput) {
                return;
            }

            const hidden = getHiddenInput(input);

            if (hidden && hidden.value) {
                selectedIds.add(hidden.value);
            }
        });

        return selectedIds;
    }

    function updateCyclistList(activeInput) {
        const datalist = document.getElementById("cyclistList");
        const selectedIds = getSelectedCyclistIds(activeInput);
        const activeHidden = getHiddenInput(activeInput);
        const activeId = activeHidden ? activeHidden.value : "";

        datalist.innerHTML = "";

        allCyclists.forEach(cyclist => {
            if (!selectedIds.has(cyclist.id) || cyclist.id === activeId) {
                const option = document.createElement("option");
                option.value = cyclist.name;
                option.dataset.id = cyclist.id;
                datalist.appendChild(option);
            }
        });
    }

    function syncCyclistId(input) {
        const hidden = getHiddenInput(input);

        if (!hidden) {
            return;
        }

        const typedName = input.value.trim().toLowerCase();

        if (typedName === "") {
            hidden.value = "";
            input.classList.remove("is-invalid");
            return;
        }

        const cyclist = allCyclists.find(c =>
            c.name.trim().toLowerCase() === typedName
        );

        if (!cyclist) {
            hidden.value = "";
            input.classList.remove("is-invalid");
            return;
        }

        const selectedIds = getSelectedCyclistIds(input);

        if (selectedIds.has(cyclist.id)) {
            hidden.value = "";
            input.value = "";
            input.classList.add("is-invalid");

            alert("Deze renner is al gekozen. Kies een andere renner.");

            updateCyclistList(input);
            return;
        }

        hidden.value = cyclist.id;
        input.classList.remove("is-invalid");
    }

    function clearOutsideJersey(type) {
        const checkboxMap = {
            Red: "HasYellowJersey",
            Green: "HasGreenJersey",
            Blue: "HasPolkaJersey",
            White: "HasWhiteJersey"
        };

        const checkedCheckbox = Array.from(document.querySelectorAll("input[type='checkbox']"))
            .find(cb => cb.name.includes(checkboxMap[type]) && cb.checked);

        if (!checkedCheckbox) {
            return;
        }

        const outsideInput = document.querySelector(`.js-outside-jersey-name[data-jersey='${type}']`);
        const outsideHidden = document.querySelector(`.js-outside-jersey-id[data-jersey='${type}']`);

        if (outsideInput) {
            outsideInput.value = "";
        }

        if (outsideHidden) {
            outsideHidden.value = "";
        }
    }

    function clearTop25Jersey(type) {
        const outsideHidden = document.querySelector(`.js-outside-jersey-id[data-jersey='${type}']`);

        if (!outsideHidden || !outsideHidden.value) {
            return;
        }

        const checkboxMap = {
            Red: "HasYellowJersey",
            Green: "HasGreenJersey",
            Blue: "HasPolkaJersey",
            White: "HasWhiteJersey"
        };

        document.querySelectorAll("input[type='checkbox']").forEach(cb => {
            if (cb.name.includes(checkboxMap[type])) {
                cb.checked = false;
            }
        });
    }

    document.getElementById("scoringForm")?.addEventListener("submit", function (e) {
        let duplicateFound = false;
        const usedIds = new Map();

        document.querySelectorAll(".js-cyclist-name, .js-outside-jersey-name").forEach(input => {
            syncCyclistId(input);

            const hidden = getHiddenInput(input);

            if (!hidden || !hidden.value) {
                input.classList.remove("is-invalid");
                return;
            }

            if (usedIds.has(hidden.value)) {
                duplicateFound = true;
                input.classList.add("is-invalid");
            } else {
                usedIds.set(hidden.value, true);
                input.classList.remove("is-invalid");
            }
        });

        if (duplicateFound) {
            e.preventDefault();
            alert("Er staat een renner dubbel. Corrigeer dit eerst voordat je de scores publiceert.");
        }
    });

    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".js-cyclist-name, .js-outside-jersey-name").forEach(input => {
            syncCyclistId(input);
        });
    });
</script>