@model StageProject_RaceCore.ViewModels.ScoringViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Etappe Resultaten";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";

    var races = ViewBag.Races as List<Race> ?? new List<Race>();
    var selectedRaceId = ViewBag.SelectedRaceId as int? ?? 0;
    var stages = ViewBag.AvailableStages as List<SelectListItem> ?? new List<SelectListItem>();
    int gameId = ViewBag.GameId ?? 0;

    string redName = ViewData["RedOutsideTop25CyclistName"]?.ToString() ?? "";
    string greenName = ViewData["GreenOutsideTop25CyclistName"]?.ToString() ?? "";
    string blueName = ViewData["BlueOutsideTop25CyclistName"]?.ToString() ?? "";
    string whiteName = ViewData["WhiteOutsideTop25CyclistName"]?.ToString() ?? "";
}

<link rel="stylesheet" href="~/css/Scoring.css" asp-append-version="true" />

<div class="scoring-page">

    @if (TempData["Error"] != null || TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">
            <strong>Fout:</strong> @(TempData["Error"] ?? TempData["ErrorMessage"])
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">
            <strong>Succes:</strong> @TempData["Success"]
        </div>
    }

    <div class="player-header-card">
        <div style="flex-grow: 1;">
            <h1 class="player-page-title">Scoring Beheer</h1>
            <p class="player-page-subtitle">Selecteer de gewenste wedstrijd en etappe.</p>
        </div>

        <a asp-controller="Dashboard"
               asp-action="Index"
               asp-route-gameId="@gameId"
               class="player-btn-white"
               style="text-decoration: none; display: flex; align-items: center; gap: 8px;">
            <i class="fas fa-arrow-left"></i> Dashboard
        </a>
    </div>

    <div class="player-table-card" style="padding:24px; margin-bottom:24px;">
        <form asp-controller="Scoring" asp-action="Index" method="get">
            <input type="hidden" name="gameId" value="@gameId" />

            <div style="display: flex; gap: 20px; align-items: flex-end; width: 100%;">

                <div style="flex: 0 0 40%;">
                    <label style="font-weight:700; margin-bottom:8px; display:block;">Wedstrijd kiezen</label>

                    <select name="raceId" class="player-search-input" onchange="this.form.submit()">
                        <option value="">-- Selecteer Wedstrijd --</option>

                        @foreach (var race in races)
                        {
                            <option value="@race.Id" selected="@(race.Id == selectedRaceId)">
                                @race.Name
                            </option>
                        }
                    </select>
                </div>

                <div style="flex: 0 0 40%;">
                    <label style="font-weight:700; margin-bottom:8px; display:block;">Rit kiezen</label>
                    <select asp-for="StageId" asp-items="stages" class="player-search-input"></select>
                </div>

                <div style="flex: 1;">
                    <button type="submit" class="player-btn-white" style="height:48px; width:100%;">
                        Rit laden
                    </button>
                </div>

            </div>
        </form>
    </div>

    @if (Model.StageId > 0)
    {
        <form asp-controller="Scoring" asp-action="SaveScores" method="post">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="StageId" />
            <input type="hidden" name="raceId" value="@selectedRaceId" />
            <input type="hidden" name="gameId" value="@gameId" />

            <div class="player-header-card">
                <h1 class="player-page-title">Rit @Model.StageId Resultaten</h1>
                <button type="submit" class="player-btn-white">Scores Publiceren</button>
            </div>

            <datalist id="cyclistList">
                @foreach (var item in Model.AvailableCyclists)
                {
                    <option value="@item.Text" data-id="@item.Value"></option>
                }
            </datalist>

            <div class="results-list">
                @for (int i = 0; i < Model.Results.Count; i++)
                {
                    <div class="result-item-card">
                        <div class="pos-badge">@Model.Results[i].Position</div>

                        <input type="hidden" asp-for="Results[i].Position" />

                        <div class="px-3" style="flex-grow:1;">
                            <input type="text"
                                   list="cyclistList"
                                   class="player-search-input js-cyclist-name"
                                   value="@Model.Results[i].CyclistName"
                                   oninput="syncId(this)"
                                   placeholder="Zoek renner..." />

                            <input type="hidden" asp-for="Results[i].CyclistId" />
                        </div>

                        <div class="jersey-flex">
                            <label>
                                <input type="checkbox" asp-for="Results[i].HasYellowJersey" class="d-none js-jersey-checkbox" data-jersey="Red" />
                                <span class="jersey-dot dot-red"></span>
                            </label>

                            <label>
                                <input type="checkbox" asp-for="Results[i].HasGreenJersey" class="d-none js-jersey-checkbox" data-jersey="Green" />
                                <span class="jersey-dot dot-green"></span>
                            </label>

                            <label>
                                <input type="checkbox" asp-for="Results[i].HasPolkaJersey" class="d-none js-jersey-checkbox" data-jersey="Blue" />
                                <span class="jersey-dot dot-blue"></span>
                            </label>

                            <label>
                                <input type="checkbox" asp-for="Results[i].HasWhiteJersey" class="d-none js-jersey-checkbox" data-jersey="White" />
                                <span class="jersey-dot dot-white"></span>
                            </label>
                        </div>
                    </div>
                }
            </div>

            <div class="player-table-card outside-jersey-card" style="margin-top:20px;">
                <h2 style="padding:20px;">Truidragers buiten Top 25</h2>

                <div class="results-list" style="padding:20px;">

                    <div class="result-item-card">
                        <div class="pos-badge dot-red"></div>
                        <input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@redName" oninput="syncId(this); clearTop25Jersey('Red');" />
                        <input type="hidden" asp-for="YellowOutsideTop25CyclistId" />
                    </div>

                    <div class="result-item-card">
                        <div class="pos-badge dot-green"></div>
                        <input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@greenName" oninput="syncId(this); clearTop25Jersey('Green');" />
                        <input type="hidden" asp-for="GreenOutsideTop25CyclistId" />
                    </div>

                    <div class="result-item-card">
                        <div class="pos-badge dot-blue"></div>
                        <input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@blueName" oninput="syncId(this); clearTop25Jersey('Blue');" />
                        <input type="hidden" asp-for="PolkaOutsideTop25CyclistId" />
                    </div>

                    <div class="result-item-card">
                        <div class="pos-badge dot-white"></div>
                        <input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@whiteName" oninput="syncId(this); clearTop25Jersey('White');" />
                        <input type="hidden" asp-for="WhiteOutsideTop25CyclistId" />
                    </div>

                </div>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        function syncId(input) {
            const list = document.getElementById("cyclistList");
            const hidden = input.nextElementSibling;
            const val = input.value.trim().toLowerCase();

            const match = Array.from(list.options)
                .find(o => o.value.toLowerCase() === val);

            hidden.value = match ? match.dataset.id : "";
        }

        function clearTop25Jersey(type) {
            document.querySelectorAll(`[data-jersey="${type}"]`)
                .forEach(x => x.checked = false);
        }

        function clearOutsideJersey(type) {
            const map = {
                Red: "Yellow",
                Green: "Green",
                Blue: "Polka",
                White: "White"
            };

            const hidden = document.querySelector(`input[name="${map[type]}OutsideTop25CyclistId"]`);

            if (hidden) {
                hidden.value = "";

                if (hidden.previousElementSibling) {
                    hidden.previousElementSibling.value = "";
                }
            }
        }

        document.querySelectorAll(".js-jersey-checkbox").forEach(box => {
            box.addEventListener("change", function () {
                if (this.checked) {
                    clearOutsideJersey(this.dataset.jersey);
                }
            });
        });
    </script>
}