@model StageProject_RaceCore.ViewModels.ScoringViewModel

@{
    ViewData["Title"] = "Etappe Resultaten";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Scoring.css" asp-append-version="true" />

<div class="scoring-page">
    @if (TempData["Error"] != null)
    {
        <div class="draft-alert draft-alert-error">@TempData["Error"]</div>
    }

    @if (TempData["DatabaseError"] != null)
    {
        <div class="draft-alert draft-alert-error">@TempData["DatabaseError"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="draft-alert" style="background:#ecfdf5;color:#166534;border-color:#bbf7d0;">
            @TempData["Success"]
        </div>
    }

    <form asp-action="SaveScores" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StageId" />

        <div class="player-header-card">
            <div>
                <h1 class="player-page-title">Etappe @Model.StageId Resultaten</h1>
                <p class="player-page-subtitle">
                    Vul de top 25 in. Klik op de trui-kleuren als een renner in de top 25 een trui draagt.
                    Truidragers buiten de top 25 kies je onderaan.
                </p>
            </div>

            <button type="submit" class="player-btn-white">
                Scores Publiceren
            </button>
        </div>

        <datalist id="cyclistList">
            @foreach (var item in Model.AvailableCyclists)
            {
                <option value="@item.Text" data-id="@item.Value"></option>
            }
        </datalist>

        <div class="results-list">
            @for (int i = 0; i < Model.Results.Count; i++)
            {
                <div class="result-item-card">
                    <div class="pos-badge">@Model.Results[i].Position</div>

                    <input type="hidden" asp-for="Results[i].Position" />

                    <div class="px-3">
                        <input type="text"
                               list="cyclistList"
                               class="player-search-input js-cyclist-name"
                               value="@Model.Results[i].CyclistName"
                               placeholder="Zoek renner..."
                               oninput="syncId(this)"
                               autocomplete="off" />

                        <input type="hidden" asp-for="Results[i].CyclistId" />
                    </div>

                    <div class="jersey-flex">
                        <label title="Gele trui">
                            <input type="checkbox" asp-for="Results[i].HasYellowJersey" class="d-none js-jersey-checkbox" data-jersey="Yellow" />
                            <span class="jersey-dot dot-yellow"></span>
                        </label>

                        <label title="Groene trui">
                            <input type="checkbox" asp-for="Results[i].HasGreenJersey" class="d-none js-jersey-checkbox" data-jersey="Green" />
                            <span class="jersey-dot dot-green"></span>
                        </label>

                        <label title="Bolletjestrui">
                            <input type="checkbox" asp-for="Results[i].HasPolkaJersey" class="d-none js-jersey-checkbox" data-jersey="Polka" />
                            <span class="jersey-dot dot-red"></span>
                        </label>

                        <label title="Witte trui">
                            <input type="checkbox" asp-for="Results[i].HasWhiteJersey" class="d-none js-jersey-checkbox" data-jersey="White" />
                            <span class="jersey-dot dot-white"></span>
                        </label>
                    </div>
                </div>
            }
        </div>

        <div class="player-table-card" style="margin-top:24px;padding:24px;">
            <h2 style="margin-top:0;">Truidragers buiten Top 25</h2>
            <p style="color:#6b7280;margin-bottom:18px;">
                Kies hier alleen truidragers die niet in de top 25 staan.
                Als de truidrager wel in de top 25 staat, klik je bovenaan op het juiste kleurbolletje.
            </p>

            <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;">
                <div>
                    <label style="font-weight:700;">Gele trui</label>
                    <select asp-for="YellowOutsideTop25CyclistId" asp-items="Model.AvailableCyclists" class="player-search-input js-outside-jersey" data-jersey="Yellow">
                        <option value="">Geen gele trui buiten top 25</option>
                    </select>
                </div>

                <div>
                    <label style="font-weight:700;">Groene trui</label>
                    <select asp-for="GreenOutsideTop25CyclistId" asp-items="Model.AvailableCyclists" class="player-search-input js-outside-jersey" data-jersey="Green">
                        <option value="">Geen groene trui buiten top 25</option>
                    </select>
                </div>

                <div>
                    <label style="font-weight:700;">Bolletjestrui</label>
                    <select asp-for="PolkaOutsideTop25CyclistId" asp-items="Model.AvailableCyclists" class="player-search-input js-outside-jersey" data-jersey="Polka">
                        <option value="">Geen bolletjestrui buiten top 25</option>
                    </select>
                </div>

                <div>
                    <label style="font-weight:700;">Witte trui</label>
                    <select asp-for="WhiteOutsideTop25CyclistId" asp-items="Model.AvailableCyclists" class="player-search-input js-outside-jersey" data-jersey="White">
                        <option value="">Geen witte trui buiten top 25</option>
                    </select>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".js-cyclist-name").forEach(input => {
                if (input.value !== "") {
                    syncId(input);
                }
            });

            document.querySelectorAll(".js-jersey-checkbox").forEach(box => {
                box.addEventListener("change", function () {
                    if (this.checked) {
                        const jerseyType = this.dataset.jersey;

                        document.querySelectorAll('.js-jersey-checkbox[data-jersey="' + jerseyType + '"]').forEach(other => {
                            if (other !== this) {
                                other.checked = false;
                            }
                        });

                        document.querySelectorAll('.js-outside-jersey[data-jersey="' + jerseyType + '"]').forEach(select => {
                            select.value = "";
                        });
                    }
                });
            });

            document.querySelectorAll(".js-outside-jersey").forEach(select => {
                select.addEventListener("change", function () {
                    if (this.value) {
                        const jerseyType = this.dataset.jersey;

                        document.querySelectorAll('.js-jersey-checkbox[data-jersey="' + jerseyType + '"]').forEach(box => {
                            box.checked = false;
                        });
                    }
                });
            });
        });

        function syncId(input) {
            const list = document.getElementById("cyclistList");
            const hidden = input.nextElementSibling;
            const option = Array.from(list.options).find(o => o.value === input.value);

            if (option) {
                hidden.value = option.getAttribute("data-id");
                input.style.borderColor = "#10b981";
                input.style.backgroundColor = "#f0fdf4";
            } else {
                hidden.value = "";
                input.style.borderColor = "#d1d5db";
                input.style.backgroundColor = "#f9fafb";
            }
        }
    </script>
}