@model StageProject_RaceCore.ViewModels.ScoringViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Etappe Resultaten";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var races = ViewBag.Races as List<Race> ?? new List<Race>();
    var selectedRaceId = ViewBag.SelectedRaceId as int? ?? 0;
    var stages = ViewBag.AvailableStages as List<SelectListItem> ?? new List<SelectListItem>();

    string redName = ViewData["RedOutsideTop25CyclistName"]?.ToString() ?? "";
    string greenName = ViewData["GreenOutsideTop25CyclistName"]?.ToString() ?? "";
    string blueName = ViewData["BlueOutsideTop25CyclistName"]?.ToString() ?? "";
    string whiteName = ViewData["WhiteOutsideTop25CyclistName"]?.ToString() ?? "";
}

<link rel="stylesheet" href="~/css/Scoring.css" asp-append-version="true" />

<div class="scoring-page">
    @* --- NAVIGATIE BALK --- *@
    <div class="d-flex justify-content-between mb-3">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Dashboard
        </a>
        <a asp-controller="Result" asp-action="StageResults" class="btn btn-info text-white">
            Stage Results <i class="fas fa-chart-line"></i>
        </a>
    </div>

    @* --- ALERTS --- *@
    @if (TempData["Error"] != null || TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">
            <strong>Fout:</strong> @(TempData["Error"] ?? TempData["ErrorMessage"])
        </div>
    }

    @* --- SELECTIE SECTIE (WEDSTRIJD & RIT DROPDOWNS) --- *@
    <div class="player-header-card">
        <div>
            <h1 class="player-page-title">Scoring Beheer</h1>
            <p class="player-page-subtitle">Selecteer de gewenste wedstrijd en etappe.</p>
        </div>
    </div>

    <div class="player-table-card" style="padding:20px; margin-bottom:20px;">
        <form asp-controller="Scoring" asp-action="Index" method="get" id="selectionForm">
            <div style="display:grid; grid-template-columns: 1fr 1fr auto; gap:15px; align-items: end;">
                
                @* Wedstrijd Dropdown *@
                <div>
                    <label style="font-weight:700; display:block; margin-bottom:5px;">Wedstrijd kiezen</label>
                    <select name="raceId" class="player-search-input" onchange="this.form.submit()">
                        <option value="">-- Selecteer Wedstrijd --</option>
                        @foreach (var race in races)
                        {
                            <!option value="@race.Id" @(race.Id == selectedRaceId ? "selected" : "")>
                                @race.Name
                            </!option>
                        }
                    </select>
                </div>

                @* Rit Dropdown *@
                <div>
                    <label style="font-weight:700; display:block; margin-bottom:5px;">Rit kiezen</label>
                    <select name="stageId" class="player-search-input">
                        @foreach (var stage in stages)
                        {
                            <option value="@stage.Value" selected="@stage.Selected">@stage.Text</option>
                        }
                    </select>
                </div>

                @* Laad Knop *@
                <button type="submit" class="player-btn-white" style="height: 45px;">
                    Rit laden
                </button>
            </div>
        </form>
    </div>

    @* --- SCORING FORMULIER --- *@
    @if (Model.StageId > 0)
    {
        <form asp-controller="Scoring" asp-action="SaveScores" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="StageId" />

            <div class="player-header-card">
                <div>
                    <h1 class="player-page-title">Rit @Model.StageId Resultaten</h1>
                </div>
                <button type="submit" class="player-btn-white">Scores Publiceren</button>
            </div>

            <datalist id="cyclistList">
                @foreach (var item in Model.AvailableCyclists)
                {
                    <option value="@item.Text" data-id="@item.Value"></option>
                }
            </datalist>

            @* Top 25 *@
            <div class="results-list">
                @for (int i = 0; i < Model.Results.Count; i++)
                {
                    <div class="result-item-card">
                        <div class="pos-badge">@Model.Results[i].Position</div>
                        <input type="hidden" asp-for="Results[i].Position" />
                        <div class="px-3" style="flex-grow:1;">
                            <input type="text" list="cyclistList" class="player-search-input js-cyclist-name" value="@Model.Results[i].CyclistName" oninput="syncId(this)" autocomplete="off" placeholder="Zoek renner..." />
                            <input type="hidden" asp-for="Results[i].CyclistId" />
                        </div>
                        <div class="jersey-flex">
                            <label><input type="checkbox" asp-for="Results[i].HasYellowJersey" class="d-none js-jersey-checkbox" data-jersey="Red" /><span class="jersey-dot dot-red"></span></label>
                            <label><input type="checkbox" asp-for="Results[i].HasGreenJersey" class="d-none js-jersey-checkbox" data-jersey="Green" /><span class="jersey-dot dot-green"></span></label>
                            <label><input type="checkbox" asp-for="Results[i].HasPolkaJersey" class="d-none js-jersey-checkbox" data-jersey="Blue" /><span class="jersey-dot dot-blue"></span></label>
                            <label><input type="checkbox" asp-for="Results[i].HasWhiteJersey" class="d-none js-jersey-checkbox" data-jersey="White" /><span class="jersey-dot dot-white"></span></label>
                        </div>
                    </div>
                }
            </div>

            @* Buiten Top 25 *@
            <div class="player-table-card outside-jersey-card" style="margin-top:20px;">
                <h2 class="outside-jersey-title">Truidragers buiten Top 25</h2>
                <div class="results-list">
                    <div class="result-item-card"><div class="pos-badge dot-red"></div><div class="px-3" style="flex-grow:1;"><input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@redName" oninput="syncId(this); clearTop25Jersey('Red');" placeholder="Rode trui..." /><input type="hidden" asp-for="YellowOutsideTop25CyclistId" /></div></div>
                    <div class="result-item-card"><div class="pos-badge dot-green"></div><div class="px-3" style="flex-grow:1;"><input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@greenName" oninput="syncId(this); clearTop25Jersey('Green');" placeholder="Groene trui..." /><input type="hidden" asp-for="GreenOutsideTop25CyclistId" /></div></div>
                    <div class="result-item-card"><div class="pos-badge dot-blue"></div><div class="px-3" style="flex-grow:1;"><input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@blueName" oninput="syncId(this); clearTop25Jersey('Blue');" placeholder="Blauwe trui..." /><input type="hidden" asp-for="PolkaOutsideTop25CyclistId" /></div></div>
                    <div class="result-item-card"><div class="pos-badge dot-white"></div><div class="px-3" style="flex-grow:1;"><input type="text" list="cyclistList" class="player-search-input js-outside-jersey-name" value="@whiteName" oninput="syncId(this); clearTop25Jersey('White');" placeholder="Witte trui..." /><input type="hidden" asp-for="WhiteOutsideTop25CyclistId" /></div></div>
                </div>
            </div>
        </form>
    }
</div>

@section Scripts {
    <script>
        function syncId(input) {
            const list = document.getElementById("cyclistList");
            const hidden = input.nextElementSibling;
            const typedValue = input.value.trim().toLowerCase();
            const option = Array.from(list.options).find(o => o.value.trim().toLowerCase() === typedValue);
            if (option) {
                hidden.value = option.getAttribute("data-id");
                input.style.borderColor = "#10b981";
            } else {
                hidden.value = "";
                input.style.borderColor = "#d1d5db";
            }
        }

        function clearTop25Jersey(jerseyType) {
            document.querySelectorAll('.js-jersey-checkbox[data-jersey="' + jerseyType + '"]').forEach(box => box.checked = false);
        }

        function clearOutsideJersey(jerseyType) {
            const map = { 'Red': 'Yellow', 'Green': 'Green', 'Blue': 'Polka', 'White': 'White' };
            const hidden = document.querySelector(`input[name="${map[jerseyType]}OutsideTop25CyclistId"]`);
            if (hidden) {
                const textInput = hidden.previousElementSibling;
                hidden.value = ""; textInput.value = "";
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".js-jersey-checkbox").forEach(box => {
                box.addEventListener("change", function () {
                    if (this.checked) {
                        const jerseyType = this.dataset.jersey;
                        document.querySelectorAll(`.js-jersey-checkbox[data-jersey="${jerseyType}"]`).forEach(other => {
                            if (other !== this) other.checked = false;
                        });
                        clearOutsideJersey(jerseyType);
                    }
                });
            });
        });
    </script>
}