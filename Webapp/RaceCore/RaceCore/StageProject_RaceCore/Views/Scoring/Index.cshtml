<script>
    const allCyclists = [
        @foreach (var rider in Model.AvailableCyclists)
        {
                <text>{ id: "@rider.Value", name: @Html.Raw(JsonSerializer.Serialize(rider.Text)) },</text>
        }
    ];

    function getHiddenInput(textInput) {
        const row = textInput.closest(".scoring-result-row, .outside-jersey-row");
        if (!row) return null;

        if (textInput.classList.contains("js-cyclist-name")) {
            return row.querySelector(".js-cyclist-id");
        }

        if (textInput.classList.contains("js-outside-jersey-name")) {
            return row.querySelector(".js-outside-jersey-id");
        }

        return null;
    }

    function getSelectedCyclistIds(exceptInput) {
        const selectedIds = new Set();

        document.querySelectorAll(".js-cyclist-name, .js-outside-jersey-name").forEach(input => {
            if (input === exceptInput) return;

            const hidden = getHiddenInput(input);

            if (hidden && hidden.value) {
                selectedIds.add(hidden.value);
            }
        });

        return selectedIds;
    }

    function updateCyclistList(activeInput) {
        const datalist = document.getElementById("cyclistList");
        const selectedIds = getSelectedCyclistIds(activeInput);
        const activeHidden = getHiddenInput(activeInput);
        const activeId = activeHidden ? activeHidden.value : "";

        datalist.innerHTML = "";

        allCyclists.forEach(cyclist => {
            if (!selectedIds.has(cyclist.id) || cyclist.id === activeId) {
                const option = document.createElement("option");
                option.value = cyclist.name;
                option.dataset.id = cyclist.id;
                datalist.appendChild(option);
            }
        });
    }

    function syncCyclistId(input) {
        const hidden = getHiddenInput(input);
        if (!hidden) return;

        const typedName = input.value.trim().toLowerCase();

        if (typedName === "") {
            hidden.value = "";
            input.classList.remove("is-invalid");
            return;
        }
@section Scripts {
    <script>
        const allCyclists = [
            @foreach (var rider in Model.AvailableCyclists)
            {
                        <text>{ id: "@rider.Value", name: @Html.Raw(JsonSerializer.Serialize(rider.Text)) },</text>
            }
        ];

        // 1. TOGGLE LOGICA VOOR BOLLEN
        // We houden bij welke radiobutton laatst is aangeklikt
        document.querySelectorAll('.jersey-dot input[type="radio"]').forEach(radio => {
            radio.addEventListener('click', function(e) {
                if (this.dataset.waschecked === 'true') {
                    // Als hij al aan stond: uitzetten
                    this.checked = false;
                    this.dataset.waschecked = 'false';
                    
                    // Hidden input ook op false zetten
                    const color = this.name.replace('Jersey', '');
                    const index = this.value;
                    document.getElementById(`Has${color}_${index}`).value = "false";
                } else {
                    // Eerst alle andere van dezelfde groep op 'false' zetten in dataset
                    document.querySelectorAll(`input[name="${this.name}"]`).forEach(r => r.dataset.waschecked = 'false');
                    // Deze op 'true' zetten
                    this.dataset.waschecked = 'true';
                }
            });
        });

        function updateJerseyHiddenInputs(radioElement, color, currentIndex) {
            // Zet alle hidden inputs van deze kleur op false
            document.querySelectorAll(`input[id^='Has${color}_']`).forEach(hidden => hidden.value = "false");
            
            // Zet de huidige op true (als de radio nog steeds checked is na de click event)
            const currentHidden = document.getElementById(`Has${color}_${currentIndex}`);
            if (currentHidden && radioElement.checked) {
                currentHidden.value = "true";
                clearOutsideJersey(color);
            }
        }

        // 2. DUBBELE RENNER VALIDATIE
        function checkForDuplicates() {
            const inputs = document.querySelectorAll('.js-cyclist-name, .js-outside-jersey-name');
            const names = [];
            const duplicates = [];

            // Reset foutmeldingen
            inputs.forEach(input => input.style.borderColor = "");
            const existingAlert = document.getElementById('duplicate-alert');
            if (existingAlert) existingAlert.remove();

            inputs.forEach(input => {
                const val = input.value.trim().toLowerCase();
                if (val !== "") {
                    if (names.includes(val)) {
                        duplicates.push(val);
                    }
                    names.push(val);
                }
            });

        const cyclist = allCyclists.find(c =>
            c.name.trim().toLowerCase() === typedName
        );

        if (!cyclist) {
            hidden.value = "";
            input.classList.remove("is-invalid");
            return;
        }
            if (duplicates.length > 0) {
                // Markeer velden
                inputs.forEach(input => {
                    if (duplicates.includes(input.value.trim().toLowerCase())) {
                        input.style.borderColor = "#ef4444";
                        input.style.backgroundColor = "#fff1f2";
                    } else {
                        input.style.backgroundColor = "";
                    }
                });

        const selectedIds = getSelectedCyclistIds(input);

        if (selectedIds.has(cyclist.id)) {
            hidden.value = "";
            input.value = "";
            input.classList.add("is-invalid");
            alert("Deze renner is al gekozen. Kies een andere renner.");
            updateCyclistList(input);
            return;
        }

        hidden.value = cyclist.id;
        input.classList.remove("is-invalid");
    }
                // Toon melding
                const alertDiv = document.createElement('div');
                alertDiv.id = 'duplicate-alert';
                alertDiv.className = 'scoring-alert scoring-alert-error';
                alertDiv.innerHTML = `<strong>LET OP:</strong> Renner staat dubbel ingevuld!`;
                document.querySelector('.scoring-page').prepend(alertDiv);
                alertDiv.scrollIntoView({ behavior: 'smooth' });
            }
        }

    function clearOutsideJersey(type) {
        const outsideInput = document.querySelector(`.js-outside-jersey-name[data-jersey='${type}']`);
        const outsideHidden = document.querySelector(`.js-outside-jersey-id[data-jersey='${type}']`);

        if (outsideInput) outsideInput.value = "";
        if (outsideHidden) outsideHidden.value = "";
    }
        // Bestaande helper functies
        function getHiddenInput(textInput) {
            const row = textInput.closest(".scoring-result-row, .outside-jersey-row");
            return textInput.classList.contains("js-cyclist-name") ? row.querySelector(".js-cyclist-id") : row.querySelector(".js-outside-jersey-id");
        }

    function clearTop25Jersey(type) {
        const outsideHidden = document.querySelector(`.js-outside-jersey-id[data-jersey='${type}']`);
        function updateCyclistList(activeInput) {
            const datalist = document.getElementById("cyclistList");
            datalist.innerHTML = "";
            allCyclists.forEach(cyclist => {
                const option = document.createElement("option");
                option.value = cyclist.name;
                datalist.appendChild(option);
            });
        }

        if (!outsideHidden || !outsideHidden.value) return;

        const checkboxMap = {
            Red: "HasYellowJersey",
            Green: "HasGreenJersey",
            Blue: "HasPolkaJersey",
            White: "HasWhiteJersey"
        };
        function syncCyclistId(input) {
            const hidden = getHiddenInput(input);
            if (!hidden) return;
            const typedName = input.value.trim().toLowerCase();
            const cyclist = allCyclists.find(c => c.name.toLowerCase() === typedName);
            hidden.value = cyclist ? cyclist.id : "";
            
            // Trigger check na elke wijziging
            checkForDuplicates();
        }

        document.querySelectorAll("input[type='checkbox']").forEach(cb => {
            if (cb.name.includes(checkboxMap[type])) {
                cb.checked = false;
            }
        });
    }

    document.getElementById("scoringForm")?.addEventListener("submit", function (e) {
        let duplicateFound = false;
        const usedIds = new Map();

        document.querySelectorAll(".js-cyclist-name, .js-outside-jersey-name").forEach(input => {
            syncCyclistId(input);

            const hidden = getHiddenInput(input);

            if (!hidden || !hidden.value) {
                input.classList.remove("is-invalid");
                return;
            }
        function clearOutsideJersey(type) {
            const outsideInput = document.querySelector(`.js-outside-jersey-name[data-jersey='${type}']`);
            const outsideHidden = document.querySelector(`.js-outside-jersey-id[data-jersey='${type}']`);
            if (outsideInput) outsideInput.value = "";
            if (outsideHidden) outsideHidden.value = "";
            checkForDuplicates();
        }

            if (usedIds.has(hidden.value)) {
                duplicateFound = true;
                input.classList.add("is-invalid");
            } else {
                usedIds.set(hidden.value, true);
                input.classList.remove("is-invalid");
            }
        });
        function clearTop25Jersey(color) {
            document.querySelectorAll(`input[name='Jersey${color}']`).forEach(rb => {
                rb.checked = false;
                rb.dataset.waschecked = 'false';
            });
            document.querySelectorAll(`input[id^='Has${color}_']`).forEach(hidden => hidden.value = "false");
        }

        if (duplicateFound) {
            e.preventDefault();
            alert("Er staat een renner dubbel. Corrigeer dit eerst voordat je de scores publiceert.");
        }
    });

    document.addEventListener("DOMContentLoaded", function () {
        const firstInput = document.querySelector(".js-cyclist-name, .js-outside-jersey-name");

        if (firstInput) {
            updateCyclistList(firstInput);
        }
    });
</script>
        // Form submit blokkeren bij duplicaten
        document.getElementById('scoringForm').addEventListener('submit', function(e) {
            const inputs = document.querySelectorAll('.js-cyclist-name, .js-outside-jersey-name');
            const names = Array.from(inputs).map(i => i.value.trim().toLowerCase()).filter(n => n !== "");
            const hasDuplicates = names.some((name, index) => names.indexOf(name) !== index);
            
            if (hasDuplicates) {
                e.preventDefault();
                alert("Er staat een renner dubbel. Corrigeer voordat u de scores publiceert.");
            }
        });
    </script>
