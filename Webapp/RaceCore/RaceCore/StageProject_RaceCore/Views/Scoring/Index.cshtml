@model StageProject_RaceCore.ViewModels.ScoringViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Etappe Resultaten";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var races = ViewBag.Races as List<Race> ?? new List<Race>();
    var selectedRaceId = ViewBag.SelectedRaceId as int? ?? 0;
    var stages = ViewBag.AvailableStages as List<SelectListItem> ?? new List<SelectListItem>();

    string redName = ViewData["RedOutsideTop25CyclistName"]?.ToString() ?? "";
    string greenName = ViewData["GreenOutsideTop25CyclistName"]?.ToString() ?? "";
    string blueName = ViewData["BlueOutsideTop25CyclistName"]?.ToString() ?? "";
    string whiteName = ViewData["WhiteOutsideTop25CyclistName"]?.ToString() ?? "";
}

<link rel="stylesheet" href="~/css/Scoring.css" asp-append-version="true" />

<div class="scoring-page">
    @if (TempData["Error"] != null)
    {
        <div class="draft-alert draft-alert-error">@TempData["Error"]</div>
    }

    @if (TempData["DatabaseError"] != null)
    {
        <div class="draft-alert draft-alert-error">@TempData["DatabaseError"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="draft-alert">@TempData["Success"]</div>
    }

    <div class="player-header-card">
        <div>
            <h1 class="player-page-title">Scoring</h1>
            <p class="player-page-subtitle">
                Kies een wedstrijd en rit via de dropdowns.
            </p>
        </div>
    </div>

    <div class="player-table-card scoring-selector-card">
        <form asp-action="Index" method="get" class="scoring-selector-form">
            <div class="scoring-stage-group">
                <label for="raceId">Wedstrijd kiezen</label>
                <select id="raceId"
                        name="raceId"
                        class="scoring-stage-select"
                        onchange="this.form.submit()">
                    @foreach (var race in races)
                    {
                        <option value="@race.Id" selected="@(race.Id == selectedRaceId)">
                            @race.Name
                        </option>
                    }
                </select>
            </div>

            <div class="scoring-stage-group">
                <label for="stageId">Rit kiezen</label>
                <select id="stageId"
                        name="stageId"
                        class="scoring-stage-select"
                        onchange="this.form.submit()">
                    @foreach (var stage in stages)
                    {
                        <option value="@stage.Value" selected="@stage.Selected">
                            @stage.Text
                        </option>
                    }
                </select>
            </div>
        </form>
    </div>

    <form asp-action="SaveScores" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="StageId" />

        <div class="player-header-card">
            <div>
                <h1 class="player-page-title">Rit @Model.StageId Resultaten</h1>
                <p class="player-page-subtitle">
                    Vul de top 25 in. Typ een renner en selecteer uit de lijst.
                </p>
            </div>

            <button type="submit" class="player-btn-white">
                Scores Publiceren
            </button>
        </div>

        <datalist id="cyclistList">
            @foreach (var item in Model.AvailableCyclists)
            {
                <option value="@item.Text" data-id="@item.Value"></option>
            }
        </datalist>

        <div class="results-list">
            @for (int i = 0; i < Model.Results.Count; i++)
            {
                <div class="result-item-card">
                    <div class="pos-badge">@Model.Results[i].Position</div>

                    <input type="hidden" asp-for="Results[i].Position" />

                    <div class="px-3">
                        <input type="text"
                               list="cyclistList"
                               class="player-search-input js-cyclist-name"
                               value="@Model.Results[i].CyclistName"
                               placeholder="Zoek renner..."
                               oninput="syncId(this)"
                               autocomplete="off" />

                        <input type="hidden" asp-for="Results[i].CyclistId" />
                    </div>

                    <div class="jersey-flex">
                        <label title="Rode trui">
                            <input type="checkbox"
                                   asp-for="Results[i].HasYellowJersey"
                                   class="d-none js-jersey-checkbox"
                                   data-jersey="Red" />
                            <span class="jersey-dot dot-red"></span>
                        </label>

                        <label title="Groene trui">
                            <input type="checkbox"
                                   asp-for="Results[i].HasGreenJersey"
                                   class="d-none js-jersey-checkbox"
                                   data-jersey="Green" />
                            <span class="jersey-dot dot-green"></span>
                        </label>

                        <label title="Blauwe trui">
                            <input type="checkbox"
                                   asp-for="Results[i].HasPolkaJersey"
                                   class="d-none js-jersey-checkbox"
                                   data-jersey="Blue" />
                            <span class="jersey-dot dot-blue"></span>
                        </label>

                        <label title="Witte trui">
                            <input type="checkbox"
                                   asp-for="Results[i].HasWhiteJersey"
                                   class="d-none js-jersey-checkbox"
                                   data-jersey="White" />
                            <span class="jersey-dot dot-white"></span>
                        </label>
                    </div>
                </div>
            }
        </div>

        <div class="player-table-card outside-jersey-card">
            <h2 class="outside-jersey-title">Truidragers buiten Top 25</h2>

            <div class="results-list">
                <div class="result-item-card">
                    <div class="pos-badge dot-red"></div>

                    <div class="px-3">
                        <input type="text"
                               list="cyclistList"
                               class="player-search-input js-outside-jersey-name"
                               value="@redName"
                               placeholder="Rode trui..."
                               oninput="syncId(this); clearTop25Jersey('Red');"
                               autocomplete="off" />

                        <input type="hidden" asp-for="YellowOutsideTop25CyclistId" />
                    </div>
                </div>

                <div class="result-item-card">
                    <div class="pos-badge dot-green"></div>

                    <div class="px-3">
                        <input type="text"
                               list="cyclistList"
                               class="player-search-input js-outside-jersey-name"
                               value="@greenName"
                               placeholder="Groene trui..."
                               oninput="syncId(this); clearTop25Jersey('Green');"
                               autocomplete="off" />

                        <input type="hidden" asp-for="GreenOutsideTop25CyclistId" />
                    </div>
                </div>

                <div class="result-item-card">
                    <div class="pos-badge dot-blue"></div>

                    <div class="px-3">
                        <input type="text"
                               list="cyclistList"
                               class="player-search-input js-outside-jersey-name"
                               value="@blueName"
                               placeholder="Blauwe trui..."
                               oninput="syncId(this); clearTop25Jersey('Blue');"
                               autocomplete="off" />

                        <input type="hidden" asp-for="PolkaOutsideTop25CyclistId" />
                    </div>
                </div>

                <div class="result-item-card">
                    <div class="pos-badge dot-white"></div>

                    <div class="px-3">
                        <input type="text"
                               list="cyclistList"
                               class="player-search-input js-outside-jersey-name"
                               value="@whiteName"
                               placeholder="Witte trui..."
                               oninput="syncId(this); clearTop25Jersey('White');"
                               autocomplete="off" />

                        <input type="hidden" asp-for="WhiteOutsideTop25CyclistId" />
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".js-cyclist-name, .js-outside-jersey-name").forEach(input => {
                if (input.value !== "") {
                    syncId(input);
                }
            });

            document.querySelectorAll(".js-jersey-checkbox").forEach(box => {
                box.addEventListener("change", function () {
                    if (this.checked) {
                        const jerseyType = this.dataset.jersey;

                        document.querySelectorAll('.js-jersey-checkbox[data-jersey="' + jerseyType + '"]').forEach(other => {
                            if (other !== this) {
                                other.checked = false;
                            }
                        });

                        clearOutsideJersey(jerseyType);
                    }
                });
            });
        });

        function syncId(input) {
            const list = document.getElementById("cyclistList");
            const hidden = input.nextElementSibling;
            const typedValue = input.value.trim().toLowerCase();

            const option = Array.from(list.options).find(o =>
                o.value.trim().toLowerCase() === typedValue
            );

            if (option) {
                hidden.value = option.getAttribute("data-id");
                input.value = option.value;
                input.style.borderColor = "#10b981";
                input.style.backgroundColor = "#f0fdf4";
            } else {
                hidden.value = "";
                input.style.borderColor = "#d1d5db";
                input.style.backgroundColor = "#f9fafb";
            }
        }

        function clearTop25Jersey(jerseyType) {
            document.querySelectorAll('.js-jersey-checkbox[data-jersey="' + jerseyType + '"]').forEach(box => {
                box.checked = false;
            });
        }

        function clearOutsideJersey(jerseyType) {
            let inputName = "";

            if (jerseyType === "Red") inputName = "YellowOutsideTop25CyclistId";
            if (jerseyType === "Green") inputName = "GreenOutsideTop25CyclistId";
            if (jerseyType === "Blue") inputName = "PolkaOutsideTop25CyclistId";
            if (jerseyType === "White") inputName = "WhiteOutsideTop25CyclistId";

            const hidden = document.querySelector('input[name="' + inputName + '"]');

            if (hidden) {
                const textInput = hidden.previousElementSibling;
                hidden.value = "";
                textInput.value = "";
                textInput.style.borderColor = "#d1d5db";
                textInput.style.backgroundColor = "#f9fafb";
            }
        }
    </script>
}