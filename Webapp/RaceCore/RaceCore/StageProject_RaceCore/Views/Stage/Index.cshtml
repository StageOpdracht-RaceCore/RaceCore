@model List<StageProject_RaceCore.Models.Stage>
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Ritten";
    var races = ViewBag.Races;
    int selectedRaceId = ViewBag.SelectedRaceId ?? 0;
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Stage.css" asp-append-version="true" />

<div class="stage-page">

    <!-- HERO -->
    <section class="stage-header-card">
        <div class="stage-header-copy">
            <p class="stage-page-kicker">RaceCore</p>
            <h1 class="stage-page-title">Ritten</h1>
            <p class="stage-page-subtitle">
                Selecteer een wedstrijd en bekijk alle ritten.
            </p>
        </div>

        <a asp-controller="Dashboard" asp-action="Index" class="stage-dashboard-white-btn">
            Dashboard
        </a>
    </section>

    <!-- FILTER -->
    <section class="stage-filter-card">
        <form asp-action="Index" method="get" class="race-select-form">

            <div class="race-select-group">
                <label>Wedstrijd</label>

                <select name="raceId" class="app-select" onchange="this.form.submit()">
                    @foreach (var race in (dynamic)races)
                    {
                        <option value="@race.Id" selected="@(race.Id == selectedRaceId)">
                            @race.Name (@race.Year) - @race.StageCount ritten
                        </option>
                    }
                </select>
            </div>

        </form>
    </section>

    <!-- TABLE -->
    <section class="stage-table-card">

        @if (Model != null && Model.Any())
        {
            <table class="stage-table">
                <thead>
                    <tr>
                        <th>Rit</th>
                        <th>Naam</th>
                        <th>Datum</th>
                        <th></th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var stage in Model)
                    {
                        <tr>
                            <td>@stage.StageNumber</td>
                            <td>@stage.Name</td>
                            <td>@(stage.Date?.ToString("dd/MM/yyyy") ?? "-")</td>
                            <td>
                                <a asp-action="Details"
                                       asp-route-id="@stage.Id"
                                       class="app-btn app-btn-primary">
                                    Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="stage-empty-state">
                Geen ritten gevonden voor deze wedstrijd.
            </div>
        }

    </section>

</div>