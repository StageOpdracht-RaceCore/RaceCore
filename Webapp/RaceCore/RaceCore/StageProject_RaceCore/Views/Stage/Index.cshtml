@model List<StageProject_RaceCore.Models.Stage>
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Ritten";
    var races = ViewBag.Races as List<Race> ?? new List<Race>();
    int selectedRaceId = ViewBag.SelectedRaceId ?? 0;
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Stage.css" asp-append-version="true" />

<div class="stage-page">

    <section class="stage-header-card">
        <h1>Ritten</h1>
        <p>Selecteer een wedstrijd en bekijk alle ritten.</p>
    </section>

    <!-- FILTER -->
    <section class="stage-filter-card">
        <form asp-action="Index" method="get">
            <label>Wedstrijd</label>

            <select name="raceId" class="app-select" onchange="this.form.submit()">
                @foreach (var race in races)
                {
                    <option value="@race.Id" selected="@(race.Id == selectedRaceId)">
                        @race.Name (@race.Year)
                    </option>
                }
            </select>
        </form>
    </section>

    <!-- LIJST -->
    <section class="stage-table-card">

        @if (Model.Any())
        {
            <table class="stage-table">
                <thead>
                    <tr>
                        <th>Rit</th>
                        <th>Naam</th>
                        <th>Datum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stage in Model)
                    {
                        <tr>
                            <td>@stage.StageNumber</td>
                            <td>@stage.Name</td>
                            <td>
                                @(stage.Date?.ToString("dd/MM/yyyy") ?? "-")
                            </td>

                            <td>
                                <a asp-action="Details" asp-route-id="@stage.Id" class="app-btn">
                                    Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p>Geen ritten gevonden.</p>
        }
    </section>
</div>