@*
    _ViewImports.cshtml
    Purpose: Provide global using directives and tag helper registrations
    for all Razor views under the Views folder. This keeps view files
    concise by avoiding repeated @using and @addTagHelper directives.
*@

@using StageProject_RaceCore
@using StageProject_RaceCore.Models
@* Register built-in ASP.NET Core MVC Tag Helpers so elements like
   <form asp-action="..."> and <a asp-controller="..."> work in views *@
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
