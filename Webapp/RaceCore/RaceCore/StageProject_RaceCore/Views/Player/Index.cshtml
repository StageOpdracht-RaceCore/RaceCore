@model StageProject_RaceCore.ViewModels.PlayerPageViewModel

@{
    ViewData["Title"] = "Players";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Main.css" />
<link rel="stylesheet" href="~/css/Player.css" />

<section class="page">

    <!-- HEADER -->
    <section class="header">
        <h6>RaceCore</h6>
        <h1>Players</h1>
        <p>Beheer alle spelers, hun draftvolgorde en prestaties in het systeem.</p>

        <div class="player-header-actions">
            <a asp-action="Create" class="player-btn player-btn-primary">
                + Nieuwe speler
            </a>

            <a asp-controller="Game" asp-action="New" class="player-btn player-btn-done">
                ✓ Done
            </a>
        </div>
    </section>

    <!-- ALERTS -->
    @if (TempData["Success"] != null)
    {
        <div class="alert success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert error">
            @TempData["Error"]
        </div>
    }

    <!-- FILTERS (SEARCH) -->
    <section class="filters">
        <h4>Filters</h4>
        <h3>Zoek speler</h3>

        <form method="get" asp-action="Index" class="cyclistsForm">
            
            <div class="formStyle">
                <label for="searchTerm">Zoeken</label>
                <input id="searchTerm"
                       name="searchTerm"
                       value="@Model.SearchTerm"
                       class="select"
                       placeholder="Zoek op naam..." />
            </div>

            <button type="submit" class="formButton btn btn-primary">
                Zoeken
            </button>

            <a asp-action="Index" class="formButton btn btn-danger">
                Reset
            </a>

        </form>
    </section>

    <!-- TABLE -->
    <section class="cyclistsOverview">
        <h4>Overzicht</h4>
        <h3>Players lijst</h3>

        @if (Model.Players != null && Model.Players.Any())
        {
            <div class="cyclistsTableWrapper">

                <table class="cyclistsTable">

                    <thead>
                        <tr>
                            <th>Speler</th>
                            <th>Draft positie</th>
                            <th>Totale punten</th>
                            <th>Selections</th>
                            <th>Draft turns</th>
                            <th>Punten records</th>
                            <th class="text-end">Acties</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var player in Model.Players)
                        {
                            <tr>

                                <td>
                                    <div class="player-name-cell">
                                        <div class="player-avatar">
                                            @(string.IsNullOrWhiteSpace(player.Name) ? "?" : player.Name.Substring(0, 1).ToUpper())
                                        </div>
                                        <div>
                                            <div class="player-name">@player.Name</div>
                                            <div class="player-meta">ID: @player.Id</div>
                                        </div>
                                    </div>
                                </td>

                                <td>
                                    <span class="race raceYes">#@player.PositionInDraft</span>
                                </td>

                                <td>
                                    <strong class="player-points">@player.TotalPoints</strong>
                                </td>

                                <td>@player.SelectionsCount</td>
                                <td>@player.DraftTurnsCount</td>
                                <td>@player.PointsRecordsCount</td>

                                <td>
                                    <div class="player-action-links">
                                        <a asp-action="Details" asp-route-id="@player.Id">Details</a>
                                        <a asp-action="Edit" asp-route-id="@player.Id">Edit</a>
                                        <a asp-action="Delete" asp-route-id="@player.Id">Delete</a>
                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>

                </table>

            </div>
        }
        else
        {
            <div class="empty">
                Geen spelers gevonden.
            </div>
        }
    </section>

</section>