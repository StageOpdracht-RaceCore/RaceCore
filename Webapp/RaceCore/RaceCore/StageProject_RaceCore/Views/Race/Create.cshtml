@model StageProject_RaceCore.Models.Race

@{
    var cyclists = ViewBag.Cyclists as List<StageProject_RaceCore.Models.Cyclist>;
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
}

<form asp-action="Create" method="post">

    <!-- RACE INFO -->
    <input asp-for="Name" class="form-control" placeholder="Naam" />

    <input asp-for="Year" type="number" class="form-control" />

    <input asp-for="StartDate" type="date" class="form-control" />
    <input asp-for="EndDate" type="date" class="form-control" />

    <hr />

    <!-- CYCLISTS -->
    <h3>Cyclists</h3>

    @foreach (var c in cyclists)
    {
        <label>
            <input type="checkbox"
                   name="selectedCyclists"
                   value="@c.Id" />
            @c.FullName
        </label>
        <br />
    }

    <hr />

    <!-- STAGES -->
    <h3>Stages</h3>

    <div id="stages-container"></div>

    <button type="button" id="add-stage">+ Stage</button>

    <hr />

    <button type="submit">Save</button>

</form>
<script>
    function getNextIndex() {
        return document.querySelectorAll("#stages-container input[name*='Name']").length;
    }

    document.getElementById("add-stage").addEventListener("click", function () {

        const index = getNextIndex();
        const container = document.getElementById("stages-container");

        const html = `
        <div style="margin-bottom:10px;">
            <input name="Stages[${index}].Name" class="form-control" placeholder="Stage naam" />
            <input name="Stages[${index}].Date" type="date" class="form-control" />

            <button type="button" onclick="this.parentElement.remove()">
                Delete
            </button>
        </div>
        `;

        container.insertAdjacentHTML("beforeend", html);
    });
</script>