@model StageProject_RaceCore.Models.Race

@inject StageProject_RaceCore.Models.AppDbContext _context

@{
    ViewData["Title"] = "Nieuwe Race";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
    var cyclists = _context.Cyclists.ToList();

}

<link rel="stylesheet" href="~/css/Race.css" />

<section class="race-page">

    ```
    <!-- HEADER -->
    <section class="race-header-card">

        <div>
            <p class="race-page-kicker">RaceCore</p>
            <h1 class="race-page-title">Nieuwe Race</h1>
            <p class="race-page-subtitle">
                Maak een nieuwe race aan in het systeem.
            </p>
        </div>

        <a asp-action="Index" class="race-dashboard-btn">
            Terug
        </a>

    </section>

    <!-- FORM -->
    <section class="race-form-card">

        <form asp-action="Create" method="post">

            @Html.AntiForgeryToken()

            <div class="race-form-grid">

                <!-- BASIS INFO -->
                <div class="race-form-group">
                    <label asp-for="Name">Naam</label>
                    <input asp-for="Name" class="race-input" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="race-form-group">
                    <label asp-for="Year">Jaar</label>
                    <input asp-for="Year" type="number" class="race-input" />
                    <span asp-validation-for="Year" class="text-danger"></span>
                </div>

                <div class="race-form-group">
                    <label asp-for="StartDate">Startdatum</label>
                    <input asp-for="StartDate" type="date" class="race-input" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="race-form-group">
                    <label asp-for="EndDate">Einddatum</label>
                    <input asp-for="EndDate" type="date" class="race-input" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

            </div>

            <!-- RENNERS SELECTEREN -->
            <div class="race-form-group">
                <label>Renners</label>

                <div class="race-checkbox-list">
                    @foreach (var cyclist in cyclists)
                    {
                        <label>
                            <input type="checkbox"
                                   name="SelectedCyclistIds"
                                   value="@cyclist.Id" />
                            @cyclist.FirstName
                        </label>
                    }
                </div>
            </div>

            <!-- NIEUWE RENNER -->
            <div class="race-form-group">
                <label>Nieuwe renner toevoegen</label>
                <input name="NewCyclistName" class="race-input" placeholder="Naam nieuwe renner" />
            </div>

            <!-- STAGES -->
            <div class="race-form-group">
                <label>Stages</label>

                <div id="stages-container">

                    <div class="stage-item">
                        <input name="Stages[0].Name" class="race-input" placeholder="Naam stage" />
                        <input name="Stages[0].Date" type="date" class="race-input" />
                    </div>

                </div>

                <button type="button" class="race-light-btn race-btn" onclick="addStage()">
                    + Stage toevoegen
                </button>
            </div>

            <!-- ACTIONS -->
            <div class="race-form-actions">
                <button type="submit" class="race-primary-btn">
                    Race aanmaken
                </button>

                <a asp-action="Index" class="race-light-btn race-btn">
                    Annuleren
                </a>
            </div>

        </form>

    </section>
    ```

</section>

<script>
    let stageIndex = 1;

    function addStage() {
        const container = document.getElementById("stages-container");

        const html = `
            <div class="stage-item" style="margin-top:10px;">
                <input name="Stages[${stageIndex}].Name" class="race-input" placeholder="Naam stage" />
                <input name="Stages[${stageIndex}].Date" type="date" class="race-input" />
            </div>
        `;

        container.insertAdjacentHTML("beforeend", html);
        stageIndex++;
    }
</script>
