@model StageProject_RaceCore.Models.Race

@{
    ViewData["Title"] = "Race Bewerken";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Race.css" />

<div class="race-page">
    <section class="race-form-card">
        <div class="race-form-header">
            <p class="race-section-kicker">RaceCore</p>
            <h1 class="race-card-title">Race bewerken</h1>
            <p>Pas de details van de race aan.</p>
        </div>

        <form asp-action="Edit" method="post" class="race-form-grid">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="race-form-group">
                <label asp-for="Name">Naam</label>
                <input asp-for="Name" class="race-form-input" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="race-form-group">
                <label asp-for="Year">Jaar</label>
                <input asp-for="Year" class="race-form-input" type="number" />
                <span asp-validation-for="Year" class="text-danger"></span>
            </div>

            <div class="race-form-group">
                <label asp-for="StartDate">Startdatum</label>
                <input asp-for="StartDate" class="race-form-input" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>

            <div class="race-form-group">
                <label asp-for="EndDate">Einddatum</label>
                <input asp-for="EndDate" class="race-form-input" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>

            <div class="race-form-actions">
                <button type="submit" class="race-btn race-btn-primary">Opslaan</button>
                <a asp-action="Index" class="race-btn race-btn-light">Annuleren</a>
            </div>
        </form>
    </section>
</div>