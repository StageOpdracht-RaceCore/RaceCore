@model IEnumerable<StageProject_RaceCore.Models.Race>

@{
    ViewData["Title"] = "Races";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Race.css" asp-append-version="true" />

<div class="player-form-page">
    <div class="player-table-card">
        <div class="player-form-header">
            <p class="player-page-kicker">RaceCore Management</p>
            <div class="d-flex justify-content-between align-items-center">
                <h1>Races</h1>
                <a class="player-btn player-btn-primary" asp-controller="Game" asp-action="new">Nieuwe Race</a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="player-data-table">
                <thead>
                    <tr>
                        <th>Naam</th>
                        <th>Jaar</th>
                        <th>Start</th>
                        <th>Einde</th>
                        <th>Stages</th>
                        <th>Entries</th>
                        <th class="text-end">Acties</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var race in Model)
                        {
                            <tr>
                                <td><strong>@race.Name</strong></td>
                                <td><span class="player-badge-draft">@race.Year</span></td>
                                <td>@(race.StartDate.HasValue ? race.StartDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                                <td>@(race.EndDate.HasValue ? race.EndDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                                <td>@((race.Stages?.Count ?? 0))</td>
                                <td>@((race.RaceEntries?.Count ?? 0))</td>
                                <td class="text-end">
                                    <div class="player-table-actions">
                                        <a class="player-btn player-btn-light btn-sm" asp-action="Edit" asp-route-id="@race.Id">Edit</a>
                                        <a class="player-btn player-btn-light btn-sm" asp-action="Details" asp-route-id="@race.Id">Details</a>
                                        <form asp-action="Delete" asp-route-id="@race.Id" method="post" class="d-inline" onsubmit="return confirm('Race verwijderen?');">
                                            <button type="submit" class="player-btn player-btn-danger btn-sm">Delete</button>
                                            @Html.AntiForgeryToken()
                                        </form>²
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center">Geen races gevonden.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
