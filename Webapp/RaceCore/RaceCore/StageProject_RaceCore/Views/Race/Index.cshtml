@model IEnumerable<StageProject_RaceCore.Models.Race>

@{
    ViewData["Title"] = "Races";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Race.css"/>

<div class="race-page">
    <section class="race-header-card">
        <p class="race-page-kicker">RaceCore</p>
        <h1 class="race-page-title">Races</h1>
        <p class="race-page-subtitle">
            Beheer alle wedstrijden, jaren, ritten en deelnames binnen RaceCore.
        </p>
    </section>

    <section class="race-table-card">
        <div class="race-table-header">
            <div>
                <p class="race-section-kicker">Overzicht</p>
                <h2 class="race-card-title">Race lijst</h2>
            </div>
        </div>

        <div class="race-table-responsive">
            <table class="race-table">
                <thead>
                    <tr>
                        <th>Naam</th>
                        <th>Jaar</th>
                        <th>Start</th>
                        <th>Einde</th>
                        <th>Stages</th>
                        <th>Entries</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var race in Model)
                        {
                            <tr>
                                <td class="race-name">@race.Name</td>
                                <td>
                                    <span class="race-year-badge">@race.Year</span>
                                </td>
                                <td>@(race.StartDate.HasValue ? race.StartDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                                <td>@(race.EndDate.HasValue ? race.EndDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                                <td>
                                    <span class="race-count">@((race.Stages?.Count ?? 0))</span>
                                </td>
                                <td>
                                    <span class="race-count">@((race.RaceEntries?.Count ?? 0))</span>
                                </td>
                                <td class="text-end">
                                    <div class="race-table-actions">
                                        <a class="race-btn race-btn-light btn-sm" asp-action="Edit" asp-route-id="@race.Id">Edit</a>
                                        <a class="race-btn race-btn-light btn-sm" asp-action="Details" asp-route-id="@race.Id">Details</a>

                                        <form asp-action="Delete"
                                              asp-route-id="@race.Id"
                                              method="post"
                                              class="race-delete-form"
                                              onsubmit="return confirm('Race verwijderen?');">
                                            <button type="submit" class="race-btn race-btn-danger btn-sm">Delete</button>
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7">
                                <div class="race-empty-state">
                                    Geen races gevonden.
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>