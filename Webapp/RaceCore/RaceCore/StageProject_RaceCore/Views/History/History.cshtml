@model StageProject_RaceCore.ViewModels.HistoryViewModel
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Historiek";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    
    var races = ViewBag.Races as List<Race> ?? new List<Race>();
    int selectedRaceId = ViewBag.SelectedRaceId ?? 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/history.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Player.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/NewGame.css" asp-append-version="true" />
}

<div class="player-page">
    @* Blauwe Header *@
    <div class="player-header-card">
        <div>
            <p class="player-page-kicker">RACECORE MANAGEMENT</p>
            <h1 class="player-page-title">Historiek: @Model.RaceName</h1>
            <p class="player-page-subtitle">
                Overzicht van alle verreden etappes en winnaars.
            </p>
        </div>

        <div class="player-header-actions">
            <a asp-controller="Result" asp-action="Index" class="player-btn player-btn-primary">
                Terug naar Ranking
            </a>
        </div>
    </div>

    @* Dropdown selectie via FORM *@
    <div class="player-toolbar-card history-toolbar">
        <form asp-controller="History" asp-action="History" method="get" class="history-form">
            <div class="game-form-group history-select-group">
                <label class="history-label">Selecteer een race</label>
                
                <select name="raceId" class="game-input">
                    <option value="">-- Kies een race --</option>
                    @foreach (var race in races)
                    {
                        @if (race.Id == selectedRaceId)
                        {
                            <option value="@race.Id" selected="selected">@race.Name @race.Year</option>
                        }
                        else
                        {
                            <option value="@race.Id">@race.Name @race.Year</option>
                        }
                    }
                </select>
            </div>
            
            <button type="submit" class="player-btn player-btn-primary history-submit-btn">
                Bekijk ritten
            </button>
        </form>
    </div>

    @* De Tabel *@
    <div class="history-card">
        @* ... Tabel inhoud blijft hetzelfde ... *@
        <table class="history-table">
            <thead>
                <tr>
                    <th>Rit</th>
                    <th>Etappe Details</th>
                    <th>Datum</th>
                    <th>Ritwinnaar</th>
                    <th>Beste Speler</th>
                    <th style="text-align: right;">Acties</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Stages != null && Model.Stages.Any())
                {
                    foreach (var stage in Model.Stages)
                    {
                        <tr>
                            <td><span class="stage-number-circle">#@stage.StageNumber</span></td>
                            <td>
                                <div class="stage-name">@stage.StageName</div>
                                <small class="stage-id-label">Stage ID: @stage.StageId</small>
                            </td>
                            <td><span class="stage-date">@stage.Date?.ToString("dd/MM")</span></td>
                            <td>
                                <div class="winner-info">
                                    <span class="winner-name">@stage.WinnerName</span>
                                    <span class="winner-team">@stage.WinnerTeam</span>
                                </div>
                            </td>
                            <td>
                                <div class="top-player-badge">
                                    <span>@stage.TopPlayerName</span>
                                    <span class="player-points">@stage.TopPlayerPoints pts</span>
                                </div>
                            </td>
                            <td style="text-align: right;">
                                <a asp-controller="Result" asp-action="StageResults" asp-route-raceId="@Model.RaceId" class="btn-details">Details</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="empty-state">
                            <p>Geen etappes gevonden voor deze wedstrijd.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>