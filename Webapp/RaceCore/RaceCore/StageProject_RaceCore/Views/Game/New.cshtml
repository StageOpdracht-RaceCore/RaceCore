@model StageProject_RaceCore.ViewModels.NewGameViewModel

@{
    ViewData["Title"] = "New Game";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";

    int selectedPlayersCount = Model.AvailablePlayers.Count(p => p.IsSelected);

    int activeGameId = ViewBag.ActiveGameId ?? 0;
    string activeGameRaceName = ViewBag.ActiveGameRaceName ?? "";
    string activeGameStageName = ViewBag.ActiveGameStageName ?? "";
    string activeGameStatus = ViewBag.ActiveGameStatus ?? "";

    string joinController = activeGameStatus == "Draft" ? "Draft" : "Dashboard";

    int totalDraftRounds = Model.RidersPerPlayer + Model.BenchPerPlayer;
    int totalDraftPicks = selectedPlayersCount * totalDraftRounds;
}

<link rel="stylesheet" href="~/css/NewGame.css" asp-append-version="true" />

<div class="new-game-page">

    @if (TempData["Error"] != null)
    {
        <div class="game-alert game-alert-danger">@TempData["Error"]</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="game-alert game-alert-success">@TempData["Success"]</div>
    }

    @if (TempData["DatabaseError"] != null)
    {
        <div class="game-alert game-alert-danger">@TempData["DatabaseError"]</div>
    }

    @if (activeGameId > 0)
    {
        <div class="game-modal-overlay show" id="activeGameModal">
            <div class="game-modal">
                <div class="game-modal-icon">🎮</div>

                <h2>Game in Progress</h2>

                <p>
                    There is already an active game running:
                    <br />
                    <strong>@activeGameRaceName</strong>
                    <br />
                    @activeGameStageName
                    <br />
                    Status: <strong>@activeGameStatus</strong>
                </p>

                <div class="game-modal-actions">
                    <button type="button" class="game-btn game-btn-light" id="closeActiveGameModal">
                        No, create new game
                    </button>

                    <a asp-controller="@joinController"
                       asp-action="Index"
                       asp-route-gameId="@activeGameId"
                       class="game-btn game-btn-start"
                       style="text-decoration:none;">
                        Yes, join game
                    </a>
                </div>
            </div>
        </div>
    }

    <form asp-action="New" method="post" id="newGameForm">
        @Html.AntiForgeryToken()

        <div class="game-hero">
            <div class="game-hero-left">
                <div class="game-flag">🏁</div>

                <div>
                    <p class="game-kicker">RaceCore Lobby</p>
                    <h1 class="game-title">New Game</h1>

                    <p class="game-subtitle">
                        Choose one complete race. The game automatically applies to all stages within that race.
                        Then choose the players and decide how many active riders and bench riders each player gets.
                    </p>
                </div>
            </div>

            <div class="game-start-box">
                <button type="button" class="game-btn game-btn-start" id="openStartGameModal">
                    ▶ Start Game
                </button>
            </div>
        </div>

        <div class="game-stats-grid">
            <div class="game-stat-card">
                <div class="game-stat-icon game-icon-blue">⚑</div>
                <div>
                    <span class="game-stat-label">Races</span>
                    <strong class="game-stat-value">@Model.AvailableRaces.Count</strong>
                </div>
            </div>

            <div class="game-stat-card">
                <div class="game-stat-icon game-icon-purple">👥</div>
                <div>
                    <span class="game-stat-label">Players</span>
                    <strong class="game-stat-value">@Model.AvailablePlayers.Count</strong>
                </div>
            </div>

            <div class="game-stat-card">
                <div class="game-stat-icon game-icon-green">✓</div>
                <div>
                    <span class="game-stat-label">Selected</span>
                    <strong id="selectedPlayersCount" class="game-stat-value">@selectedPlayersCount</strong>
                </div>
            </div>

            <div class="game-stat-card">
                <div class="game-stat-icon game-icon-orange">🚴</div>
                <div>
                    <span class="game-stat-label">Cyclists</span>
                    <strong class="game-stat-value">@Model.TotalCyclists</strong>
                </div>
            </div>

            <div class="game-stat-card">
                <div class="game-stat-icon game-icon-blue">⛰</div>
                <div>
                    <span class="game-stat-label">Stages in Race</span>
                    <strong class="game-stat-value">@Model.TotalStages</strong>
                </div>
            </div>
        </div>

        <div class="game-layout">

            <div class="game-panel">
                <div class="game-panel-header">
                    <div class="game-panel-icon">⚙</div>
                    <h2 class="game-panel-title">Game Setup</h2>
                </div>

                <div class="game-form-group">
                    <label asp-for="RaceId">Race</label>
                    <select asp-for="RaceId" asp-items="Model.AvailableRaces" class="game-input" id="raceSelect">
                        <option value="">-- Choose a race --</option>
                    </select>
                    <span asp-validation-for="RaceId" class="text-danger"></span>
                </div>

                <div class="game-warning-box">
                    ℹ Race Structure<br />
                    <span>This game will be linked to the complete race.</span>
                    <br />
                    <span>Scoring will happen later per stage within this race.</span>
                </div>

                <div class="game-form-group">
                    <label asp-for="RidersPerPlayer">Active riders per player</label>
                    <input asp-for="RidersPerPlayer"
                           type="number"
                           min="1"
                           max="30"
                           class="game-input"
                           id="ridersPerPlayerInput" />
                    <span asp-validation-for="RidersPerPlayer" class="text-danger"></span>
                </div>

                <div class="game-form-group">
                    <label asp-for="BenchPerPlayer">Bench riders per player</label>
                    <input asp-for="BenchPerPlayer"
                           type="number"
                           min="0"
                           max="30"
                           class="game-input"
                           id="benchPerPlayerInput" />
                    <span asp-validation-for="BenchPerPlayer" class="text-danger"></span>
                </div>

                <div class="game-warning-box">
                    ℹ Draft Settings<br />
                    <span>
                        Per player:
                        <strong id="summaryActive">@Model.RidersPerPlayer</strong> active +
                        <strong id="summaryBench">@Model.BenchPerPlayer</strong> bench =
                        <strong id="summaryTotal">@totalDraftRounds</strong> rounds.
                    </span>
                    <br />
                    <span>
                        Total needed:
                        <strong id="summaryNeeded">@totalDraftPicks</strong> cyclists.
                    </span>
                    <br />
                    <span>
                        Available in this race:
                        <strong>@Model.AvailableRaceCyclists</strong> cyclists.
                    </span>
                </div>

                @if (!Model.AvailableRaces.Any())
                {
                    <div class="game-alert game-alert-danger">
                        No races available yet. Create a race first.
                    </div>
                }

                @if (!Model.AvailablePlayers.Any())
                {
                    <div class="game-alert game-alert-danger">
                        No players available yet. Create players first.
                    </div>
                }

                <div class="game-manage-actions">
                    <a asp-controller="Race" asp-action="Index" class="game-btn game-btn-light">
                        ⚑ Manage Races
                    </a>

                    <a asp-controller="Player" asp-action="Index" class="game-btn game-btn-light">
                        👥 Manage Players
                    </a>

                    <a asp-controller="Cyclist" asp-action="Index" class="game-btn game-btn-light">
                        🚴 Manage Cyclists
                    </a>
                </div>

                <div class="game-info-list">
                    <div class="game-info-item">
                        <div class="game-info-icon">
                            <a asp-controller="Dashboard" asp-action="Index">🔄</a>
                        </div>
                        <div>
                            <strong>Snake Draft</strong>
                            <span>The draft order is automatically balanced fairly.</span>
                        </div>
                    </div>
                </div>

                <div class="game-warning-box">
                    ℹ Important<br />
                    Every Start Game creates a new separate game.
                </div>
            </div>

            <div class="game-panel">
                <div class="game-panel-header">
                    <div class="game-panel-icon">👥</div>
                    <h2 class="game-panel-title">Select Players</h2>
                </div>

                <p class="game-panel-text">
                    Choose at least 2 players.
                </p>

                <div class="players-grid">
                    @if (Model.AvailablePlayers.Any())
                    {
                        for (int i = 0; i < Model.AvailablePlayers.Count; i++)
                        {
                            var player = Model.AvailablePlayers[i];
                            int displayNumber = i + 1;

                            <label class="player-pick-card">
                                <input type="checkbox"
                                       name="SelectedPlayerIds"
                                       value="@player.Id"
                                       class="player-checkbox"
                                @(player.IsSelected ? "checked" : "") />

                                <div class="player-pick-avatar">
                                    @(string.IsNullOrWhiteSpace(player.Name) ? "?" : player.Name.Substring(0, 1).ToUpper())
                                </div>

                                <div>
                                    <div class="player-pick-name">@player.Name</div>
                                    <div class="player-pick-meta">Player ID: @player.Id</div>
                                </div>

                                <div class="player-pick-badge">
                                    #@displayNumber
                                </div>
                            </label>
                        }
                    }
                    else
                    {
                        <div class="game-empty-state">
                            <h3>No players found</h3>

                            <a asp-controller="Player" asp-action="Create" class="game-btn game-btn-start">
                                New Player
                            </a>
                        </div>
                    }
                </div>

                <span asp-validation-for="SelectedPlayerIds" class="text-danger"></span>

                <div class="game-draft-summary">
                    <div class="game-draft-summary-icon">🏆</div>
                    <div>
                        <strong>Fair Snake Draft</strong>
                        <span id="draftSummaryText">@totalDraftRounds rounds per player</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="game-modal-overlay" id="startGameModal">
            <div class="game-modal">
                <div class="game-modal-icon">🏁</div>

                <h2>Start New Game?</h2>

                <p>
                    Game <strong id="modalRaceName">the selected race</strong> will be started.
                    <br />
                    This game applies to <strong>all stages of this race</strong>.
                    <br />
                    Active: <strong id="modalActive">@Model.RidersPerPlayer</strong> riders per player
                    <br />
                    Bench: <strong id="modalBench">@Model.BenchPerPlayer</strong> riders per player
                    <br />
                    Total needed: <strong id="modalNeeded">@totalDraftPicks</strong> cyclists
                </p>

                <div class="game-modal-actions">
                    <button type="button" class="game-btn game-btn-light" id="cancelStartGame">
                        Cancel
                    </button>

                    <button type="submit"
                            form="newGameForm"
                            class="game-btn game-btn-start">
                        Yes, start game
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const storageKey = "RaceCore_NewGame_Settings";

            const selectedCount = document.getElementById("selectedPlayersCount");
            const checkboxes = document.querySelectorAll(".player-checkbox");

            const form = document.getElementById("newGameForm");

            const modal = document.getElementById("startGameModal");
            const openModalBtn = document.getElementById("openStartGameModal");
            const cancelModalBtn = document.getElementById("cancelStartGame");

            const activeGameModal = document.getElementById("activeGameModal");
            const closeActiveGameModal = document.getElementById("closeActiveGameModal");

            const raceSelect = document.getElementById("raceSelect");
            const modalRaceName = document.getElementById("modalRaceName");

            const ridersInput = document.getElementById("ridersPerPlayerInput");
            const benchInput = document.getElementById("benchPerPlayerInput");

            const summaryActive = document.getElementById("summaryActive");
            const summaryBench = document.getElementById("summaryBench");
            const summaryTotal = document.getElementById("summaryTotal");
            const summaryNeeded = document.getElementById("summaryNeeded");
            const draftSummaryText = document.getElementById("draftSummaryText");

            const modalActive = document.getElementById("modalActive");
            const modalBench = document.getElementById("modalBench");
            const modalNeeded = document.getElementById("modalNeeded");

            function getSelectedPlayersCount() {
                return document.querySelectorAll(".player-checkbox:checked").length;
            }

            function getNumberValue(input, fallback) {
                if (!input) {
                    return fallback;
                }

                const value = parseInt(input.value, 10);

                if (Number.isNaN(value)) {
                    return fallback;
                }

                return value;
            }

            function getSelectedPlayerIds() {
                return Array.from(document.querySelectorAll(".player-checkbox:checked"))
                    .map(cb => cb.value);
            }

            function saveSettings() {
                const settings = {
                    raceId: raceSelect ? raceSelect.value : "",
                    ridersPerPlayer: ridersInput ? ridersInput.value : "12",
                    benchPerPlayer: benchInput ? benchInput.value : "6",
                    selectedPlayerIds: getSelectedPlayerIds()
                };

                localStorage.setItem(storageKey, JSON.stringify(settings));
            }

            function loadSettings() {
                const saved = localStorage.getItem(storageKey);

                if (!saved) {
                    return;
                }

                let settings = null;

                try {
                    settings = JSON.parse(saved);
                } catch {
                    localStorage.removeItem(storageKey);
                    return;
                }

                if (raceSelect && settings.raceId) {
                    const raceExists = Array.from(raceSelect.options)
                        .some(option => option.value === settings.raceId);

                    if (raceExists) {
                        raceSelect.value = settings.raceId;
                    }
                }

                if (ridersInput && settings.ridersPerPlayer) {
                    ridersInput.value = settings.ridersPerPlayer;
                }

                if (benchInput && settings.benchPerPlayer) {
                    benchInput.value = settings.benchPerPlayer;
                }

                if (Array.isArray(settings.selectedPlayerIds)) {
                    checkboxes.forEach(cb => {
                        cb.checked = settings.selectedPlayerIds.includes(cb.value);
                    });
                }
            }

            function updateSelectedPlayersCount() {
                const count = getSelectedPlayersCount();

                if (selectedCount) {
                    selectedCount.textContent = count;
                }

                updateDraftSummary();
            }

            function updateDraftSummary() {
                const selectedPlayers = getSelectedPlayersCount();
                const active = Math.max(1, getNumberValue(ridersInput, 12));
                const bench = Math.max(0, getNumberValue(benchInput, 6));
                const totalRounds = active + bench;
                const needed = selectedPlayers * totalRounds;

                if (summaryActive) summaryActive.textContent = active;
                if (summaryBench) summaryBench.textContent = bench;
                if (summaryTotal) summaryTotal.textContent = totalRounds;
                if (summaryNeeded) summaryNeeded.textContent = needed;

                if (draftSummaryText) {
                    draftSummaryText.textContent = totalRounds + " rounds per player";
                }

                if (modalActive) modalActive.textContent = active;
                if (modalBench) modalBench.textContent = bench;
                if (modalNeeded) modalNeeded.textContent = needed;
            }

            function updateModalRaceName() {
                if (!raceSelect || !modalRaceName) return;

                const selectedOption = raceSelect.options[raceSelect.selectedIndex];

                modalRaceName.textContent =
                    selectedOption && selectedOption.value !== ""
                        ? selectedOption.text
                        : "the selected race";
            }

            loadSettings();

            checkboxes.forEach(cb => {
                cb.addEventListener("change", function () {
                    updateSelectedPlayersCount();
                    saveSettings();
                });
            });

            if (ridersInput) {
                ridersInput.addEventListener("input", function () {
                    updateDraftSummary();
                    saveSettings();
                });

                ridersInput.addEventListener("change", function () {
                    updateDraftSummary();
                    saveSettings();
                });
            }

            if (benchInput) {
                benchInput.addEventListener("input", function () {
                    updateDraftSummary();
                    saveSettings();
                });

                benchInput.addEventListener("change", function () {
                    updateDraftSummary();
                    saveSettings();
                });
            }

            if (raceSelect) {
                raceSelect.addEventListener("change", function () {
                    updateModalRaceName();
                    saveSettings();
                });
            }

            if (openModalBtn && modal) {
                openModalBtn.addEventListener("click", function () {
                    updateSelectedPlayersCount();
                    updateDraftSummary();
                    updateModalRaceName();
                    saveSettings();
                    modal.classList.add("show");
                });
            }

            if (cancelModalBtn && modal) {
                cancelModalBtn.addEventListener("click", function () {
                    modal.classList.remove("show");
                });
            }

            if (closeActiveGameModal && activeGameModal) {
                closeActiveGameModal.addEventListener("click", function () {
                    activeGameModal.classList.remove("show");
                });
            }

            if (form) {
                form.addEventListener("submit", function () {
                    saveSettings();
                });
            }

            updateSelectedPlayersCount();
            updateDraftSummary();
            updateModalRaceName();
            saveSettings();
        });
    </script>
}