@model List<StageProject_RaceCore.Models.Cyclist>

@{
    ViewData["Title"] = "Cyclists";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Cyclist.css" />

<div class="cyclists-page">
    <div class="cyclists-filter-card">
        <div class="cyclists-section-kicker">Filters</div>
        <h3 class="cyclists-filter-title">Zoek cyclists</h3>

        @* Zoekbalk *@
        <form method="get" class="cyclists-form">
            <div class="form-group">
                <label for="search">Zoeken</label>
                <input id="search"
                       type="text"
                       name="search"
                       class="cyclists-input"
                       value="@Context.Request.Query["search"]"
                       placeholder="Zoek op naam of team" />
            </div>

            @* Active filter *@
            <div class="form-group">
                <label for="active">Status</label>
                <select id="active" name="active" class="cyclists-select">
                    <option value="">Alle</option>
                    <option value="true" selected="@(Context.Request.Query["active"] == "true")">Actief</option>
                    <option value="false" selected="@(Context.Request.Query["active"] == "false")">Niet actief</option>
                </select>
            </div>

            @* Zoeken en Reset knop *@
            <div class="form-group button-group">
                <button type="submit" class="cyclists-btn">Zoeken</button>
            </div>
        </form>
        <div class="countAndReset">
            <div class="cyclists-count">
                Aantal cyclists: @ViewBag.CyclistCount
            </div>
            <a href="@Url.Action("Index", "Cyclist")" class="cyclists-btn reset-btn">Reset</a>
        </div>
        
    </div>

    <div class="cyclists-table-card">
        <div class="cyclists-table-header">
            <div class="cyclists-section-kicker">Overzicht</div>
            <h3 class="cyclists-card-title">Cyclists lijst</h3>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="cyclists-table-wrapper">
                <table class="cyclists-table">
                    <thead>
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Team</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cyclist in Model)
                        {
                            <tr>
                                <td class="cyclist-name">@cyclist.FirstName</td>
                                <td class="cyclist-name">@cyclist.LastName</td>
                                <td class="cyclist-team">@cyclist.Team?.Name</td>
                                <td>
                                    @if (cyclist.IsActive)
                                    {
                                        <span class="status-badge status-active">Actief</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-inactive">Niet actief</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @{
                    int currentPage = ViewBag.CurrentPage ?? 1;
                    int totalPages = ViewBag.TotalPages ?? 1;

                    int startPage = Math.Max(1, currentPage - 2);
                    int endPage = Math.Min(totalPages, startPage + 4);

                    if (endPage - startPage < 4)
                    {
                        startPage = Math.Max(1, endPage - 4);
                    }

                    var currentSearch = Context.Request.Query["search"].ToString();
                    var currentActive = Context.Request.Query["active"].ToString();
                }

                <div class="pagination-container">

                    @* Eerste pagina *@
                    @if (currentPage > 1)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-active="@currentActive"
                               asp-route-page="1"
                               asp-route-pageSize="@ViewBag.PageSize"
                               class="pagination-btn">
                            ⏮ Eerste
                        </a>
                    }

                    @* Vorige *@
                    @if (currentPage > 1)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-active="@currentActive"
                               asp-route-page="@(currentPage - 1)"
                               asp-route-pageSize="@ViewBag.PageSize"
                               class="pagination-btn">
                            ← Vorige
                        </a>
                    }

                    @* Paginanummers (max 5) *@
                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-active="@currentActive"
                               asp-route-page="@i"
                               asp-route-pageSize="@ViewBag.PageSize"
                               class="pagination-btn @(i == currentPage ? "active" : "")">
                            @i
                        </a>
                    }

                    @* Volgende *@
                    @if (currentPage < totalPages)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-active="@currentActive"
                               asp-route-page="@(currentPage + 1)"
                               asp-route-pageSize="@ViewBag.PageSize"
                               class="pagination-btn">
                            Volgende →
                        </a>
                    }

                    @* Laatste pagina *@
                    @if (currentPage < totalPages)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-active="@currentActive"
                               asp-route-page="@totalPages"
                               asp-route-pageSize="@ViewBag.PageSize"
                               class="pagination-btn">
                            Laatste ⏭
                        </a>
                    }

                </div>
            </div>
        }
        else
        {
            <div class="empty-box">
                Geen cyclists gevonden.
            </div>
        }
    </div>

</div>