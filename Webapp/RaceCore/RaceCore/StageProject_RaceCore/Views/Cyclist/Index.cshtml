@model List<StageProject_RaceCore.Models.Cyclist>
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Cyclists";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";

    string currentSearch = ViewBag.Search as string ?? "";
    string currentStatus = ViewBag.Status as string ?? "";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 25;
    int cyclistCount = ViewBag.CyclistCount ?? 0;

    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, startPage + 4);

    var races = allRaces.ToList();

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, startPage + 4);

    if (endPage - startPage < 4)
    {
        startPage = Math.Max(1, endPage - 4);
    }
}

<link rel="stylesheet" href="~/css/Main.css" asp-append-version="true" />
<link rel="stylesheet" href="~/css/Cyclist.css" asp-append-version="true" />

<section class="cyclist-page">

    <!-- HEADER -->
    <section class="cyclist-header-card">
        <div class="cyclist-header-copy">
            <p class="cyclist-page-kicker">RaceCore</p>
            <h1 class="cyclist-page-title">Cyclists</h1>
            <p class="cyclist-page-subtitle">
                Bekijk alle renners, hun team, status en deelname aan grote rondes.
            </p>
        </div>

        <div class="cyclist-header-actions">

            <!-- ✅ FIX: correcte MVC navigatie -->
            <a asp-action="Create" asp-controller="Cyclist" class="cyclist-add-btn">
                + Renner toevoegen
            </a>

            <a asp-controller="Dashboard" asp-action="Index" class="cyclist-dashboard-white-btn">
                Dashboard
            </a>

        </div>
    </section>

    <!-- TOASTS -->
    @if (TempData["Success"] != null)
    {
        <div class="cyclist-toast cyclist-toast-success">
            ✓ @TempData["Success"]
        </div>
    }

    @if (TempData["CreateError"] != null)
    {
        <div class="cyclist-toast cyclist-toast-error">
            ✕ @TempData["CreateError"]
        </div>
    }

    @if (TempData["DatabaseError"] != null)
    {
        <div class="cyclist-toast cyclist-toast-error">
            ✕ @TempData["DatabaseError"]
        </div>
    }

    <!-- FILTERS -->
    <section class="cyclist-filter-card">
        <div class="cyclist-card-title">
            <p class="cyclist-card-kicker">Filters</p>
            <h2>Zoek cyclists</h2>
        </div>

        <form method="get" asp-action="Index" asp-controller="Cyclist" class="cyclist-filter-form">

            <div class="cyclist-form-group">
                <label>Zoeken</label>
                <input type="text" name="search" class="cyclist-input" value="@currentSearch" />
            </div>

            <div class="cyclist-form-group">
                <label>Status</label>
                <select name="status" class="cyclist-input">
                    <option value="" selected="@(string.IsNullOrEmpty(currentStatus))">Alle</option>
                    <option value="active" selected="@(currentStatus == "active")">Actief</option>
                    <option value="inactive" selected="@(currentStatus == "inactive")">Niet actief</option>
                </select>
            </div>

            <div class="cyclist-button-group">
                <button type="submit" class="cyclist-primary-btn">Zoeken</button>

                <a asp-action="Index" class="cyclist-reset-btn">
                    Reset
                </a>
            </div>

        </form>

        <div class="cyclist-count">
            Aantal gekozen cyclists: <strong>@cyclistCount</strong>
        </div>

    </section>

    <!-- TABLE -->
    <section class="cyclist-table-card">

        @if (Model != null && Model.Any())
        {
            <div class="cyclist-table-wrapper">
                <table class="cyclist-table">
                    <thead>
                        <tr>
                            <th>Voornaam</th>
                            <th>Achternaam</th>
                            <th>Team</th>
                            <th>Status</th>

                            @foreach (var race in races)
                            {
                                <th>@race.Name</th>
                            }
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var cyclist in Model)
                        {
                            var cyclistRaceIds = cyclist.RaceEntries?.Select(re => re.RaceId).ToList() ?? new List<int>();
                            var availableRaces = allRaces
                                .Where(r => !cyclistRaceIds.Contains(r.Id))
                                .ToList();

                            <tr>
                                <td>@cyclist.FirstName</td>
                                <td>@cyclist.LastName</td>

                                <td>
                                    @(cyclist.Team != null ? cyclist.Team.Name : "Geen team")
                                </td>

                                <td>
                                    @if (cyclist.IsActive)
                                    {
                                        <span class="cyclist-status status-active">Actief</span>
                                    }
                                    else
                                    {
                                        <span class="cyclist-status status-inactive">Niet actief</span>
                                    }
                                </td>

                                <td style="display:flex; gap:8px; align-items:center;">

                                    <td>
                                        @if (doetMee)
                                        {
                                            <span class="race-badge race-yes">Ja</span>
                                        }
                                        else
                                        {
                                            <span class="race-badge race-no">Nee</span>
                                        }
                                    </td>
                                }
                                <td>
                                    <button type="button"
                                            class="cyclist-delete-btn"
                                            onclick="openDeleteModal(@cyclist.Id, '@cyclist.FullName')">
                                        Verwijderen
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- PAGINATION -->
            <div class="cyclist-pagination">

                @if (currentPage > 1)
                {
                    <a asp-action="Index"
                       asp-route-page="1"
                       asp-route-search="@currentSearch"
                       asp-route-status="@currentStatus"
                       class="cyclist-page-btn">&lt;&lt;</a>

                    <a asp-action="Index"
                       asp-route-page="@(currentPage - 1)"
                       asp-route-search="@currentSearch"
                       asp-route-status="@currentStatus"
                       class="cyclist-page-btn">&lt;</a>
                }

                @for (int i = startPage; i <= endPage; i++)
                {
                    <a asp-action="Index"
                           asp-route-page="@i"
                           asp-route-search="@currentSearch"
                           asp-route-status="@currentStatus"
                           class="cyclist-page-btn @(i == currentPage ? "active" : "")">
                        @i
                    </a>
                }

                @if (currentPage < totalPages)
                {
                    <a asp-action="Index"
                       asp-route-page="@(currentPage + 1)"
                       asp-route-search="@currentSearch"
                       asp-route-status="@currentStatus"
                       class="cyclist-page-btn">&gt;</a>

                    <a asp-action="Index"
                       asp-route-page="@totalPages"
                       asp-route-search="@currentSearch"
                       asp-route-status="@currentStatus"
                       class="cyclist-page-btn">&gt;&gt;</a>
                }

            </div>
        }
        else
        {
            <div class="cyclist-empty">
                Geen gekozen cyclists gevonden.
            </div>
        }

    </section>

</section>

@* ── Add Cyclist Modal ──────────────────────────────────── *@
<div id="addCyclistModal" class="cyclist-modal-backdrop" onclick="closeAddModal(event)">
    <div class="cyclist-modal">
        <div class="cyclist-modal-header">
            <div>
                <p class="cyclist-card-kicker">Nieuw</p>
                <h2>Renner toevoegen</h2>
            </div>
            <button type="button" class="cyclist-modal-close" onclick="closeAddModal()">&times;</button>
        </div>

        @if (TempData["CreateError"] != null)
        {
            <div class="cyclist-toast cyclist-toast-error">
                ✕ @TempData["CreateError"]
            </div>
        }

        <form method="post" asp-action="Create" asp-controller="Cyclist" class="cyclist-modal-form">
            @Html.AntiForgeryToken()

            <div class="cyclist-form-group">
                <label for="addFirstName">Voornaam <span class="cyclist-required">*</span></label>
                <input id="addFirstName"
                       type="text"
                       name="firstName"
                       class="cyclist-input"
                       placeholder="bv. Tadej"
                       required />
            </div>

            <div class="cyclist-form-group">
                <label for="addLastName">Achternaam <span class="cyclist-required">*</span></label>
                <input id="addLastName"
                       type="text"
                       name="lastName"
                       class="cyclist-input"
                       placeholder="bv. Pogačar"
                       required />
            </div>

            <div class="cyclist-form-group">
                <label for="addTeamId">Team</label>
                <select id="addTeamId" name="teamId" class="cyclist-input">
                    <option value="0">— Geen team —</option>
                    @foreach (var team in allTeams)
                    {
                        <option value="@team.Id">@team.Name</option>
                    }
                </select>
            </div>

            <div class="cyclist-button-group cyclist-modal-actions">
                <button type="submit" class="cyclist-primary-btn">Opslaan</button>
                <button type="button" class="cyclist-reset-btn" onclick="closeAddModal()">Annuleren</button>
            </div>
        </form>
    </div>
</div>

@* ── Delete Cyclist Modal ───────────────────────────────── *@
<div id="deleteCyclistModal" class="cyclist-modal-backdrop" onclick="closeDeleteModal(event)">
    <div class="cyclist-modal cyclist-modal-sm">
        <div class="cyclist-modal-header">
            <div>
                <p class="cyclist-card-kicker">Verwijderen</p>
                <h2>Renner verwijderen</h2>
            </div>
            <button type="button" class="cyclist-modal-close" onclick="closeDeleteModal()">&times;</button>
        </div>

        <p class="cyclist-delete-confirm-text">
            Weet je zeker dat je <strong id="deleteCyclistName"></strong> wil verwijderen? Dit kan niet ongedaan worden gemaakt.
        </p>

        <form method="post" asp-action="Delete" asp-controller="Cyclist" id="deleteForm" class="cyclist-modal-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="deleteCyclistId" />
            <div class="cyclist-button-group cyclist-modal-actions">
                <button type="submit" class="cyclist-danger-btn">Verwijderen</button>
                <button type="button" class="cyclist-reset-btn" onclick="closeDeleteModal()">Annuleren</button>
            </div>
        </form>
    </div>
</div>


<script>
    function openAddModal() {
        document.getElementById('addCyclistModal').classList.add('active');
        document.getElementById('addFirstName').focus();
    }

    function closeAddModal(e) {
        if (!e || e.target === document.getElementById('addCyclistModal')) {
            document.getElementById('addCyclistModal').classList.remove('active');
        }
    }

    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') { closeAddModal(); closeDeleteModal(); }
    });

    function openDeleteModal(id, name) {
        document.getElementById('deleteCyclistId').value = id;
        document.getElementById('deleteCyclistName').textContent = name;
        document.getElementById('deleteCyclistModal').classList.add('active');
    }

    function closeDeleteModal(e) {
        if (!e || e.target === document.getElementById('deleteCyclistModal')) {
            document.getElementById('deleteCyclistModal').classList.remove('active');
        }
    }



    @if (openModal)
    {
            <text>document.addEventListener('DOMContentLoaded', openAddModal);</text>
    }
</script>
