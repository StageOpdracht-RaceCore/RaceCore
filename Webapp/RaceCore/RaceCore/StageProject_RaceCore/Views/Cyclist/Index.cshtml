@model List<StageProject_RaceCore.Models.Cyclist>
@using StageProject_RaceCore.Models

@{
    ViewData["Title"] = "Cyclists";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    string currentSearch = ViewBag.Search as string ?? "";
    string currentStatus = ViewBag.Status as string ?? "";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int pageSize = ViewBag.PageSize ?? 25;
    int cyclistCount = ViewBag.CyclistCount ?? 0;
    var races = ViewBag.Races as List<Race> ?? new List<Race>();

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, startPage + 4);

    if (endPage - startPage < 4)
    {
        startPage = Math.Max(1, endPage - 4);
    }
}
<link rel="stylesheet" href="~/css/Main.css"/> 
<link rel="stylesheet" href="~/css/Cyclist.css" />

<section class="page">
    <section class="header">
        <h6>RaceCore</h6>
        <h1>Cyclists</h1>
        <p>Bekijk hier alle renners en aan welke wedstrijd ze meedoen. </p>
    </section>

    <section class="filters">
        <h4>Filters</h4>
        <h3>Zoek cyclists</h3>

        <form method="get" asp-action="Index" asp-controller="Cyclist" class="cyclistsForm">
            <div class="formStyle">
                <label for="search">Zoeken</label>
                <input id="search" type="text" name="search" class="select" value="@currentSearch" placeholder="Zoek op naam of team" />
            </div>

            <div class="formStyle">
                <label for="status">Status</label>
                <select id="status" name="status" class="select">
                    <option value="" selected="@(string.IsNullOrEmpty(currentStatus))">Alle</option>
                    <option value="active" selected="@(currentStatus == "active")">Actief</option>
                    <option value="inactive" selected="@(currentStatus == "inactive")">Niet actief</option>

                    @foreach (var race in races)
                    {
                        var raceValue = $"race-{race.Id}";
                        <option value="@raceValue" selected="@(currentStatus == raceValue)">
                            @race.Name
                        </option>
                    }
                </select>
            </div>

                <button type="submit" class="formButton btn btn-primary">Zoeken</button>
        </form>

        <div class="countAndReset">
            <p>Aantal cyclists: <strong>@cyclistCount</strong></p>

            <a asp-action="Index" asp-controller="Cyclist" class="formButton btn btn-danger">
                Reset
            </a>
        </div>
    </section>

    <section class="cyclistsOverview">
        <h4>Overzicht</h4>
        <h3>Cyclists lijst</h3>

        @if (Model != null && Model.Any())
        {
            <section class="cyclistsTableWrapper">
                <table class="cyclistsTable">
                    <thead>
                        <tr>
                            <th>First Name</th>
                            <th>Last Name</th>
                            <th>Team</th>
                            <th>Status</th>
                            @foreach (var race in races)
                            {
                                <th>@race.Name</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cyclist in Model)
                        {
                            <tr>
                                <td class="cyclistName">@cyclist.FirstName</td>
                                <td class="cyclistName">@cyclist.LastName</td>
                                <td class="cyclistTeam">@(cyclist.Team?.Name ?? "Geen team")</td>

                                <td>
                                    @if (cyclist.IsActive)
                                    {
                                        <span class="status statusActive">Actief</span>
                                    }
                                    else
                                    {
                                        <span class="status statusInactive">Niet actief</span>
                                    }
                                </td>

                                @foreach (var race in races)
                                {
                                    bool doetMee = cyclist.RaceEntries.Any(re => re.RaceId == race.Id);

                                    <td>
                                        @if (doetMee)
                                        {
                                            <span class=" race raceYes">Ja</span>
                                        }
                                        else
                                        {
                                            <span class="race raceNo">Nee</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>

                <div class="pagenumbers">
                    @if (currentPage > 1)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-status="@currentStatus"
                               asp-route-page="1"
                               asp-route-pageSize="@pageSize"
                               class="pageBtn">
                            &lt;&lt; Eerste
                        </a>

                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-status="@currentStatus"
                               asp-route-page="@(currentPage - 1)"
                               asp-route-pageSize="@pageSize"
                               class="pageBtn">
                            &lt; Vorige
                        </a>
                    }

                    @for (int i = startPage; i <= endPage; i++)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-status="@currentStatus"
                               asp-route-page="@i"
                               asp-route-pageSize="@pageSize"
                               class="pageBtn @(i == currentPage ? "active" : "")">
                            @i
                        </a>
                    }

                    @if (currentPage < totalPages)
                    {
                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-status="@currentStatus"
                               asp-route-page="@(currentPage + 1)"
                               asp-route-pageSize="@pageSize"
                               class="pageBtn">
                            Volgende &gt;
                        </a>

                        <a asp-action="Index"
                               asp-route-search="@currentSearch"
                               asp-route-status="@currentStatus"
                               asp-route-page="@totalPages"
                               asp-route-pageSize="@pageSize"
                               class="pageBtn">
                            Laatste &gt;&gt;
                        </a>
                    }
                </div>
            </section>
        }
        else
        {
            <div class="empty">
                Geen cyclists gevonden.
            </div>
        }
    </section>

</section>

