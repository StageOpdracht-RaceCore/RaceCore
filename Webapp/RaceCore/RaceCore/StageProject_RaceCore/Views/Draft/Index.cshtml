@model List<StageProject_RaceCore.ViewModels.DraftTurnViewModel>

@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    ViewData["Title"] = "Draft";

    var cyclists = ViewBag.Cyclists as List<StageProject_RaceCore.Models.Cyclist>
                   ?? new List<StageProject_RaceCore.Models.Cyclist>();

    int raceId = ViewBag.RaceId ?? 0;

    var pickedIds = Model
        .Where(t => t.CyclistId != null)
        .Select(t => t.CyclistId!.Value)
        .ToList();

    var availableCyclists = cyclists
        .Where(c => !pickedIds.Contains(c.Id))
        .OrderBy(c => c.FullName)
        .ToList();

    var currentTurn = Model
        .Where(t => t.CyclistId == null)
        .OrderBy(t => t.TurnNumber)
        .FirstOrDefault();

    var playerRows = Model
        .GroupBy(t => t.PlayerName)
        .Select(g => new
        {
            PlayerName = g.Key,
            TotalTurns = g.Count(),
            PickedCount = g.Count(x => x.CyclistId != null),
            NextTurn = g.Where(x => x.CyclistId == null).OrderBy(x => x.TurnNumber).FirstOrDefault(),
            LastPicked = g.Where(x => x.CyclistId != null).OrderByDescending(x => x.TurnNumber).FirstOrDefault()
        })
        .OrderBy(x => x.NextTurn == null ? 999999 : x.NextTurn.TurnNumber)
        .ThenBy(x => x.PlayerName)
        .ToList();

    var totalPlayers = playerRows.Count;
    var totalTurns = Model.Count;
    var pickedCount = Model.Count(t => t.CyclistId != null);
    var remainingTurns = Model.Count(t => t.CyclistId == null);
    var draftIsLive = totalTurns > 0 && remainingTurns > 0;
    var draftIsDone = totalTurns > 0 && remainingTurns == 0;
    var draftIsEmpty = totalTurns == 0;
}

<link rel="stylesheet" href="~/css/Draft.css" asp-append-version="true" />

<div class="draft-page">
    <div class="draft-page-header">
        <div class="draft-page-header-left">
            <span class="draft-page-kicker">RaceCore Draft Center</span>
            <h1>Live Draft</h1>
            <p>
                Hier zie je enkel de spelers die meedoen. Elke speler komt om de beurt aan bod
                en bouwt stap voor stap zijn team van wielrenners.
            </p>
        </div>

        <div class="draft-page-header-right">
            <div class="draft-status-pill @(draftIsLive ? "live" : "done")">
                <span class="draft-status-dot"></span>
                @(draftIsLive ? "Draft Live" : draftIsDone ? "Draft Afgerond" : "Nog Geen Draft")
            </div>
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="draft-alert draft-alert-error">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="draft-alert" style="background:#ecfdf5;color:#166534;border-color:#bbf7d0;">
            @TempData["Success"]
        </div>
    }

    @if (TempData["DatabaseError"] != null)
    {
        <div class="draft-alert draft-alert-error">
            @TempData["DatabaseError"]
        </div>
    }

    <form asp-action="GenerateDraft" method="post" style="margin-bottom:18px;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="raceId" value="@raceId" />

        <button type="submit"
                class="draft-pick-button"
                onclick="return confirm('Ben je zeker? Dit verwijdert de huidige draft en maakt een nieuwe fair snake draft.');">
            Generate Fair Snake Draft
        </button>
    </form>

    <div class="draft-stats-grid">
        <div class="draft-stat-card">
            <div class="draft-stat-icon">🎯</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Status</span>
                <strong class="draft-stat-value">
                    @(draftIsLive ? "LIVE" : draftIsDone ? "DONE" : "EMPTY")
                </strong>
            </div>
        </div>

        <div class="draft-stat-card">
            <div class="draft-stat-icon">👥</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Spelers</span>
                <strong class="draft-stat-value">@totalPlayers</strong>
            </div>
        </div>

        <div class="draft-stat-card">
            <div class="draft-stat-icon">🚴</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Gekozen renners</span>
                <strong class="draft-stat-value">@pickedCount</strong>
            </div>
        </div>

        <div class="draft-stat-card">
            <div class="draft-stat-icon">📋</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Resterende beurten</span>
                <strong class="draft-stat-value">@remainingTurns</strong>
            </div>
        </div>
    </div>

    <div class="draft-layout">
        <section class="draft-main-card">
            <div class="draft-card-header">
                <div class="draft-card-header-text">
                    <h2>Spelers in deze draft</h2>
                    <p>Je ziet hier alleen de spelers, niet alle 105 draftbeurten.</p>
                </div>

                <div class="draft-card-header-badge">
                    @totalPlayers spelers
                </div>
            </div>

            <div class="draft-table-wrap">
                <div class="draft-table">
                    <div class="draft-table-head">
                        <div>Speler</div>
                        <div>Picks</div>
                        <div>Actie</div>
                    </div>

                    <div class="draft-table-body">
                        @if (!playerRows.Any())
                        {
                            <div class="draft-empty-state" style="padding:24px;">
                                Nog geen draft aangemaakt. Klik op <strong>Generate Fair Snake Draft</strong>.
                            </div>
                        }
                        else
                        {
                            @foreach (var player in playerRows)
                            {
                                var isActive = currentTurn != null && player.NextTurn != null && player.NextTurn.Id == currentTurn.Id;
                                var initial = !string.IsNullOrWhiteSpace(player.PlayerName)
                                    ? player.PlayerName.Substring(0, 1).ToUpper()
                                    : "?";

                                <div class="draft-row @(isActive ? "active" : "")">
                                    <div class="draft-cell draft-player-cell" data-label="Speler">
                                        <div class="draft-player-avatar">
                                            @initial
                                        </div>

                                        <div class="draft-player-meta">
                                            <div class="draft-player-name-row">
                                                <span class="draft-player-name">@player.PlayerName</span>

                                                @if (isActive)
                                                {
                                                    <span class="draft-inline-badge active">Aan de beurt</span>
                                                }
                                                else if (player.PickedCount >= player.TotalTurns)
                                                {
                                                    <span class="draft-inline-badge picked">Klaar</span>
                                                }
                                                else
                                                {
                                                    <span class="draft-inline-badge waiting">Wacht</span>
                                                }
                                            </div>

                                            <span class="draft-player-subtitle">
                                                @if (player.LastPicked != null)
                                                {
                                                    <text>Laatst gekozen: @player.LastPicked.CyclistName</text>
                                                }
                                                else
                                                {
                                                    <text>Nog geen renner gekozen</text>
                                                }
                                            </span>
                                        </div>
                                    </div>

                                    <div class="draft-cell draft-position-cell" data-label="Picks">
                                        <span class="draft-position-badge">
                                            @player.PickedCount / @player.TotalTurns
                                        </span>
                                    </div>

                                    <div class="draft-cell draft-selection-cell" data-label="Actie">
                                        @if (isActive && currentTurn != null)
                                        {
                                            <form asp-action="PickCyclist" method="post" class="draft-pick-form js-draft-pick-form">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="draftTurnId" value="@currentTurn.Id" />
                                                <input type="hidden" name="raceId" value="@raceId" />
                                                <input type="hidden" name="cyclistId" class="js-cyclist-id" required />

                                                <div class="draft-search-select js-search-select">
                                                    <div class="draft-search-select-input-wrap">
                                                        <input type="text"
                                                               class="draft-search-input js-search-input"
                                                               placeholder="Typ om een renner te zoeken..."
                                                               autocomplete="off" />
                                                        <button type="button" class="draft-search-toggle js-search-toggle" tabindex="-1">
                                                            ▾
                                                        </button>
                                                    </div>

                                                    <div class="draft-search-dropdown js-search-dropdown">
                                                        <div class="draft-search-empty js-search-empty">
                                                            Geen renners gevonden.
                                                        </div>

                                                        @foreach (var cyclist in availableCyclists)
                                                        {
                                                            <button type="button"
                                                                    class="draft-search-option js-search-option"
                                                                    data-id="@cyclist.Id"
                                                                    data-name="@cyclist.FullName">
                                                                <span class="draft-search-option-name">@cyclist.FullName</span>
                                                            </button>
                                                        }
                                                    </div>
                                                </div>

                                                <button type="submit" class="draft-pick-button">
                                                    Pick
                                                </button>
                                            </form>
                                        }
                                        else if (player.PickedCount >= player.TotalTurns)
                                        {
                                            <div class="draft-picked-name">
                                                <span class="draft-picked-icon">✔</span>
                                                <span>Team compleet</span>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="draft-empty-state">
                                                Waiting...
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </section>

        <aside class="draft-sidebar">
            <div class="draft-side-card draft-side-highlight">
                <div class="draft-side-card-header">
                    <h3>Live Draft Info</h3>
                    <span class="draft-mini-status @(draftIsLive ? "live" : "done")">
                        @(draftIsLive ? "Live" : draftIsDone ? "Done" : "Empty")
                    </span>
                </div>

                <div class="draft-current-turn-box">
                    <span class="draft-current-turn-label">Nu aan de beurt</span>
                    <strong class="draft-current-turn-name">
                        @(currentTurn?.PlayerName ?? (draftIsDone ? "Einde Draft" : "Nog geen draft"))
                    </strong>
                </div>

                <div class="draft-info-list">
                    <div class="draft-info-item">
                        <span>Spelers zichtbaar</span>
                        <strong>@totalPlayers</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Beschikbare renners</span>
                        <strong>@availableCyclists.Count</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Gekozen renners</span>
                        <strong>@pickedCount</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Totale draft beurten</span>
                        <strong>@totalTurns</strong>
                    </div>
                </div>
            </div>

            <div class="draft-side-card">
                <div class="draft-side-card-header">
                    <h3>Draft Progress</h3>
                </div>

                <div class="draft-progress-wrap">
                    <div class="draft-progress-bar">
                        <div class="draft-progress-fill" style="width:@(totalTurns == 0 ? 0 : (pickedCount * 100 / totalTurns))%;"></div>
                    </div>

                    <div class="draft-progress-text">
                        @pickedCount / @totalTurns picks completed
                    </div>
                </div>
            </div>

            <div class="draft-side-card draft-tip-card">
                <div class="draft-tip-title">💡 Snake Draft</div>
                <p>
                    Je ziet alleen de spelers. Intern staan er meerdere beurten klaar, maar die worden niet allemaal als aparte rijen getoond.
                </p>
            </div>
        </aside>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchSelects = document.querySelectorAll(".js-search-select");

        searchSelects.forEach(function (select) {
            const input = select.querySelector(".js-search-input");
            const hiddenId = select.closest("form").querySelector(".js-cyclist-id");
            const options = Array.from(select.querySelectorAll(".js-search-option"));
            const emptyState = select.querySelector(".js-search-empty");
            const toggle = select.querySelector(".js-search-toggle");
            const form = select.closest("form");

            function normalize(value) {
                return (value || "")
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "")
                    .trim();
            }

            function filterOptions() {
                const term = normalize(input.value);
                let visibleCount = 0;

                options.forEach(function (option) {
                    const name = normalize(option.dataset.name);
                    const matches = term === "" || name.includes(term);

                    option.style.display = matches ? "flex" : "none";

                    if (matches) {
                        visibleCount++;
                    }
                });

                emptyState.style.display = visibleCount === 0 ? "flex" : "none";
            }

            function openDropdown() {
                select.classList.add("open");
                filterOptions();
            }

            function closeDropdown() {
                select.classList.remove("open");
            }

            function clearSelectionIfTypedDifferent() {
                const currentSelectedName = options.find(o => o.dataset.id === hiddenId.value)?.dataset.name || "";

                if (normalize(input.value) !== normalize(currentSelectedName)) {
                    hiddenId.value = "";
                }
            }

            input.addEventListener("focus", function () {
                openDropdown();
            });

            input.addEventListener("input", function () {
                clearSelectionIfTypedDifferent();
                openDropdown();
                filterOptions();
            });

            toggle.addEventListener("click", function () {
                if (select.classList.contains("open")) {
                    closeDropdown();
                } else {
                    openDropdown();
                    input.focus();
                }
            });

            options.forEach(function (option) {
                option.addEventListener("click", function () {
                    input.value = option.dataset.name;
                    hiddenId.value = option.dataset.id;
                    closeDropdown();
                });
            });

            form.addEventListener("submit", function (e) {
                if (!hiddenId.value) {
                    e.preventDefault();
                    input.focus();
                    input.classList.add("draft-search-input-error");

                    setTimeout(function () {
                        input.classList.remove("draft-search-input-error");
                    }, 1600);
                }
            });

            document.addEventListener("click", function (e) {
                if (!select.contains(e.target)) {
                    closeDropdown();
                }
            });
        });
    });
</script>