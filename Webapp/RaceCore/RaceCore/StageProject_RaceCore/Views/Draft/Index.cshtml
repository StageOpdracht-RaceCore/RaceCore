@model List<StageProject_RaceCore.ViewModels.DraftTurnViewModel>

@{
    /* =========================================================
       PAGINA INSTELLINGEN
       ========================================================= */

    Layout = "~/Views/Shared/_CleanLayout.cshtml";
    ViewData["Title"] = "Draft";

    /* =========================================================
       DATA UIT VIEWBAG OPHALEN
       ========================================================= */

    // Lijst met wielrenners ophalen uit ViewBag
    var cyclists = ViewBag.Cyclists as List<StageProject_RaceCore.Models.Cyclist>
                   ?? new List<StageProject_RaceCore.Models.Cyclist>();

    // Game id ophalen
    int gameId = ViewBag.GameId ?? 0;

    // Draft instellingen ophalen
    int ridersPerPlayer = ViewBag.RidersPerPlayer ?? 12;
    int benchPerPlayer = ViewBag.BenchPerPlayer ?? 6;

    // Totaal aantal picks per speler
    int totalPicksPerPlayer = ridersPerPlayer + benchPerPlayer;

    // Race naam ophalen
    string raceName = ViewBag.RaceName ?? "Unknown race";

    /* =========================================================
       HUIDIGE DRAFT BEURT BEPALEN
       ========================================================= */

    // Eerste beurt zoeken waar nog geen wielrenner gekozen is
    var currentTurn = Model
        .Where(t => t.CyclistId == null)
        .OrderBy(t => t.TurnNumber)
        .FirstOrDefault();

    int currentPlayerPickedCount = 0;
    int currentPickNumberForPlayer = 0;
    bool currentPickIsBench = false;

    // Als er nog een huidige beurt bestaat
    if (currentTurn != null)
    {
        // Aantal picks tellen die deze speler al heeft gedaan
        currentPlayerPickedCount = Model.Count(t =>
            t.PlayerId == currentTurn.PlayerId &&
            t.CyclistId != null);

        // Volgende pick nummer bepalen
        currentPickNumberForPlayer = currentPlayerPickedCount + 1;

        // Controleren of deze pick een bench pick is
        currentPickIsBench = currentPlayerPickedCount >= ridersPerPlayer;
    }

    /* =========================================================
       SPELER RIJEN OPBOUWEN
       ========================================================= */

    var playerRows = Model
        .GroupBy(t => new { t.PlayerId, t.PlayerName })
        .Select(g => new
        {
            PlayerId = g.Key.PlayerId,
            PlayerName = g.Key.PlayerName,

            // Totaal aantal beurten van speler
            TotalTurns = g.Count(),

            // Aantal picks dat al gekozen is
            PickedCount = g.Count(x => x.CyclistId != null),

            // Aantal actieve renners gekozen
            ActivePicked = Math.Min(g.Count(x => x.CyclistId != null), ridersPerPlayer),

            // Aantal bench renners gekozen
            BenchPicked = Math.Max(0, g.Count(x => x.CyclistId != null) - ridersPerPlayer),

            // Volgende beurt van deze speler
            NextTurn = g.Where(x => x.CyclistId == null).OrderBy(x => x.TurnNumber).FirstOrDefault()
        })
        .OrderBy(x => x.NextTurn == null ? 999999 : x.NextTurn.TurnNumber)
        .ThenBy(x => x.PlayerName)
        .ToList();

    /* =========================================================
       ALGEMENE DRAFT STATISTIEKEN
       ========================================================= */

    var totalPlayers = playerRows.Count;
    var totalTurns = Model.Count;
    var pickedCount = Model.Count(t => t.CyclistId != null);
    var remainingTurns = Model.Count(t => t.CyclistId == null);

    // Draft is live als er nog beurten over zijn
    var draftIsLive = totalTurns > 0 && remainingTurns > 0;

    // Draft is klaar als er geen beurten meer over zijn
    var draftIsDone = totalTurns > 0 && remainingTurns == 0;
}

<!-- CSS bestand van draft pagina -->
<link rel="stylesheet" href="~/css/Draft.css" asp-append-version="true" />

<div class="draft-page">

    <!-- =========================================================
         HEADER VAN DE DRAFT PAGINA
         ========================================================= -->

    <div class="draft-page-header">
        <div class="draft-page-header-left">
            <span class="draft-page-kicker">RaceCore Draft Center</span>

            <h1>Live Draft</h1>

            <p>
                Race: <strong>@raceName</strong><br />
                First you choose <strong>@ridersPerPlayer active riders</strong>.
                Then you choose <strong>@benchPerPlayer bench riders</strong>.
            </p>
        </div>

        <div class="draft-page-header-right">

            <!-- Status van de draft -->
            <div class="draft-status-pill @(draftIsLive ? "live" : "done")">
                <span class="draft-status-dot"></span>
                @(draftIsLive ? "Draft Live" : draftIsDone ? "Draft Finished" : "No Draft Yet")
            </div>

            <!-- Knop om naar New Game te gaan -->
            <div class="draft-header-actions">
                <a asp-controller="Game"
                   asp-action="New"
                   class="draft-header-btn draft-header-btn-white">
                    New Game
                </a>
            </div>
        </div>
    </div>

    <!-- =========================================================
         FOUTMELDINGEN
         ========================================================= -->
    @if (TempData["Error"] != null)
    {
        <div class="draft-alert draft-alert-error">@TempData["Error"]</div>
    }

    @if (TempData["DatabaseError"] != null)
    {
        <div class="draft-alert draft-alert-error">@TempData["DatabaseError"]</div>
    }

    <!-- =========================================================
         DRAFT STATISTIEKEN BOVENAAN
         ========================================================= -->

    <div class="draft-stats-grid">

        <!-- Status kaart -->
        <div class="draft-stat-card">
            <div class="draft-stat-icon">🎯</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Status</span>
                <strong class="draft-stat-value">
                    @(draftIsLive ? "LIVE" : draftIsDone ? "DONE" : "EMPTY")
                </strong>
            </div>
        </div>

        <!-- Aantal spelers -->
        <div class="draft-stat-card">
            <div class="draft-stat-icon">👥</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Players</span>
                <strong class="draft-stat-value">@totalPlayers</strong>
            </div>
        </div>

        <!-- Aantal gekozen renners -->
        <div class="draft-stat-card">
            <div class="draft-stat-icon">🚴</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Selected Riders</span>
                <strong class="draft-stat-value">@pickedCount</strong>
            </div>
        </div>

        <!-- Aantal resterende beurten -->
        <div class="draft-stat-card">
            <div class="draft-stat-icon">📋</div>
            <div class="draft-stat-content">
                <span class="draft-stat-label">Remaining Turns</span>
                <strong class="draft-stat-value">@remainingTurns</strong>
            </div>
        </div>
    </div>

    <!-- =========================================================
         DRAFT CONTENT LAYOUT
         ========================================================= -->

    <div class="draft-website-layout" id="draft-players-section">

        <!-- Linkerkant met spelers en picks -->
        <div class="draft-players-area">
            <div class="draft-page-section-title">
                <div>
                    <h2>Players in this draft</h2>
                    <p>
                        Each player chooses @ridersPerPlayer active riders and then @benchPerPlayer bench riders.
                    </p>
                </div>

                <span>@totalPlayers players</span>
            </div>

            <!-- Draft tabel -->
            <div class="draft-table">
                <div class="draft-table-head">
                    <div>Player</div>
                    <div>Picks</div>
                    <div>Action</div>
                </div>

                <div class="draft-table-body">
                    @if (!playerRows.Any())
                    {
                        <!-- Melding als er geen draft bestaat -->
                        <div class="draft-empty-state" style="padding:24px;">
                            No draft has been created yet. Start a New Game first.
                        </div>
                    }
                    else
                    {
                        foreach (var player in playerRows)
                        {
                            // Controleren of deze speler nu aan de beurt is
                            var isActive = currentTurn != null &&
                                           player.NextTurn != null &&
                                           player.NextTurn.Id == currentTurn.Id;

                            // Eerste letter voor avatar
                            var initial = "?";

                            if (!string.IsNullOrWhiteSpace(player.PlayerName))
                            {
                                initial = player.PlayerName.Substring(0, 1).ToUpper();
                            }

                            // Controleren of volgende pick bench is
                            var nextIsBench = player.PickedCount >= ridersPerPlayer;

                            <div class="draft-row @(isActive ? "active" : "")">
                                <div class="draft-cell draft-player-cell" data-label="Player">
                                    <div class="draft-player-avatar">@initial</div>

                                    <div class="draft-player-meta">
                                        <div class="draft-player-name-row">
                                            <span class="draft-player-name">@player.PlayerName</span>

                                            @if (isActive)
                                            {
                                                if (nextIsBench)
                                                {
                                                    <span class="draft-inline-badge active" style="background:#fff7ed;color:#c2410c;">
                                                        Choose Bench Rider
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="draft-inline-badge active">
                                                        Choose Active Rider
                                                    </span>
                                                }
                                            }
                                            else if (player.PickedCount >= player.TotalTurns)
                                            {
                                                <span class="draft-inline-badge picked">Done</span>
                                            }
                                            else
                                            {
                                                <span class="draft-inline-badge waiting">Waiting</span>
                                            }
                                        </div>

                                        <!-- Aantal actieve en bench picks tonen -->
                                        <span class="draft-player-subtitle">
                                            Active: @player.ActivePicked / @ridersPerPlayer |
                                            Bench: @player.BenchPicked / @benchPerPlayer
                                        </span>
                                    </div>
                                </div>

                                <!-- Pick teller -->
                                <div class="draft-cell draft-position-cell" data-label="Picks">
                                    <span class="draft-position-badge">
                                        @player.PickedCount / @totalPicksPerPlayer
                                    </span>
                                </div>

                                <!-- Actie kolom -->
                                <div class="draft-cell draft-selection-cell" data-label="Action">
                                    @if (isActive && currentTurn != null)
                                    {
                                        <!-- Formulier om wielrenner te kiezen -->
                                        <form asp-action="PickCyclist" method="post" class="draft-pick-form">
                                            @Html.AntiForgeryToken()

                                            <input type="hidden" name="draftTurnId" value="@currentTurn.Id" />
                                            <input type="hidden" name="gameId" value="@gameId" />
                                            <input type="hidden" name="cyclistId" class="draft-selected-cyclist-id" />

                                            <!-- Zoekveld voor wielrenners -->
                                            <div class="draft-combobox">
                                                <input type="text"
                                                       class="draft-combobox-input"
                                                       autocomplete="off"
                                                       placeholder="Type full name or scroll through the list..."
                                                       required />

                                                <!-- Dropdown lijst met wielrenners -->
                                                <div class="draft-combobox-list">
                                                    @foreach (var cyclist in cyclists.OrderBy(c => c.FullName))
                                                    {
                                                        <button type="button"
                                                                class="draft-combobox-option"
                                                                data-id="@cyclist.Id"
                                                                data-name="@cyclist.FullName">
                                                            @cyclist.FullName
                                                        </button>
                                                    }

                                                    <div class="draft-combobox-empty">
                                                        No cyclist found.
                                                    </div>
                                                </div>
                                            </div>

                                            <button type="submit" class="draft-pick-button">
                                                Pick
                                            </button>
                                        </form>
                                    }
                                    else if (player.PickedCount >= player.TotalTurns)
                                    {
                                        <!-- Speler is klaar -->
                                        <div class="draft-picked-name">
                                            <span class="draft-picked-icon">✔</span>
                                            <span>Team Complete</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- Speler wacht op beurt -->
                                        <div class="draft-empty-state">
                                            Waiting...
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <!-- Rechterkant met draft informatie -->
        <div class="draft-info-area">
            <div class="draft-side-card draft-side-highlight">
                <div class="draft-side-card-header">
                    <h3>Live Draft Info</h3>

                    <span class="draft-mini-status @(draftIsLive ? "live" : "done")">
                        @(draftIsLive ? "Live" : draftIsDone ? "Done" : "Empty")
                    </span>
                </div>

                <!-- Huidige beurt tonen -->
                <div class="draft-current-turn-box">
                    <span class="draft-current-turn-label">Current Turn</span>

                    <strong class="draft-current-turn-name">
                        @(currentTurn?.PlayerName ?? (draftIsDone ? "Draft Finished" : "No Draft Yet"))
                    </strong>

                    @if (currentTurn != null)
                    {
                        <div style="margin-top:12px;">
                            @if (currentPickIsBench)
                            {
                                <span style="display:inline-flex;padding:7px 12px;border-radius:999px;background:#fff7ed;color:#c2410c;font-weight:900;">
                                    Bench Rider @(currentPickNumberForPlayer - ridersPerPlayer) / @benchPerPlayer
                                </span>
                            }
                            else
                            {
                                <span style="display:inline-flex;padding:7px 12px;border-radius:999px;background:#ecfdf5;color:#047857;font-weight:900;">
                                    Active Rider @currentPickNumberForPlayer / @ridersPerPlayer
                                </span>
                            }
                        </div>
                    }
                </div>

                <!-- Extra draft info -->
                <div class="draft-info-list">
                    <div class="draft-info-item">
                        <span>Active riders per player</span>
                        <strong>@ridersPerPlayer</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Bench riders per player</span>
                        <strong>@benchPerPlayer</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Total per player</span>
                        <strong>@totalPicksPerPlayer</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Available cyclists</span>
                        <strong>@cyclists.Count</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Selected cyclists</span>
                        <strong>@pickedCount</strong>
                    </div>

                    <div class="draft-info-item">
                        <span>Total draft turns</span>
                        <strong>@totalTurns</strong>
                    </div>
                </div>
            </div>

            <!-- Draft progress kaart -->
            <div class="draft-side-card">
                <div class="draft-side-card-header">
                    <h3>Draft Progress</h3>
                </div>

                <div class="draft-progress-wrap">
                    <div class="draft-progress-bar">
                        <div class="draft-progress-fill" style="width:@(totalTurns == 0 ? 0 : (pickedCount * 100 / totalTurns))%;"></div>
                    </div>

                    <div class="draft-progress-text">
                        @pickedCount / @totalTurns picks completed
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- SignalR script voor live multiplayer updates -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

<script>
    // Game id gebruiken in JavaScript
    const gameId = Number(@gameId);

    // Voorkomt dubbele redirects/herlaad acties
    let pageIsChanging = false;

    // Versie van de huidige draft pagina
    let currentDraftVersion = "@pickedCount-@(currentTurn?.Id ?? 0)-@ViewBag.GameStatus-@ridersPerPlayer-@benchPerPlayer";

    /* =========================================================
    TEKST NORMALISEREN VOOR ZOEKFUNCTIE
    ========================================================= */

    function normalizeText(value) {
    return value
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .trim();
    }

    /* =========================================================
    COMBOBOX VOOR WIELRENNERS
    ========================================================= */

    document.querySelectorAll(".draft-combobox").forEach(function (box) {
    const input = box.querySelector(".draft-combobox-input");
    const options = Array.from(box.querySelectorAll(".draft-combobox-option"));
    const empty = box.querySelector(".draft-combobox-empty");
    const form = box.closest("form");
    const hiddenId = form.querySelector(".draft-selected-cyclist-id");

    // Lijst openen
    function openList() {
    box.classList.add("open");
    }

    // Lijst sluiten
    function closeList() {
    setTimeout(function () {
    box.classList.remove("open");
    }, 160);
    }

    // Lijst filteren op basis van input
    function filterList() {
    const search = normalizeText(input.value);
    let visibleCount = 0;

    hiddenId.value = "";

    options.forEach(function (option) {
    const name = normalizeText(option.dataset.name || "");
    const visible = name.includes(search);

    option.style.display = visible ? "block" : "none";

    if (visible) {
    visibleCount++;
    }
    });

    empty.style.display = visibleCount === 0 ? "block" : "none";

    const exactMatch = options.find(function (option) {
    return normalizeText(option.dataset.name || "") === search;
    });

    if (exactMatch) {
    hiddenId.value = exactMatch.dataset.id;
    }
    }

    input.addEventListener("focus", function () {
    openList();
    filterList();
    });

    input.addEventListener("click", function () {
    openList();
    filterList();
    });

    input.addEventListener("input", function () {
    openList();
    filterList();
    });

    input.addEventListener("blur", closeList);

    // Wielrenner kiezen uit lijst
    options.forEach(function (option) {
    option.addEventListener("click", function () {
    input.value = option.dataset.name;
    hiddenId.value = option.dataset.id;
    box.classList.remove("open");

    options.forEach(x => x.classList.remove("active"));
    option.classList.add("active");
    });
    });

    // Controle voor submit
    form.addEventListener("submit", function (event) {
    const typedName = normalizeText(input.value);

    if (!hiddenId.value) {
    const exactMatch = options.find(function (option) {
    return normalizeText(option.dataset.name || "") === typedName;
    });

    if (exactMatch) {
    hiddenId.value = exactMatch.dataset.id;
    }
    }

    if (!hiddenId.value) {
    event.preventDefault();
    alert("Choose a cyclist from the list. Type the full exact name or click a cyclist.");
    input.focus();
    openList();
    }
    });
    });

    /* =========================================================
    NAVIGATIE FUNCTIES
    ========================================================= */

    function goToDraft() {
    if (pageIsChanging) {
    return;
    }

    pageIsChanging = true;

    const url = "/Draft/Index?gameId=" + gameId + "&refresh=" + Date.now() + "#draft-players-section";
    window.location.replace(url);
    }

    function goToDashboard() {
    if (pageIsChanging) {
    return;
    }

    pageIsChanging = true;

    window.location.replace("/Dashboard/Index?gameId=" + gameId + "&refresh=" + Date.now());
    }

    // Terug scrollen naar draft sectie na refresh
    window.addEventListener("load", function () {
    const section = document.getElementById("draft-players-section");

    if (section !== null && window.location.hash === "#draft-players-section") {
    section.scrollIntoView();
    }
    });

    /* =========================================================
    SIGNALR LIVE UPDATE CONNECTIE
    ========================================================= */

    const connection = new signalR.HubConnectionBuilder()
    .withUrl("/gameHub")
    .withAutomaticReconnect([0, 500, 1000, 2000])
    .build();

    // Event ontvangen wanneer draft wijzigt
    connection.on("DraftUpdated", function (data) {
    console.log("DraftUpdated received:", data);

    if (Number(data.gameId) !== gameId) {
    return;
    }

    if (data.draftFinished === true || data.draftFinished === "true") {
    goToDashboard();
    return;
    }

    goToDraft();
    });

    // SignalR starten en game groep joinen
    connection.start()
    .then(function () {
    console.log("SignalR connected for game:", gameId);
    return connection.invoke("JoinGameGroup", gameId);
    })
    .then(function () {
    console.log("Joined SignalR group: game-" + gameId);
    })
    .catch(function (err) {
    console.error("SignalR connection error:", err);
    });

    /* =========================================================
    HOST PING
    ========================================================= */

    function sendHostPing() {
    if (gameId <= 0) {
    return;
    }

    fetch("/Game/HostPing?gameId=" + gameId, {
    method: "POST",
    credentials: "same-origin",
    headers: {
    "X-Requested-With": "XMLHttpRequest"
    }
    }).catch(function () { });
    }

    /* =========================================================
    DRAFT STATUS CONTROLEREN
    ========================================================= */

    async function checkDraftState() {
    if (gameId <= 0 || pageIsChanging) {
    return;
    }

    try {
    const response = await fetch("/Draft/GetDraftState?gameId=" + gameId + "&t=" + Date.now(), {
    method: "GET",
    credentials: "same-origin",
    cache: "no-store",
    headers: {
    "X-Requested-With": "XMLHttpRequest"
    }
    });

    const data = await response.json();

    if (!data.exists) {
    return;
    }

    console.log("DraftState:", data);

    if (data.status !== "Draft") {
    goToDashboard();
    return;
    }

    if (data.version !== currentDraftVersion) {
    goToDraft();
    }
    } catch (error) {
    console.error("DraftState error:", error);
    }
    }

    // Host actief houden
    sendHostPing();
    setInterval(sendHostPing, 5000);

    // Draft status elke seconde controleren
    setInterval(checkDraftState, 1000);
</script>