@model StageProject_RaceCore.ViewModels.LeaderboardViewModel

@{
    ViewData["Title"] = "Leaderboard";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Leaderboard.css" asp-append-version="true" />

<div class="leaderboard-page">

    <!-- =========================
         HERO / HEADER
    ========================== -->
    <section class="leaderboard-hero">

        <!-- Linkerkant: titel -->
        <div class="leaderbord-title">
            <h6>RaceCore Ranking</h6>
            <h1>Ranglijst</h1>
            <p>Bekijk per rit hoeveel punten elke speler heeft behaald.</p>
        </div>

        <!-- Rechterkant: game selectie + Done knop -->
        <div class="leaderboard-hero-actions">

            <!-- Game dropdown: toont alleen afgewerkte games -->
            <form asp-controller="Leaderboard"
                  asp-action="Index"
                  method="get"
                  class="leaderboard-game-form">

                <label for="gameId">Afgewerkte game</label>

                <select id="gameId"
                        name="gameId"
                        onchange="this.form.submit()"
                        disabled="@(!Model.Games.Any())">

                    @foreach (var game in Model.Games)
                    {
                        if (game.Id == Model.SelectedGameId)
                        {
                            <option value="@game.Id" selected>
                                @game.Race?.Name - @game.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </option>
                        }
                        else
                        {
                            <option value="@game.Id">
                                @game.Race?.Name - @game.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                            </option>
                        }
                    }
                </select>
            </form>

            <!-- Done knop -->
            <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="leaderboard-done-btn">
                ✔ Done
            </a>
        </div>
    </section>

    <!-- =========================
         EMPTY STATE ALS ER GEEN AFGEWERKTE GAME IS
    ========================== -->
    @if (!Model.Games.Any())
    {
        <section class="leaderboard-card">
            <div class="leaderboard-empty">
                <h2>Geen afgewerkte games gevonden</h2>
                <p>Alleen games die volledig klaar zijn worden hier getoond.</p>
            </div>
        </section>
    }
    else
    {
        <!-- =========================
             STATS CARDS
        ========================== -->
        <section class="leaderboard-stats">

            <!-- Race naam -->
            <div class="leaderboard-stat-card">
                <span>Race</span>
                <strong>@Model.RaceName</strong>
            </div>

            <!-- Game status -->
            <div class="leaderboard-stat-card">
                <span>Status</span>
                <strong>@Model.GameStatus</strong>
            </div>

            <!-- Aantal spelers -->
            <div class="leaderboard-stat-card">
                <span>Spelers</span>
                <strong>@Model.PlayerCount</strong>
            </div>

            <!-- Totaal punten -->
            <div class="leaderboard-stat-card">
                <span>Totaal punten</span>
                <strong>@Model.TotalPoints</strong>
            </div>
        </section>

        <!-- =========================
             EXCEL-ACHTIGE PUNTENTABEL
        ========================== -->
        <section class="leaderboard-card">

            <!-- Header van de kaart -->
            <div class="leaderboard-card-header">
                <div>
                    <h2>Score per rit</h2>
                    <p>Elke rij is een rit. Elke kolom is een speler.</p>
                </div>
            </div>

            <!-- Empty state als er geen spelers zijn -->
            @if (!Model.Players.Any())
            {
                <div class="leaderboard-empty">
                    <h2>Nog geen spelers</h2>
                    <p>Er zijn geen spelers gekoppeld aan deze afgewerkte game.</p>
                </div>
            }
            else
            {
                <!-- Scrollbare tabel -->
                <div class="leaderboard-table-wrapper">
                    <table class="leaderboard-score-table">

                        <!-- Tabel hoofding -->
                        <thead>
                            <tr>
                                <th class="stage-column">Rit</th>

                                @foreach (var player in Model.Players)
                                {
                                    <th class="player-header">
                                        @player.PlayerName
                                    </th>
                                }
                            </tr>
                        </thead>

                        <!-- Tabel inhoud -->
                        <tbody>

                            <!-- Ritten -->
                            @foreach (var stageRow in Model.StageRows)
                            {
                                <tr>
                                    <td class="stage-name">
                                        Rit @stageRow.StageNumber
                                    </td>

                                    @foreach (var player in Model.Players)
                                    {
                                        int points = stageRow.PointsPerPlayer.ContainsKey(player.PlayerId)
                                            ? stageRow.PointsPerPlayer[player.PlayerId]
                                            : 0;

                                        <td class="points-number">
                                            @points
                                        </td>
                                    }
                                </tr>
                            }

                            <!-- Eindafrekening -->
                            <tr class="final-row">
                                <td class="stage-name">
                                    Eindafrekening
                                </td>

                                @foreach (var player in Model.Players)
                                {
                                    int finalPoints = Model.FinalSettlementPoints.ContainsKey(player.PlayerId)
                                        ? Model.FinalSettlementPoints[player.PlayerId]
                                        : 0;

                                    <td class="points-number">
                                        @finalPoints
                                    </td>
                                }
                            </tr>

                            <!-- Totaal -->
                            <tr class="total-row">
                                <td class="stage-name">
                                    TOTAAL
                                </td>

                                @foreach (var player in Model.Players)
                                {
                                    int total = Model.TotalPointsPerPlayer.ContainsKey(player.PlayerId)
                                        ? Model.TotalPointsPerPlayer[player.PlayerId]
                                        : 0;

                                    <td class="points-number">
                                        @total
                                    </td>
                                }
                            </tr>
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
</div>