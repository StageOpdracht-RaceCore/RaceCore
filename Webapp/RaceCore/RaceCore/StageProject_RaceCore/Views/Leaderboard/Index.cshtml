    </section>

    @if (!Model.Games.Any())
    {
        <section class="leaderboard-card">
            <div class="leaderboard-empty">
                <h2>Geen game gevonden</h2>
                <p>Start eerst een nieuwe game voordat het leaderboard punten kan tonen.</p>
            </div>
        </section>
    }
    else
    {
        <section class="leaderboard-stats">
            <div class="leaderboard-stat-card">
                <span>Race</span>
                <strong>@Model.RaceName</strong>
            </div>

            <div class="leaderboard-stat-card">
                <span>Status</span>
                <strong>@Model.GameStatus</strong>
            </div>

            <div class="leaderboard-stat-card">
                <span>Spelers</span>
                <strong>@Model.PlayerCount</strong>
            </div>

            <div class="leaderboard-stat-card">
                <span>Totaal punten</span>
                <strong>@Model.TotalPoints</strong>
            </div>
        </section>

        <section class="leaderboard-card">
            <div class="leaderboard-card-header">
                <div>
                    <h2>Player Ranking</h2>
                    <p>Rangschikking op basis van alle punten in deze game.</p>
                </div>
            </div>

            @if (!Model.Rows.Any())
            {
                <div class="leaderboard-empty">
                    <h2>Nog geen spelers</h2>
                    <p>Er zijn nog geen draft turns of spelers gekoppeld aan deze game.</p>
                </div>
            }
            else
            {
                <div class="leaderboard-table-wrapper">
                    <table class="leaderboard-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Player</th>
                                <th>Draft</th>
                                <th>Renners</th>
                                <th>Beste renner</th>
                                <th>Punten</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var row in Model.Rows)
                            {
                                int percentage = maxPoints > 0
                                    ? (int)Math.Round((double)row.TotalPoints / maxPoints * 100)
                                    : 0;

                                <tr>
                                    <td>
                                        <span class="rank-badge rank-@row.Rank">@row.Rank</span>
                                    </td>

                                    <td>
                                        <div class="player-cell">
                                            <div class="player-avatar" style="background:@row.Color">
                                                @row.Initials
                                            </div>

                                            <div>
                                                <strong>@row.PlayerName</strong>
                                                <span>Player ID: @row.PlayerId</span>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="draft-pill">#@row.DraftPosition</span>
                                    </td>

                                    <td>
                                        @row.RidersCount
                                    </td>

                                    <td>
                                        <div class="best-rider">
                                            <strong>@row.BestCyclistName</strong>
                                            <span>@row.BestCyclistPoints punten</span>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="points-cell">
                                            <strong>@row.TotalPoints</strong>

                                            <div class="points-bar">
                                                <div style="width:@percentage%; background:@row.Color"></div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
