@model ErrorViewModel
@{
    // Page title for the error view
    ViewData["Title"] = "Error";
}

@* Error.cshtml
   Purpose: Friendly error page displayed when an unhandled exception
   occurs. In production this page should be generic to avoid leaking
   sensitive information. During development use the Development
   environment to show detailed error pages from the framework.
*@

<h1 class="text-danger">Error.</h1>
<h2 class="text-danger">An error occurred while processing your request.</h2>

@* Optionally show the request ID to help correlate logs and traces. *@
@if (Model.ShowRequestId)
{
    <p>
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Development Mode</h3>
<p>
    Switching to the <strong>Development</strong> environment will display more detailed information about the error that occurred.
</p>
<p>
    <strong>The Development environment should not be enabled for deployed applications.</strong>
    It may expose sensitive exception details to end users.
    For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong> environment variable to <strong>Development</strong>
    and restarting the application.
</p>