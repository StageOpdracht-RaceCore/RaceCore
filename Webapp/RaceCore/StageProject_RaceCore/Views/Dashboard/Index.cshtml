@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
@functions {
    public string GetPlayerColor(string playerName)
    {
        var colors = new[]
        {
            "#ef4444",
            "#3b82f6",
            "#10b981",
            "#f59e0b",
            "#8b5cf6",
            "#ec4899",
            "#14b8a6",
            "#eab308"
        };

        int index = Math.Abs(playerName.GetHashCode()) % colors.Length;
        return colors[index];
    }
}

<div class="dashboard-container">

    <div class="stats-grid">
        <div class="stat-card">
            <h4>Players</h4>
            <p>5</p>
        </div>
        <div class="stat-card">
            <h4>Cyclists</h4>
            <p>120</p>
        </div>
        <div class="stat-card">
            <h4>Teams</h4>
            <p>22</p>
        </div>
        <div class="stat-card">
            <h4>Stages</h4>
            <p>21</p>
        </div>
    </div>

    <div class="main-grid">

        <div class="card">
            <h3>Player Ranking</h3>
            <table class="ranking-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th>Points</th>
                    </tr>
                </thead>
                <tbody>
                    <tr style="background-color:@GetPlayerColor("Daniel");">
                        <td>1</td>
                        <td>Daniel</td>
                        <td>245</td>
                    </tr>
                    <tr style="background-color:@GetPlayerColor("Alex");">
                        <td>2</td>
                        <td>Alex</td>
                        <td>230</td>
                    </tr>
                    <tr style="background-color:@GetPlayerColor("John");">
                        <td>3</td>
                        <td>John</td>
                        <td>210</td>
                    </tr>
                    <tr style="background-color:@GetPlayerColor("Mike");">
                        <td>4</td>
                        <td>Mike</td>
                        <td>198</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="card">
            <h3>Latest Stage</h3>
            <p><strong>Stage 5</strong></p>
            <p>1. Pogacar</p>
            <p>2. Van Aert</p>
            <p>3. Evenepoel</p>
        </div>

    </div>

    <div class="main-grid second-row">

        <div class="card">
            <h3>Top Cyclists</h3>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Points</th>
                    </tr>
                </thead>
                <tbody>
                    <tr><td>Pogacar</td><td>120</td></tr>
                    <tr><td>Van Aert</td><td>110</td></tr>
                    <tr><td>Evenepoel</td><td>105</td></tr>
                </tbody>
            </table>
        </div>

        <div class="card">
            <h3>Jerseys</h3>
            <p>Yellow: Pogacar</p>
            <p>Green: Van Aert</p>
            <p>Polka Dot: Ciccone</p>
            <p>White: Evenepoel</p>
        </div>

        <div class="card">
            <h3>Draft</h3>
            <p>Completed: Yes</p>
            <p>Total picks: 50</p>
        </div>

    </div>

</div>