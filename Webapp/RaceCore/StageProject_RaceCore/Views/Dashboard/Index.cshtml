@model StageProject_RaceCore.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@functions {
    public string GetPlayerColor(string playerName)
    {
        var colors = new[]
        {
            "#3b82f6",
            "#eab308",
            "#10b981",
            "#8b5cf6",
            "#ef4444",
            "#f59e0b",
            "#ec4899",
            "#14b8a6",
            "#6366f1",
            "#84cc16",
            "#f97316",
            "#06b6d4"
        };

        if (string.IsNullOrWhiteSpace(playerName))
        {
            return colors[0];
        }

        int value = 0;

        foreach (char c in playerName.Trim().ToLower())
        {
            value += c;
        }

        int index = value % colors.Length;
        return colors[index];
    }
}

<div class="dashboard-container">

    <div class="stats-grid">
        <div class="stat-card">
            <h4>Players</h4>
            <p>@Model.PlayersCount</p>
        </div>
        <div class="stat-card">
            <h4>Cyclists</h4>
            <p>@Model.CyclistsCount</p>
        </div>
        <div class="stat-card">
            <h4>Teams</h4>
            <p>@Model.TeamsCount</p>
        </div>
        <div class="stat-card">
            <h4>Stages</h4>
            <p>@Model.StagesCount</p>
        </div>
    </div>

    <div class="main-grid">

        <div class="card">
            <h3>Player Ranking</h3>
            @if (Model.PlayerRanking.Any())
            {
                <table class="ranking-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Player</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var player in Model.PlayerRanking)
                        {
                            <tr style="background-color:@GetPlayerColor(player.PlayerName);">
                                <td>@player.Position</td>
                                <td>@player.PlayerName</td>
                                <td>@player.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>No player ranking data available yet.</p>
            }
        </div>

        <div class="card">
            <h3>Latest Stage</h3>
            @if (!string.IsNullOrWhiteSpace(Model.LatestStageTitle))
            {
                <p><strong>@Model.LatestStageTitle</strong></p>

                @if (Model.LatestStageTop3.Any())
                {
                    @foreach (var item in Model.LatestStageTop3)
                    {
                        <p>@item</p>
                    }
                }
                else
                {
                    <p>No stage results available yet.</p>
                }
            }
            else
            {
                <p>No stage available yet.</p>
            }
        </div>

    </div>

    <div class="main-grid second-row">

        <div class="card">
            <h3>Top Cyclists</h3>
            @if (Model.TopCyclists.Any())
            {
                <table>
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Points</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cyclist in Model.TopCyclists)
                        {
                            <tr>
                                <td>@cyclist.Name</td>
                                <td>@cyclist.Points</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <p>No cyclist points available yet.</p>
            }
        </div>

        <div class="card">
            <h3>Jerseys</h3>
            @if (Model.Jerseys.Any())
            {
                @foreach (var jersey in Model.Jerseys)
                {
                    <p>@jersey.Type: @jersey.CyclistName</p>
                }
            }
            else
            {
                <p>No jersey data available yet.</p>
            }
        </div>

        <div class="card">
            <h3>Draft</h3>
            <p>Completed: @(Model.DraftCompleted ? "Yes" : "No")</p>
            <p>Total picks: @Model.TotalDraftPicks</p>
        </div>

    </div>

</div>