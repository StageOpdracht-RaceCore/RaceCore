@model IEnumerable<StageProject_RaceCore.Models.TeamViewModel>
@using System.Linq

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Team.css" />

<div class="page-card">
    <h2>Teams</h2>
    <p>This is the Team Overview</p>
    <p>On this page you will be able to view the teams and their points.</p>
</div>

@if (!(Model?.Any() ?? false))
{
    <div class="page-card">
        <h3>No teams found</h3>
        <p>There are currently no teams in the system.</p>
    </div>
}
else
{
    <div class="teams-grid">
        @foreach (var team in Model)
        {
            <div class="team-card collapsed" style="--team-color:@(team.Color ?? "#ddd");">
                <div class="team-header">
                    <div class="team-meta">
                        <span class="swatch" style="background:var(--team-color)"></span>
                        <div>
                            <div style="font-size:1.05rem; font-weight:600">@team.Name <span class="tag">@team.Tag</span></div>
                            <div style="font-size:0.85rem; color:#666">@(team.ActiveCyclistsCount + team.BenchCyclistsCount) cyclists</div>
                        </div>
                    </div>

                    <div style="text-align:right; display:flex; flex-direction:column; align-items:flex-end; gap:6px;">
                        <div style="display:flex; align-items:center; gap:8px;">
                            <div class="badge">@team.TeamPoints pts</div>
                            <button type="button" class="collapse-toggle" aria-expanded="false" title="Toggle team">
                                <span class="arrow">▾</span>
                            </button>
                        </div>
                        <div style="font-size:0.85rem; color:#666;">Active: <strong>@team.ActiveCyclistsCount</strong> · Bench: <strong>@team.BenchCyclistsCount</strong></div>
                    </div>
                </div>

                <div class="team-body">
                    <div class="composition">
                        <div class="column">
                            <h4>Active</h4>

                            @if (team.ActiveCyclists != null && team.ActiveCyclists.Any())
                            {
                                <ul class="cyclist-list">
                                    @foreach (var c in team.ActiveCyclists)
                                    {
                                        <li>
                                            <span>@c.FirstName @c.LastName</span>
                                            <form asp-controller="Team" asp-action="ToggleCyclistStatus" method="post" style="display:inline; margin-left:8px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cyclistId" value="@c.Id" />
                                                <input type="hidden" name="isActive" value="false" />
                                                <button type="submit" class="btn" style="font-size:0.85rem; padding:4px 8px; border-radius:4px; border:1px solid #ddd; background:#fff; color:#333;">Bench</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No active cyclists</div>
                            }
                        </div>

                        <div class="column">
                            <h4>Bench</h4>

                            @if (team.BenchCyclists != null && team.BenchCyclists.Any())
                            {
                                <ul class="cyclist-list">
                                    @foreach (var c in team.BenchCyclists)
                                    {
                                        <li>
                                            <span>@c.FirstName @c.LastName</span>
                                            <form asp-controller="Team" asp-action="ToggleCyclistStatus" method="post" style="display:inline; margin-left:8px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cyclistId" value="@c.Id" />
                                                <input type="hidden" name="isActive" value="true" />
                                                <button type="submit" class="btn" style="font-size:0.85rem; padding:4px 8px; border-radius:4px; border:1px solid #0a6; background:#0a6; color:#fff;">Activate</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No cyclists on the bench</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
    (function () {
        // Delegated click handler for collapse toggling
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.collapse-toggle');
            if (btn) {
                var cardBtn = btn.closest('.team-card');
                if (!cardBtn) return;
                var isNowCollapsedBtn = cardBtn.classList.toggle('collapsed');
                btn.setAttribute('aria-expanded', String(!isNowCollapsedBtn));
                return;
            }

            var header = e.target.closest('.team-header');
            if (header) {
                if (e.target.closest('button') || e.target.closest('a') || e.target.closest('form')) return;
                var cardHeader = header.closest('.team-card');
                if (!cardHeader) return;
                var toggle = cardHeader.querySelector('.collapse-toggle');
                var isNowCollapsedHeader = cardHeader.classList.toggle('collapsed');
                if (toggle) toggle.setAttribute('aria-expanded', String(!isNowCollapsedHeader));
            }
        });
    })();
</script>