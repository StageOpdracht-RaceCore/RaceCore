@model IEnumerable<StageProject_RaceCore.Models.TeamViewModel>
@using System.Linq

@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Team.css" />

<div class="page-card page-summary">
    <h2>Teams</h2>
    <p>This is the Team Overview</p>
    <p>On this page you will be able to view the teams and their points.</p>
</div>

@if (!(Model?.Any() ?? false))
{
    <div class="page-card">
        <h3>No teams found</h3>
        <p>There are currently no teams in the system.</p>
    </div>
}
else
{
    <div class="teams-grid">
        @foreach (var team in Model.OrderByDescending(t => (t.ActiveCyclistsCount + t.BenchCyclistsCount)))
        {
            <div class="team-card collapsed" data-team-id="@team.Id" style="--team-color:@(team.Color ?? "#ddd");">
                <div class="team-header">
                    <div class="team-meta">
                        <span class="swatch" style="background:var(--team-color)"></span>
                        <div>
                            <div style="font-size:1.05rem; font-weight:600">@team.Name <span class="tag">@team.Tag</span></div>
                            <div style="font-size:0.85rem; color:#666">@(team.ActiveCyclistsCount + team.BenchCyclistsCount) cyclists</div>
                        </div>
                    </div>

                    <div class="team-stats">
                        <div class="team-stats-top">
                            <div class="badge">@team.TeamPoints pts</div>
                            <button type="button" class="collapse-toggle" aria-expanded="false" title="Toggle team">
                                <span class="arrow">▾</span>
                            </button>
                        </div>
                        <div class="team-counts">Active: <strong>@team.ActiveCyclistsCount</strong> · Bench: <strong>@team.BenchCyclistsCount</strong></div>
                    </div>
                </div>

                <div class="team-body">
                    <div class="composition">
                        <div class="column">
                            <h4>Active</h4>

                            @if (team.ActiveCyclists != null && team.ActiveCyclists.Any())
                            {
                                <ul class="cyclist-list">
                                    @foreach (var c in team.ActiveCyclists)
                                    {
                                        <li>
                                            <span>@c.FirstName @c.LastName</span>
                                            <form asp-controller="Team" asp-action="ToggleCyclistStatus" method="post" class="cyclist-form" style="display:inline; margin-left:8px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cyclistId" value="@c.Id" />
                                                <input type="hidden" name="isActive" value="false" />
                                                <button type="submit" class="btn bench-btn" style="font-size:0.85rem; padding:4px 8px; border-radius:4px; border:1px solid #ddd; background:#fff; color:#333;">Bench</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No active cyclists</div>
                            }
                        </div>

                        <div class="column">
                            <h4>Bench</h4>

                            @if (team.BenchCyclists != null && team.BenchCyclists.Any())
                            {
                                <ul class="cyclist-list">
                                    @foreach (var c in team.BenchCyclists)
                                    {
                                        <li>
                                            <span>@c.FirstName @c.LastName</span>
                                            <form asp-controller="Team" asp-action="ToggleCyclistStatus" method="post" class="cyclist-form" style="display:inline; margin-left:8px;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="cyclistId" value="@c.Id" />
                                                <input type="hidden" name="isActive" value="true" />
                                                <button type="submit" class="btn activate-btn" style="font-size:0.85rem; padding:4px 8px; border-radius:4px; border:1px solid #0a6; background:#0a6; color:#fff;">Activate</button>
                                            </form>
                                        </li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <div class="empty">No cyclists on the bench</div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

<script>
    (function () {
        var STORAGE_KEY = 'teamsCollapseState';

        function readState() {
            try {
                var raw = localStorage.getItem(STORAGE_KEY);
                return raw ? JSON.parse(raw) : {};
            } catch (e) {
                return {};
            }
        }

        function writeState(state) {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
            } catch (e) {
                // ignore
            }
        }

        function saveCardState(card) {
            var id = card.getAttribute('data-team-id');
            if (!id) return;
            var state = readState();
            state[id] = card.classList.contains('collapsed');
            writeState(state);
        }

        function restoreAll() {
            var state = readState();
            document.querySelectorAll('.team-card[data-team-id]').forEach(function (card) {
                var id = card.getAttribute('data-team-id');
                if (!id) return;
                var collapsed = state.hasOwnProperty(id) ? state[id] : true; // default collapsed
                if (collapsed) {
                    card.classList.add('collapsed');
                    var btn = card.querySelector('.collapse-toggle');
                    if (btn) btn.setAttribute('aria-expanded', 'false');
                } else {
                    card.classList.remove('collapsed');
                    var btn = card.querySelector('.collapse-toggle');
                    if (btn) btn.setAttribute('aria-expanded', 'true');
                }
            });
        }

        // Assign or restore a stable accent color per team id using localStorage so colors persist across refreshes
        function hashStringToInt(str) {
            var h = 2166136261 >>> 0;
            for (var i = 0; i < str.length; i++) {
                h ^= str.charCodeAt(i);
                h = Math.imul(h, 16777619) >>> 0;
            }
            return h >>> 0;
        }

        // Ensure visually distinct colors: keep saved colors, for new ones pick hues
        // that are at least MIN_HUE_DIFF apart using golden angle stepping.
        (function assignDistinctColors() {
            var MIN_HUE_DIFF = 60; // degrees
            var goldenAngle = 137.508;
            var usedHues = [];

            // helper to compute minimal circular hue distance
            function hueDistance(a, b) {
                var d = Math.abs(a - b) % 360;
                return d > 180 ? 360 - d : d;
            }

            document.querySelectorAll('.team-card[data-team-id]').forEach(function (card, i) {
                var id = card.getAttribute('data-team-id');
                if (!id) return;
                var storageKey = 'teamColor_' + id;
                var saved = null;
                try { saved = localStorage.getItem(storageKey); } catch (e) { saved = null; }

                if (saved) {
                    // try to parse saved hue and remember it
                    card.style.setProperty('--team-color', saved);
                    var m = saved && saved.match(/hsl\(([-0-9.]+)\s*,\s*([0-9.]+)%\s*,\s*([0-9.]+)%\)/i);
                    if (m) {
                        var h = parseFloat(m[1]);
                        if (!Number.isNaN(h)) usedHues.push(h);
                    }
                } else {
                    // base hue from stable hash of id
                    var hash = hashStringToInt(String(id));
                    var baseHue = hash % 360;
                    // start candidate and step until distance constraint met
                    var candidate = (baseHue + (i * goldenAngle)) % 360;
                    var attempts = 0;
                    while (usedHues.some(function (uh) { return hueDistance(uh, candidate) < MIN_HUE_DIFF; })) {
                        candidate = (candidate + goldenAngle) % 360;
                        attempts++;
                        if (attempts > 36) break; // safety: after full wheel give up
                    }
                    var accent = 'hsl(' + candidate.toFixed(2) + ',70%,60%)';
                    card.style.setProperty('--team-color', accent);
                    try { localStorage.setItem(storageKey, accent); } catch (e) { /* ignore */ }
                    usedHues.push(candidate);
                }
            });
        })();

        // Restore collapse state after assigning colors
        restoreAll();

        // Delegated click handler for collapse toggling and saving state
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.collapse-toggle');
            if (btn) {
                var cardBtn = btn.closest('.team-card');
                if (!cardBtn) return;
                var isCollapsed = cardBtn.classList.toggle('collapsed');
                btn.setAttribute('aria-expanded', String(!isCollapsed));
                saveCardState(cardBtn);
                return;
            }

            var header = e.target.closest('.team-header');
            if (header) {
                if (e.target.closest('button') || e.target.closest('a') || e.target.closest('form')) return;
                var cardHeader = header.closest('.team-card');
                if (!cardHeader) return;
                var toggle = cardHeader.querySelector('.collapse-toggle');
                var isCollapsedHeader = cardHeader.classList.toggle('collapsed');
                if (toggle) toggle.setAttribute('aria-expanded', String(!isCollapsedHeader));
                saveCardState(cardHeader);
            }
        });

        // Before any bench/activate form submission, ensure current state is persisted.
        // Intercept clicks on bench/activate buttons to write current state (defensive)
        document.addEventListener('click', function (e) {
            var btn = e.target.closest('.bench-btn, .activate-btn');
            if (!btn) return;
            // write full state snapshot
            var state = {};
            document.querySelectorAll('.team-card[data-team-id]').forEach(function (card) {
                var id = card.getAttribute('data-team-id');
                if (!id) return;
                state[id] = card.classList.contains('collapsed');
            });
            writeState(state);
        }, true);
    })();
</script>
