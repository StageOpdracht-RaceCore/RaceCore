@model IEnumerable<StageProject_RaceCore.Models.Team>
@using System.Linq
@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-card">
    <h2>Teams</h2>
    <p>This is the Team Overview</p>
    <p>on this page you will be able to view the teams, and their points</p>
</div>

@if (!(Model?.Any() ?? false))
{
    <div class="page-card">
        <h3>No teams found</h3>
        <p>There are currently no teams in the system.</p>
    </div>
}
else
{
    <div class="teams-list">
        @foreach (var team in Model)
        {
            <div class="team-card" style="border-left: 6px solid; padding: 8px; margin-bottom: 12px;">
                <h3>@team.Name (@team.Tag)</h3>
                
                <p>Active cyclists: <strong>@team.ActiveCyclistsCount</strong> — Bench: <strong>@team.BenchCyclistsCount</strong></p>
                <p>Team points (active tunics x @StageProject_RaceCore.Models.Team.TunicPoints): <strong>@(team.ActiveCyclistsCount * StageProject_RaceCore.Models.Team.TunicPoints)</strong></p>

                <div class="team-composition">
                    <div class="active-list" style="margin-bottom:8px;">
                        <h4>Active</h4>
                        @if (team.Cyclists != null && team.Cyclists.Any(c => c.IsActive))
                        {
                            <ul>
                                @foreach (var c in team.Cyclists.Where(c => c.IsActive))
                                {
                                    <li>@c.FirstName @c.LastName</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p><em>No active cyclists</em></p>
                        }
                    </div>

                    <div class="bench-list">
                        <h4>Bench</h4>
                        @if (team.Cyclists != null && team.Cyclists.Any(c => !c.IsActive))
                        {
                            <ul>
                                @foreach (var c in team.Cyclists.Where(c => !c.IsActive))
                                {
                                    <li>@c.FirstName @c.LastName</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p><em>No cyclists on the bench</em></p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
