@model IEnumerable<StageProject_RaceCore.Models.TeamViewModel>
@using System.Linq
@{
    ViewData["Title"] = "Teams";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-card">
    <h2>Teams</h2>
    <p>This is the Team Overview</p>
    <p>on this page you will be able to view the teams, their team colors, and their points</p>
</div>

@if (!(Model?.Any() ?? false))
{
    <div class="page-card">
        <h3>No teams found</h3>
        <p>There are currently no teams in the system.</p>
    </div>
}
else
{
    <div class="teams-list">
        @foreach (var team in Model)
        {
            <div class="team-card" style="border-left: 6px solid @(team.Color ?? "#ccc"); padding: 8px; margin-bottom: 12px;">
                <h3>@team.Name (@team.Tag)</h3>
                <p>Color: <span style="display:inline-block;width:16px;height:16px;background:@(team.Color ?? "#ccc");border:1px solid #000;margin-right:6px;"></span> @(team.Color ?? "N/A")</p>
                <p>Active cyclists: <strong>@team.ActiveCyclistsCount</strong> — Bench: <strong>@team.BenchCyclistsCount</strong></p>
                <p>Team points (active tunics x @StageProject_RaceCore.Models.Team.TunicPoints): <strong>@team.TeamPoints</strong></p>

                <div class="team-composition">
                    <div class="active-list" style="margin-bottom:8px;">
                        <h4>Active</h4>
                        @if (team.ActiveCyclists != null && team.ActiveCyclists.Any())
                        {
                            <ul>
                                @foreach (var c in team.ActiveCyclists)
                                {
                                    <li>@c.FirstName @c.LastName</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p><em>No active cyclists</em></p>
                        }
                    </div>

                    <div class="bench-list">
                        <h4>Bench</h4>
                        @if (team.BenchCyclists != null && team.BenchCyclists.Any())
                        {
                            <ul>
                                @foreach (var c in team.BenchCyclists)
                                {
                                    <li>@c.FirstName @c.LastName</li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p><em>No cyclists on the bench</em></p>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
