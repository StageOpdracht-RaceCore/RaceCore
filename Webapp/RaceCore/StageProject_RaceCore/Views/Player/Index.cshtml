@model List<StageProject_RaceCore.Models.Player>

<h2>Spelers</h2>

<a class="btn btn-primary mb-3" asp-action="Create">Nieuwe speler</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Naam</th>
            <th>Draft positie</th>
            <th>Punten</th>
            <th>Acties</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            <tr>
                <td>@p.Name</td>
                <td>@p.PositionInDraft</td>
                <td>@p.TotalPoints</td>
                <td>
                    <a asp-action="Details" asp-route-id="@p.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@p.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@p.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>