
@{
    @model IEnumerable<StageProject_RaceCore.Controllers.ResultVM>

    <table border="1">
        <thead>
            <tr>
                <th>Positie</th>
                <th>Naam</th>
                <th>Punten</th>
                <th>Truien</th>
                <th>Totaal</th>
            </tr>
        </thead>
        <tbody>
            @{
                int pos = 1;
            }
            @foreach (var item in Model)
            {
                <tr>
                    <td>@pos</td>
                    <td>@item.CyclistName</td>
                    <td>@item.points</td>
                    <td>@item.JerseyType</td>
                    <td>@item.totalPoints</td>
                </tr>
                pos++;
            }
        </tbody>
    </table>

    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
