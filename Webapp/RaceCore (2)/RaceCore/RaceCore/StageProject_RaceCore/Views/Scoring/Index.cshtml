@model StageProject_RaceCore.ViewModels.ScoringViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using StageProject_RaceCore.Models
@using System.Text.Json

@{
    ViewData["Title"] = "Stage Resultaten";
    Layout = "~/Views/Shared/_CleanLayout.cshtml";

    var races = ViewBag.Races as List<Race> ?? new List<Race>();
    var stages = ViewBag.Stages as List<Stage> ?? new List<Stage>();

    int selectedRaceId = ViewBag.SelectedRaceId ?? 0;
    int selectedGameId = ViewBag.SelectedGameId ?? Model.GameSessionId;
    int stageNumber = ViewBag.StageNumber ?? 1;

    var yellowName = ViewBag.YellowJerseyName ?? "Yellow Jersey";
    var greenName = ViewBag.GreenJerseyName ?? "Green Jersey";
    var polkaName = ViewBag.PolkaJerseyName ?? "Bolletjestrui";
    var themeClass = ViewBag.JerseyTheme ?? "default-theme";

    string yellowOutsideName = ViewData["RedOutsideTop25CyclistName"]?.ToString() ?? "";
    string greenOutsideName = ViewData["GreenOutsideTop25CyclistName"]?.ToString() ?? "";
    string blueOutsideName = ViewData["BlueOutsideTop25CyclistName"]?.ToString() ?? "";
    string whiteOutsideName = ViewData["WhiteOutsideTop25CyclistName"]?.ToString() ?? "";
}

<link rel="stylesheet" href="~/css/Scoring.css" asp-append-version="true" />

<div class="scoring-page @themeClass">

    @* Meldingen tonen als er iets fout of goed is gegaan *@
    @if (TempData["Error"] != null)
    {
        <div class="scoring-alert scoring-alert-error">
            <strong>FOUT:</strong> <span>@TempData["Error"]</span>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="scoring-alert scoring-alert-success">
            <strong>OK:</strong> <span>@TempData["Success"]</span>
        </div>
    }

    @* Bovenste header van de scoring pagina *@
    <section class="scoring-hero">
        <div>
            <h1>@races.FirstOrDefault(r => r.Id == selectedRaceId)?.Name Scoring</h1>
            <p>Huidige etappe: <strong>Rit @stageNumber</strong></p>
        </div>

        <a asp-controller="Dashboard"
           asp-action="Index"
           asp-route-gameId="@selectedGameId"
           class="scoring-dashboard-btn">
            Dashboard
        </a>
    </section>

    @* Race en rit selectie *@
    <section class="scoring-card">
        <form asp-controller="Scoring" asp-action="Index" method="get" class="scoring-filter-form">
            <div style="display: flex; gap: 20px; align-items: flex-end; flex-wrap: wrap;">

                @* Race kiezen *@
                <div class="scoring-field">
                    <label>Race:</label>
                    <select name="raceId"
                            onchange="window.location.href='@Url.Action("Index", "Scoring")?raceId=' + this.value">
                        @foreach (var race in races)
                        {
                            <option value="@race.Id" selected="@(race.Id == selectedRaceId)">
                                @race.Name (@race.Year)
                            </option>
                        }
                    </select>
                </div>

                @* Rit kiezen, gameId blijft behouden zodat de juiste game wordt gebruikt *@
                <div class="scoring-field">
                    <label>Rit:</label>
                    <select name="stageId" onchange="this.form.submit()">
                        @foreach (var s in stages)
                        {
                            <option value="@s.Id" selected="@(s.Id == Model.StageId)">
                                Rit @s.StageNumber @(!string.IsNullOrEmpty(s.Name) ? $"- {s.Name}" : "")
                            </option>
                        }
                    </select>
                </div>

                <input type="hidden" name="raceId" value="@selectedRaceId" />
                <input type="hidden" name="gameId" value="@selectedGameId" />
            </div>
        </form>
    </section>

    @* Formulier dat de scores opslaat *@
    <form asp-controller="Scoring" asp-action="SaveScores" method="post" id="scoringForm">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="GameSessionId" />
        <input type="hidden" asp-for="StageId" />
        <input type="hidden" name="raceId" value="@selectedRaceId" />

        <section class="scoring-section-header">
            <h2>Rit @stageNumber Resultaten</h2>
            <button type="submit" class="scoring-publish-btn">Scores Publiceren</button>
        </section>

        @* Datalist met alle beschikbare renners van deze race *@
        <datalist id="cyclistList"></datalist>

        @* Top 25 resultaten *@
        <section class="scoring-results-list">
            @for (int i = 0; i < Model.Results.Count; i++)
            {
                <div class="scoring-result-row">
                    <div class="scoring-position">@Model.Results[i].Position</div>

                    <input type="hidden" asp-for="Results[i].Position" />
                    <input type="hidden" asp-for="Results[i].CyclistId" class="js-cyclist-id" />

                    <input type="text"
                           class="scoring-rider-input js-cyclist-name"
                           list="cyclistList"
                           value="@Model.Results[i].CyclistName"
                           placeholder="Zoek renner..."
                           autocomplete="off"
                           onfocus="updateCyclistList(this)"
                           oninput="syncCyclistId(this); updateCyclistList(this)" />

                    @* Truien binnen Top 25 *@
                    <div class="scoring-jersey-options">

                        <label class="jersey-dot jersey-red" title="@yellowName">
                            <input type="radio"
                                   name="JerseyYellow"
                                   value="@i"
                            @(Model.Results[i].HasYellowJersey ? "checked" : "")
                                   onchange="updateJerseyHiddenInputs(this, 'Yellow', @i)" />
                            <span></span>
                        </label>

                        <label class="jersey-dot jersey-green" title="@greenName">
                            <input type="radio"
                                   name="JerseyGreen"
                                   value="@i"
                            @(Model.Results[i].HasGreenJersey ? "checked" : "")
                                   onchange="updateJerseyHiddenInputs(this, 'Green', @i)" />
                            <span></span>
                        </label>

                        <label class="jersey-dot jersey-blue" title="@polkaName">
                            <input type="radio"
                                   name="JerseyPolka"
                                   value="@i"
                            @(Model.Results[i].HasPolkaJersey ? "checked" : "")
                                   onchange="updateJerseyHiddenInputs(this, 'Polka', @i)" />
                            <span></span>
                        </label>

                        <label class="jersey-dot jersey-white" title="White Jersey">
                            <input type="radio"
                                   name="JerseyWhite"
                                   value="@i"
                            @(Model.Results[i].HasWhiteJersey ? "checked" : "")
                                   onchange="updateJerseyHiddenInputs(this, 'White', @i)" />
                            <span></span>
                        </label>

                        @* Deze hidden inputs worden mee gepost naar de controller *@
                        <input type="hidden" name="Results[@i].HasYellowJersey" id="HasYellow_@i" value="@(Model.Results[i].HasYellowJersey ? "true" : "false")" />
                        <input type="hidden" name="Results[@i].HasGreenJersey" id="HasGreen_@i" value="@(Model.Results[i].HasGreenJersey ? "true" : "false")" />
                        <input type="hidden" name="Results[@i].HasPolkaJersey" id="HasPolka_@i" value="@(Model.Results[i].HasPolkaJersey ? "true" : "false")" />
                        <input type="hidden" name="Results[@i].HasWhiteJersey" id="HasWhite_@i" value="@(Model.Results[i].HasWhiteJersey ? "true" : "false")" />
                    </div>
                </div>
            }
        </section>

        @* Truien die niet in de Top 25 staan *@
        <section class="scoring-section-header scoring-jersey-header">
            <h2>Truien buiten Top 25</h2>
        </section>

        <section class="scoring-card scoring-outside-jerseys">

            <div class="outside-jersey-row">
                <label class="outside-jersey-label">
                    <span class="outside-jersey-dot outside-red"></span> @yellowName buiten Top 25
                </label>
                <input type="hidden" asp-for="YellowOutsideTop25CyclistId" class="js-outside-jersey-id" data-jersey="Yellow" />
                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@yellowOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="Yellow"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('Yellow')" />
            </div>

            <div class="outside-jersey-row">
                <label class="outside-jersey-label">
                    <span class="outside-jersey-dot outside-green"></span> @greenName buiten Top 25
                </label>
                <input type="hidden" asp-for="GreenOutsideTop25CyclistId" class="js-outside-jersey-id" data-jersey="Green" />
                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@greenOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="Green"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('Green')" />
            </div>

            <div class="outside-jersey-row">
                <label class="outside-jersey-label">
                    <span class="outside-jersey-dot outside-blue"></span> @polkaName buiten Top 25
                </label>
                <input type="hidden" asp-for="PolkaOutsideTop25CyclistId" class="js-outside-jersey-id" data-jersey="Polka" />
                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@blueOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="Polka"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('Polka')" />
            </div>

            <div class="outside-jersey-row">
                <label class="outside-jersey-label">
                    <span class="outside-jersey-dot outside-white"></span> White Jersey buiten Top 25
                </label>
                <input type="hidden" asp-for="WhiteOutsideTop25CyclistId" class="js-outside-jersey-id" data-jersey="White" />
                <input type="text"
                       class="scoring-rider-input js-outside-jersey-name"
                       list="cyclistList"
                       value="@whiteOutsideName"
                       placeholder="Zoek renner..."
                       autocomplete="off"
                       data-jersey="White"
                       onfocus="updateCyclistList(this)"
                       oninput="syncCyclistId(this); updateCyclistList(this); clearTop25Jersey('White')" />
            </div>
        </section>
    </form>
</div>

@section Scripts {
    <script>
        // Alle renners worden vanuit C# naar JavaScript gezet
        const allCyclists = [
            @foreach (var rider in Model.AvailableCyclists)
            {
                    <text>{ id: "@rider.Value", name: @Html.Raw(JsonSerializer.Serialize(rider.Text)) },</text>
            }
        ];

        // Radio button opnieuw aanklikken = trui weghalen
        document.querySelectorAll('.jersey-dot input[type="radio"]').forEach(radio => {
            radio.addEventListener('click', function () {
                if (this.dataset.waschecked === 'true') {
                    this.checked = false;
                    this.dataset.waschecked = 'false';

                    const color = this.name.replace('Jersey', '');
                    const index = this.value;
                    const hidden = document.getElementById(`Has${color}_${index}`);

                    if (hidden) {
                        hidden.value = "false";
                    }
                } else {
                    document.querySelectorAll(`input[name="${this.name}"]`).forEach(r => r.dataset.waschecked = 'false');
                    this.dataset.waschecked = 'true';
                }
            });
        });

        // Zet de juiste hidden trui waarde op true
        function updateJerseyHiddenInputs(radioElement, color, currentIndex) {
            document.querySelectorAll(`input[id^='Has${color}_']`).forEach(hidden => hidden.value = "false");

            const currentHidden = document.getElementById(`Has${color}_${currentIndex}`);

            if (currentHidden && radioElement.checked) {
                currentHidden.value = "true";
                clearOutsideJersey(color);
            }
        }

        // Haalt het juiste hidden cyclistId veld op
        function getHiddenInput(textInput) {
            const row = textInput.closest(".scoring-result-row, .outside-jersey-row");

            if (!row) {
                return null;
            }

            return textInput.classList.contains("js-cyclist-name")
                ? row.querySelector(".js-cyclist-id")
                : row.querySelector(".js-outside-jersey-id");
        }

        // Vult de autocomplete lijst met renners
        function updateCyclistList(activeInput) {
            const datalist = document.getElementById("cyclistList");

            datalist.innerHTML = "";

            allCyclists.forEach(cyclist => {
                const option = document.createElement("option");
                option.value = cyclist.name;
                datalist.appendChild(option);
            });
        }

        // Koppelt de getypte naam aan de juiste cyclistId
        function syncCyclistId(input) {
            const hidden = getHiddenInput(input);

            if (!hidden) {
                return;
            }

            const typedName = input.value.trim().toLowerCase();
            const cyclist = allCyclists.find(c => c.name.toLowerCase() === typedName);

            hidden.value = cyclist ? cyclist.id : "";

            checkForDuplicates();
        }

        // Als trui binnen Top 25 gekozen wordt, buiten Top 25 leegmaken
        function clearOutsideJersey(type) {
            const outsideInput = document.querySelector(`.js-outside-jersey-name[data-jersey='${type}']`);
            const outsideHidden = document.querySelector(`.js-outside-jersey-id[data-jersey='${type}']`);

            if (outsideInput) {
                outsideInput.value = "";
            }

            if (outsideHidden) {
                outsideHidden.value = "";
            }

            checkForDuplicates();
        }

        // Als trui buiten Top 25 gekozen wordt, trui binnen Top 25 uitzetten
        function clearTop25Jersey(color) {
            document.querySelectorAll(`input[name='Jersey${color}']`).forEach(rb => {
                rb.checked = false;
                rb.dataset.waschecked = 'false';
            });

            document.querySelectorAll(`input[id^='Has${color}_']`).forEach(hidden => hidden.value = "false");
        }

        // Controleert of dezelfde renner dubbel is ingevuld
        function checkForDuplicates() {
            const inputs = document.querySelectorAll('.js-cyclist-name, .js-outside-jersey-name');
            const names = [];
            const duplicates = [];

            inputs.forEach(input => {
                input.style.borderColor = "";
                input.style.backgroundColor = "";
            });

            const existingAlert = document.getElementById('duplicate-alert');

            if (existingAlert) {
                existingAlert.remove();
            }

            inputs.forEach(input => {
                const val = input.value.trim().toLowerCase();

                if (val !== "") {
                    if (names.includes(val)) {
                        duplicates.push(val);
                    }

                    names.push(val);
                }
            });

            if (duplicates.length > 0) {
                inputs.forEach(input => {
                    if (duplicates.includes(input.value.trim().toLowerCase())) {
                        input.style.borderColor = "#ef4444";
                        input.style.backgroundColor = "#fff1f2";
                    }
                });

                const alertDiv = document.createElement('div');
                alertDiv.id = 'duplicate-alert';
                alertDiv.className = 'scoring-alert scoring-alert-error';
                alertDiv.innerHTML = `<strong>LET OP:</strong> Cyclist staat dubbel ingevuld!`;

                document.querySelector('.scoring-page').prepend(alertDiv);
            }
        }

        // Voorkomt opslaan als er dubbele renners zijn
        document.getElementById('scoringForm').addEventListener('submit', function (e) {
            const inputs = document.querySelectorAll('.js-cyclist-name, .js-outside-jersey-name');
            const names = Array.from(inputs)
                .map(i => i.value.trim().toLowerCase())
                .filter(n => n !== "");

            const hasDuplicates = names.some((name, index) => names.indexOf(name) !== index);

            if (hasDuplicates) {
                e.preventDefault();
                alert("Er staat een renner dubbel. Corrigeer voordat je de scores publiceert.");
            }
        });
    </script>
}