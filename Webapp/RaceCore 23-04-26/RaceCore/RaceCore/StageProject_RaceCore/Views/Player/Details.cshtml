@model StageProject_RaceCore.Models.Player

@{
    ViewData["Title"] = "Player details";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Player.css" asp-append-version="true" />

<div class="player-details-page">
    <div class="player-details-hero">
        <div class="player-details-avatar">
            @(string.IsNullOrWhiteSpace(Model.Name) ? "?" : Model.Name.Substring(0, 1).ToUpper())
        </div>

        <div>
            <p class="player-page-kicker">Player overview</p>
            <h1>@Model.Name</h1>
            <p class="player-page-subtitle">
                Overzicht van draft positie, punten en gekoppelde records.
            </p>
        </div>
    </div>

    <div class="player-stats-grid">
        <div class="player-stat-card">
            <span class="player-stat-label">Draft positie</span>
            <strong class="player-stat-value">#@Model.PositionInDraft</strong>
        </div>
        <div class="player-stat-card">
            <span class="player-stat-label">Totale punten</span>
            <strong class="player-stat-value">@Model.TotalPoints</strong>
        </div>
        <div class="player-stat-card">
            <span class="player-stat-label">Selections</span>
            <strong class="player-stat-value">@(Model.Selections?.Count ?? 0)</strong>
        </div>
        <div class="player-stat-card">
            <span class="player-stat-label">Draft turns</span>
            <strong class="player-stat-value">@(Model.DraftTurns?.Count ?? 0)</strong>
        </div>
        <div class="player-stat-card">
            <span class="player-stat-label">Punten records</span>
            <strong class="player-stat-value">@(Model.PlayerPoints?.Count ?? 0)</strong>
        </div>
    </div>

    <div class="player-details-grid">
        <div class="player-detail-card">
            <h3>Basisinformatie</h3>
            <div class="player-detail-list">
                <div><span>Naam</span><strong>@Model.Name</strong></div>
                <div><span>Player ID</span><strong>@Model.Id</strong></div>
                <div><span>Draft positie</span><strong>#@Model.PositionInDraft</strong></div>
                <div><span>Total points</span><strong>@Model.TotalPoints</strong></div>
            </div>
        </div>

        <div class="player-detail-card">
            <h3>Activiteit</h3>
            <div class="player-detail-list">
                <div><span>Selections</span><strong>@(Model.Selections?.Count ?? 0)</strong></div>
                <div><span>Draft turns</span><strong>@(Model.DraftTurns?.Count ?? 0)</strong></div>
                <div><span>Punten records</span><strong>@(Model.PlayerPoints?.Count ?? 0)</strong></div>
            </div>
        </div>
    </div>

    <div class="player-form-actions">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="player-btn player-btn-primary">Bewerken</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="player-btn player-btn-danger">Verwijderen</a>
        <a asp-action="Index" class="player-btn player-btn-light">Terug</a>
    </div>
</div>