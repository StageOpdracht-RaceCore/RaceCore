@model StageProject_RaceCore.Models.Race

@{
    ViewData["Title"] = "Race Details";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<link rel="stylesheet" href="~/css/Race.css" asp-append-version="true" />

<div class="player-details-page">
    <div class="player-details-hero">
        <div class="player-details-avatar">
            @Model.Name.Substring(0, 1).ToUpper()
        </div>
        <div>
            <p class="player-page-kicker">RaceCore Management</p>
            <h1>@Model.Name</h1>
            <p class="player-page-subtitle">@Model.Year Edition</p>
        </div>
    </div>

    <div class="player-stats-grid">
        <div class="player-stat-card">
            <span class="player-stat-label">Jaar</span>
            <strong class="player-stat-value">@Model.Year</strong>
        </div>
        <div class="player-stat-card">
            <span class="player-stat-label">Etappes</span>
            <strong class="player-stat-value">@(Model.Stages?.Count ?? 0)</strong>
        </div>
        <div class="player-stat-card">
            <span class="player-stat-label">Inschrijvingen</span>
            <strong class="player-stat-value">@(Model.RaceEntries?.Count ?? 0)</strong>
        </div>
    </div>

    <div class="player-details-grid">
        <div class="player-detail-card">
            <h3>Race Informatie</h3>
            <div class="player-detail-list">
                <div><span>Startdatum</span><strong>@(Model.StartDate?.ToString("yyyy-MM-dd") ?? "-")</strong></div>
                <div><span>Einddatum</span><strong>@(Model.EndDate?.ToString("yyyy-MM-dd") ?? "-")</strong></div>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <h3>Stages</h3>
        @if (Model.Stages != null && Model.Stages.Any())
        {
            <div class="table-responsive">
                <table class="player-data-table table-sm">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Naam</th>
                            <th>Datum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in Model.Stages)
                        {
                            <tr>
                                <td>@s.Id</td>
                                <td><strong>@s.Name</strong></td>
                                <td>@(s.Date?.ToString("yyyy-MM-dd") ?? "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted p-3">Geen etappes voor deze race.</p>
        }
    </div>

